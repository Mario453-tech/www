<?php
$_codexGuardStart = class_exists('GameLog', false) ? GameLog::pageStart('admin/reset_password.php') : microtime(true);
try {

require_once __DIR__ . '/../src/init.php';
require_once __DIR__ . '/../src/AdminAuth.php';

$token = Validator::sanitize($_GET['token'] ?? '');
$error = $success = '';

if (empty($token) || !AdminAuth::verifyResetToken($token)) {
    $error = 'Link jest nieprawidłowy lub wygasł. Poproś o nowy.';
    $token = '';
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!CSRF::validateToken($_POST['csrf_token'] ?? '')) {
        $error = 'Błąd zabezpieczeń — odśwież stronę.';
    } else {
        $pass1 = $_POST['password']  ?? '';
        $pass2 = $_POST['password2'] ?? '';
        $tok   = Validator::sanitize($_POST['token'] ?? '');

        if ($pass1 !== $pass2) {
            $error = 'Hasła nie są identyczne.';
        } elseif (strlen($pass1) < 8) {
            $error = 'Hasło musi mieć minimum 8 znaków.';
        } else {
            $result = AdminAuth::resetPassword($tok, $pass1);
            if ($result['success']) {
                header('Location: /admin/login.php?logged_out=1');
                exit();
            }
            $error = $result['message'];
        }
    }
}

$csrf = CSRF::generateToken();
?>
<!DOCTYPE html><html lang="pl"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Nowe hasło — Admin</title>
<link rel="stylesheet" href="<?= asset('/assets/css/admin.css') ?>">
</head>
<body class="auth-page">
<div class="auth-wrap">
    <div class="auth-logo"><div class="auth-logo-text">Oil<span>Corp</span></div><div class="auth-logo-sub">Nowe hasło</div></div>
    <div class="auth-card">
        <div class="auth-card-title">Ustaw nowe hasło</div>

        <?php if($error):?><div class="auth-alert auth-alert-err">⚠ <?=htmlspecialchars($error)?></div><?php endif?>
        <?php if($success):?><div class="auth-alert auth-alert-ok">✓ <?=htmlspecialchars($success)?></div><?php endif?>

        <?php if($token && !$success): ?>
        <form method="POST" id="resetForm">
            <input type="hidden" name="csrf_token" value="<?=$csrf?>">
            <input type="hidden" name="token" value="<?=htmlspecialchars($token)?>">

            <div class="auth-field">
                <label class="auth-label" for="pw1">Nowe hasło</label>
                <div class="auth-pw-wrap">
                    <input class="auth-input" type="password" name="password" id="pw1"
                        placeholder="minimum 8 znaków" required oninput="checkStrength(this.value)">
                    <button type="button" class="auth-pw-eye" onclick="togglePw('pw1')">👁</button>
                </div>
                <div class="auth-strength"><div class="auth-strength-bar" id="sbar"></div></div>
                <div class="auth-hint" id="shint">Podaj hasło</div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="pw2">Powtórz hasło</label>
                <div class="auth-pw-wrap">
                    <input class="auth-input" type="password" name="password2" id="pw2"
                        placeholder="••••••••" required oninput="checkMatch()">
                    <button type="button" class="auth-pw-eye" onclick="togglePw('pw2')">👁</button>
                </div>
            </div>

            <button type="submit" class="auth-btn" id="submitBtn">Ustaw nowe hasło</button>
        </form>
        <?php else: ?>
            <a href="/admin/forgot_password.php" class="auth-btn" class="auth-btn auth-btn-block">Wyślij nowy link →</a>
        <?php endif ?>

        <a href="/admin/login.php" class="auth-lnk-center">← Wróć do logowania</a>
    </div>
</div>
<script>
function togglePw(id){var i=document.getElementById(id);i.type=i.type==='password'?'text':'password';}
function checkStrength(v){
    var bar=document.getElementById('sbar'),hint=document.getElementById('shint');
    var score=0;
    if(v.length>=8)score++;if(v.length>=12)score++;
    if(/[A-Z]/.test(v))score++;if(/[0-9]/.test(v))score++;if(/[^A-Za-z0-9]/.test(v))score++;
    var colors=['#e05555','#e05555','#e0b644','#c8a84b','#4ec97a','#4ec97a'];
    var labels=['','Za krótkie','Słabe','Średnie','Dobre','Silne'];
    bar.style.width=(score*20)+'%';bar.style.background=colors[score];
    hint.textContent=labels[score];hint.style.color=colors[score];
    checkMatch();
}
function checkMatch(){
    var p1=document.getElementById('pw1').value,p2=document.getElementById('pw2').value;
    var btn=document.getElementById('submitBtn');
    if(p2.length>0){document.getElementById('pw2').style.borderColor=p1===p2?'var(--green)':'var(--red)';}
    btn.disabled=!(p1===p2&&p1.length>=8);
}
</script>
</body></html>
<?php
} catch (Throwable $e) {
    if (class_exists('GameLog', false)) {
        GameLog::error('admin/reset_password.php', 'Unhandled exception', $e);
    }
    if (!headers_sent()) {
        http_response_code(500);
    }
    echo 'Wystapil blad aplikacji.';
} finally {
    if (class_exists('GameLog', false)) {
        GameLog::pageEnd('admin/reset_password.php', $_codexGuardStart);
    }
}
