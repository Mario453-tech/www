$params       = [];

if ($filterPlayer !== '') {
    $where    = 'WHERE cm.is_deleted = 0 AND cm.username LIKE ?';
    $params[] = '%' . $filterPlayer . '%';
} else {
    $where = 'WHERE cm.is_deleted = 0';
}

$expiredCutoff = date('Y-m-d H:i:s', strtotime('-30 minutes'));

