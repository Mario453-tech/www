$totalPages = max(1, (int)ceil($total / $perPage));

$stmt = $db->prepare("
    SELECT cm.id, cm.sender_id AS player_id, cm.username, cm.message,
           cm.created_at, cm.is_deleted, cm.channel, cm.is_admin, cm.is_pinned
