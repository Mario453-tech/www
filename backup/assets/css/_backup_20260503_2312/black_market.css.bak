/* ═══════════════════════════════════════════════════════════
   CZARNY RYNEK ROPY — style
   ═══════════════════════════════════════════════════════════ */

/* ── Zakładki market ─────────────────────────────────────── */
.market-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--gold-border);
}
.market-tab {
    padding: .75rem 1.25rem;
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--text2);
    font-weight: 500;
    font-size: .95rem;
    border-bottom: 2px solid transparent;
    transition: all .2s;
}
.market-tab:hover {
    color: var(--text);
    background: var(--gold-dim);
}
.market-tab.active {
    color: var(--gold);
    border-bottom-color: var(--gold);
}
.market-tab-content {
    display: none;
}
.market-tab-content.active {
    display: block;
}

/* ── Score bar ───────────────────────────────────────────── */
.bm-score-wrap {
    margin-bottom: 1.5rem;
}
.bm-score-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .5rem;
}
.bm-score-label {
    font-weight: 600;
    color: var(--text);
}
.bm-score-value {
    font-weight: 700;
    font-size: 1.1rem;
}
.bm-score-track {
    width: 100%;
    height: 10px;
    background: var(--bg3);
    border-radius: 5px;
    overflow: hidden;
}
.bm-score-fill {
    height: 100%;
    border-radius: 5px;
    transition: width .5s ease, background .3s;
}
.bm-score-low  { background: var(--green); }
.bm-score-mid  { background: var(--gold); }
.bm-score-high { background: var(--red); }

.bm-score-desc {
    margin-top: .35rem;
    font-size: .82rem;
    color: var(--text3);
}

/* ── Warning banner ──────────────────────────────────────── */
.bm-warning {
    display: none;
    padding: .75rem 1rem;
    margin-bottom: 1rem;
    background: var(--red-dim);
    border: 1px solid rgba(224,85,85,.3);
    border-radius: 8px;
    color: var(--red);
    font-size: .9rem;
    font-weight: 500;
}

/* ── Lista graczy (10 kolumn) ────────────────────────────── */
.bm-list { font-size: .9rem; }

.bm-list-head,
.bm-list-row {
    display: grid;
    grid-template-columns: 3rem 1fr 1fr 10rem 4rem 4rem 7rem 7rem 5rem 3rem;
    gap: 0 .5rem;
    align-items: center;
    padding: .5rem .75rem;
}

.bm-list-head {
    color: var(--text2);
    font-weight: 600;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .04em;
    border-bottom: 1px solid var(--gold-border);
}

.bm-list-row {
    border-bottom: 1px solid rgba(255,255,255,.04);
    color: var(--text);
}

.bm-list-row:hover { background: rgba(200,168,75,.04); }

/* ── Lista transakcji (9 kolumn) ─────────────────────────── */
.bm-tx-head,
.bm-tx-row {
    display: grid;
    grid-template-columns: 3rem 1fr 5rem 7rem 7rem 7rem 5rem 5rem 9rem;
    gap: 0 .5rem;
    align-items: center;
    padding: .5rem .75rem;
}

.bm-tx-head {
    color: var(--text2);
    font-weight: 600;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .04em;
    border-bottom: 1px solid var(--gold-border);
}

.bm-tx-row {
    border-bottom: 1px solid rgba(255,255,255,.04);
    color: var(--text);
}

.bm-tx-row:hover         { background: rgba(200,168,75,.04); }
.bm-tx-row--detected     { background: rgba(224,85,85,.06); }
.bm-tx-row--detected:hover { background: rgba(224,85,85,.1); }

/* ── Inline form w liście ────────────────────────────────── */
.bm-score-form {
    display: inline-flex;
    gap: 4px;
    align-items: center;
}

/* ── Meta (username + company) ───────────────────────────── */
.bm-player-company {
    font-size: .78rem;
    color: var(--text3);
}

/* ── Data ────────────────────────────────────────────────── */
.bm-cell-date {
    font-size: .82rem;
    color: var(--text3);
}

/* ── Credit delta ────────────────────────────────────────── */
.bm-cell-credit--neg { color: var(--red); }
.bm-cell-credit--neu { color: var(--text3); }

/* Ryzyko */
.bm-risk-low  { color: var(--green); font-weight: 600; }
.bm-risk-mid  { color: var(--gold);  font-weight: 600; }
.bm-risk-high { color: var(--red);   font-weight: 600; }

/* Buyer */
.bm-buyer {
    font-style: italic;
    color: var(--text2);
}

/* Expires */
.bm-expires {
    color: var(--text3);
    font-size: .85rem;
}

/* ── Przycisk sprzedaży ──────────────────────────────────── */
.bm-sell-btn {
    padding: .35rem .85rem;
    font-size: .82rem;
    font-weight: 600;
    border-radius: 6px;
}

/* ── Historia ────────────────────────────────────────────── */
.bm-status-ok       { color: var(--green); font-weight: 600; }
.bm-status-detected { color: var(--red);   font-weight: 600; }
.bm-penalty         { color: var(--red);   font-weight: 600; }

/* ── Config grid ─────────────────────────────────────────── */
.config-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
}

.config-label {
    display: block;
    font-size: .82rem;
    color: var(--text2);
    margin-bottom: .25rem;
}

.config-input {
    width: 100%;
    padding: .4rem .6rem;
    background: var(--bg3);
    border: 1px solid var(--gold-border);
    border-radius: 4px;
    color: var(--text);
    font-size: .9rem;
}

.config-submit { margin-top: 1.25rem; }

/* ── Filter note ─────────────────────────────────────────── */
.bm-filter-note {
    font-size: .8rem;
    color: var(--text2);
}

.bm-filter-reset {
    color: var(--gold);
    margin-left: .5rem;
}

/* ── Empty state ─────────────────────────────────────────── */
.bm-empty {
    text-align: center;
    color: var(--text3);
    padding: 2rem 0 !important;
    font-style: italic;
}

/* ── Toast (fallback) ────────────────────────────────────── */
.bm-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    padding: .85rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: .9rem;
    z-index: 9999;
    opacity: 0;
    transition: opacity .3s, transform .3s;
    pointer-events: none;
}
.bm-toast-show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
}
.bm-toast-success {
    background: var(--green);
    color: #fff;
}
.bm-toast-error {
    background: var(--red);
    color: #fff;
}

/* ── Subtitle ────────────────────────────────────────────── */
.bm-subtitle {
    color: var(--text2);
    font-size: .9rem;
    margin-bottom: 1.25rem;
}

/* ── Oferty gracza — div grid (7 kolumn) ─────────────────── */
.bm-offers-grid  { font-size: .9rem; }

.bm-offer-head,
.bm-offer-row {
    display: grid;
    grid-template-columns: 1fr 6rem 7rem 8rem 5rem 6rem 6rem;
    gap: 0 .5rem;
    align-items: center;
    padding: .5rem .75rem;
}

.bm-offer-head {
    color: var(--text2);
    font-weight: 600;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .04em;
    border-bottom: 1px solid var(--gold-border);
}

.bm-offer-row {
    border-bottom: 1px solid rgba(255,255,255,.04);
    color: var(--text);
}

.bm-offer-row:hover { background: rgba(200,168,75,.04); }

/* ── Historia gracza — div grid (6 kolumn) ───────────────── */
.bm-history-grid  { font-size: .9rem; }

.bm-history-head,
.bm-history-row {
    display: grid;
    grid-template-columns: 10rem 6rem 8rem 8rem 8rem 6rem;
    gap: 0 .5rem;
    align-items: center;
    padding: .5rem .75rem;
}

.bm-history-head {
    color: var(--text2);
    font-weight: 600;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .04em;
    border-bottom: 1px solid var(--gold-border);
}

.bm-history-row {
    border-bottom: 1px solid rgba(255,255,255,.04);
    color: var(--text);
}

.bm-history-row:hover      { background: rgba(200,168,75,.04); }
.bm-row-detected           { background: rgba(224,85,85,.06); }
.bm-row-detected:hover     { background: rgba(224,85,85,.1); }

/* ── Section heading ─────────────────────────────────────── */
.bm-section-heading {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 .75rem;
    padding-bottom: .4rem;
    border-bottom: 1px solid var(--gold-border);
}

/* ── Admin table ─────────────────────────────────────────── */
.bm-admin-score-input {
    width: 70px;
    padding: .3rem .5rem;
    background: var(--bg3);
    border: 1px solid var(--gold-border);
    border-radius: 4px;
    color: var(--text);
    font-size: .85rem;
    text-align: center;
}
.bm-admin-save-btn {
    padding: .25rem .65rem;
    font-size: .78rem;
}

/* ═══════════════════════════════════════════════════════════
   RESPONSYWNOŚĆ MOBILNA
═══════════════════════════════════════════════════════════ */

/* Tabele wielokolumnowe — przewijane poziomo na mobile */
@media (max-width: 900px) {
  /* Lista graczy (10 kol.) */
  .bm-list {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .bm-list-head,
  .bm-list-row {
    min-width: 780px;
  }

  /* Lista transakcji (9 kol.) */
  .bm-tx-list {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .bm-tx-head,
  .bm-tx-row {
    min-width: 700px;
  }

  /* Oferty gracza (7 kol.) */
  .bm-offers-grid {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .bm-offer-head,
  .bm-offer-row {
    min-width: 580px;
  }

  /* Historia gracza (6 kol.) */
  .bm-history-grid {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .bm-history-head,
  .bm-history-row {
    min-width: 520px;
  }
}

/* ── Mobile (≤ 600px) ─────────────────────────────────── */
@media (max-width: 600px) {
  /* Karty towarów → 1 kolumna */
  .bm-goods-grid {
    grid-template-columns: 1fr;
  }

  /* Nagłówek strony */
  .bm-page-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  /* Filtry → wrap */
  .bm-filters {
    flex-wrap: wrap;
    gap: 6px;
  }
}
