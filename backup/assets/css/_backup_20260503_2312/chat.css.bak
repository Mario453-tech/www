/* ═══════════════════════════════════════════════════════════════
   CHAT + NEWS — wrapper i panel aktualności
   ═══════════════════════════════════════════════════════════════ */

/* Wrapper: newsy po lewej, czat po prawej */
.chat-news-wrapper {
    display: flex;
    gap: 12px;
    align-items: stretch;
}

/* Panel aktualności — zajmuje ~30% szerokości */
.news-panel {
    flex: 0 0 30%;
    min-width: 180px;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    overflow: hidden;
}

.news-panel h2 {
    padding: 12px 16px 10px;
    margin: 0;
    font-size: .85rem;
    border-bottom: 1px solid var(--brd, rgba(255,255,255,.08));
}

.news-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
}

.news-list::-webkit-scrollbar { width: 4px; }
.news-list::-webkit-scrollbar-track { background: transparent; }
.news-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 2px; }

.news-item {
    border-bottom: 1px solid rgba(255,255,255,.06);
    padding-bottom: 8px;
}
.news-item:last-child { border-bottom: none; padding-bottom: 0; }

.news-item--pinned {
    background: rgba(200,168,75,.07);
    border-left: 2px solid rgba(200,168,75,.5);
    padding: 6px 8px;
    border-radius: 0 4px 4px 0;
    margin: 0 -4px;
}

.news-item-title {
    font-size: .78rem;
    font-weight: 600;
    color: rgba(232,232,240,.9);
    margin-bottom: 3px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.news-item-pin {
    color: #c8a84b;
    font-size: .7rem;
}

.news-item-content {
    font-size: .74rem;
    color: rgba(232,232,240,.65);
    line-height: 1.45;
    word-break: break-word;
}

.news-item-date {
    font-size: .66rem;
    color: rgba(232,232,240,.3);
    margin-top: 4px;
}

.news-loading {
    color: rgba(232,232,240,.35);
    font-size: .75rem;
    text-align: center;
    margin: auto;
}

/* Czat zajmuje pozostałe ~70% (flex:1) */
.chat-box {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    overflow: hidden;
}

.chat-box h2 {
    padding: 12px 16px 10px;
    margin: 0;
    font-size: .85rem;
    border-bottom: 1px solid var(--brd, rgba(255,255,255,.08));
}

.chat-messages {
    height: 220px;
    overflow-y: auto;
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    scroll-behavior: smooth;
}

.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 2px; }

.chat-loading {
    color: rgba(232,232,240,.35);
    font-size: .75rem;
    text-align: center;
    margin: auto;
}

/* ── Pojedyncza wiadomość ─────────────────────────────────────── */
.chat-msg {
    display: flex;
    gap: 6px;
    font-size: .78rem;
    line-height: 1.4;
    animation: chatFadeIn .15s ease;
}

@keyframes chatFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
}

.chat-msg-time {
    color: rgba(232,232,240,.3);
    font-size: .7rem;
    white-space: nowrap;
    padding-top: 1px;
    min-width: 52px;
}

.chat-msg-author {
    font-weight: 600;
    white-space: nowrap;
    color: var(--orange, #c8a84b);
}

.chat-msg--mine .chat-msg-author {
    color: #6fcf97;
}

.chat-msg-text {
    color: rgba(232,232,240,.85);
    word-break: break-word;
}

/* ── Formularz ────────────────────────────────────────────────── */
.chat-form {
    display: flex;
    gap: 6px;
    padding: 8px 12px;
    border-top: 1px solid var(--brd, rgba(255,255,255,.08));
}

.chat-input {
    flex: 1;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 4px;
    color: #e8e8f0;
    font-size: .82rem;
    padding: 5px 10px;
    outline: none;
    transition: border-color .15s;
}

.chat-input:focus {
    border-color: var(--orange, #c8a84b);
}

.chat-send {
    padding: 5px 14px;
    font-size: .8rem;
    white-space: nowrap;
}

/* ── System / info ────────────────────────────────────────────── */
.chat-msg--system .chat-msg-author { color: rgba(232,232,240,.4); font-weight: normal; }
.chat-msg--system .chat-msg-text   { color: rgba(232,232,240,.4); font-style: italic; }

/* ── Wiadomości administratora ───────────────────────────────── */
.chat-msg--admin {
    background: rgba(200,168,75,.08);
    border-left: 2px solid rgba(200,168,75,.5);
    padding: 3px 6px 3px 8px;
    border-radius: 0 4px 4px 0;
    margin: 2px 0;
}
.chat-msg--admin .chat-msg-author {
    color: #c8a84b;
    font-weight: 700;
}
.chat-msg--admin .chat-msg-text {
    color: rgba(232,232,240,.95);
}

/* ── Pasek przypiętych — stały, poza scrollem ─────────────────── */
.chat-pinned-bar {
    border-bottom: 1px solid rgba(200,168,75,.25);
    background: rgba(200,168,75,.06);
    padding: 6px 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    max-height: 110px;
    overflow-y: auto;
}

.chat-pinned-bar::-webkit-scrollbar { width: 3px; }
.chat-pinned-bar::-webkit-scrollbar-thumb { background: rgba(200,168,75,.3); border-radius: 2px; }

.chat-pinned-bar-label {
    font-size: .62rem;
    color: rgba(200,168,75,.55);
    text-transform: uppercase;
    letter-spacing: .06em;
    font-weight: 600;
    margin-bottom: 2px;
}

.chat-pinned-entry {
    display: flex;
    gap: 5px;
    font-size: .76rem;
    line-height: 1.35;
    align-items: flex-start;
}

.chat-pinned-entry-icon {
    color: #c8a84b;
    flex-shrink: 0;
    font-size: .7rem;
    padding-top: 1px;
}

.chat-pinned-entry-text {
    color: rgba(232,232,240,.88);
    word-break: break-word;
}

.chat-msg--pinned {
    background: rgba(200,168,75,.12);
    border-left: 2px solid #c8a84b;
    padding: 3px 6px 3px 8px;
    border-radius: 0 4px 4px 0;
}

/* ── Chat v2: przyciski report i DM ── */
.chat-msg { position: relative; }
.chat-msg-opts {
    display: inline-flex; gap: 4px;
    opacity: 0; transition: opacity .15s;
    margin-left: 6px; vertical-align: middle;
}
.chat-msg:hover .chat-msg-opts { opacity: 1; }
.chat-report-btn, .chat-dm-btn {
    background: none; border: none; cursor: pointer;
    font-size: 11px; padding: 1px 4px;
    color: rgba(255,255,255,.35);
    border-radius: 3px; text-decoration: none;
    transition: color .15s, background .15s;
}
.chat-report-btn:hover { color: #e24b4a; background: rgba(226,75,74,.12); }
.chat-dm-btn:hover { color: #378add; background: rgba(55,138,221,.12); }