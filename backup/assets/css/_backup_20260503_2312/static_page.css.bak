/* ═══════════════════════════════════════════════════════════════
   STATIC PAGE — styl podstron statycznych (Regulamin, Polityka itp.)
   ═══════════════════════════════════════════════════════════════ */

.static-page-wrap {
    max-width: 820px;
    margin: 30px auto;
    padding: 0 16px 60px;
}

.static-page-hdr {
    text-align: center;
    padding: 36px 16px 28px;
    border-bottom: 1px solid var(--border2);
    margin-bottom: 28px;
}

.static-page-icon {
    font-size: 40px;
    display: block;
    margin-bottom: 10px;
}

.static-page-hdr h1 {
    font-size: 24px;
    font-weight: 800;
    color: var(--gold);
    margin: 0 0 6px;
    letter-spacing: .5px;
}

.static-page-meta {
    font-size: 11px;
    color: var(--text3);
    letter-spacing: .5px;
    text-transform: uppercase;
    margin: 0;
}

/* ── Treść WYSIWYG ── */
.static-page-content {
    font-size: 14px;
    line-height: 1.75;
    color: var(--text2);
}

.static-page-content h1,
.static-page-content h2,
.static-page-content h3 {
    color: var(--gold);
    margin: 24px 0 10px;
}

.static-page-content h2 { font-size: 17px; border-bottom: 1px solid var(--border2); padding-bottom: 6px; }
.static-page-content h3 { font-size: 15px; }

.static-page-content p   { margin: 0 0 12px; }
.static-page-content ul,
.static-page-content ol  { margin: 0 0 14px; padding-left: 22px; }
.static-page-content li  { margin-bottom: 5px; }

.static-page-content a {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
}
.static-page-content a:hover { color: var(--orange); }

.static-page-content strong { color: var(--text); }

.static-page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 14px 0;
    font-size: 13px;
}
.static-page-content th,
.static-page-content td {
    border: 1px solid var(--border2);
    padding: 7px 12px;
    text-align: left;
}
.static-page-content th {
    background: var(--bg3);
    color: var(--muted2);
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .5px;
}

.static-page-content blockquote {
    border-left: 3px solid var(--gold);
    margin: 14px 0;
    padding: 8px 16px;
    background: var(--bg3);
    color: var(--muted2);
    font-style: italic;
}

.static-page-content code {
    background: var(--bg3);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
    color: var(--gold);
}

/* ── Przycisk powrót ── */
.static-page-back {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border2);
    text-align: center;
}
