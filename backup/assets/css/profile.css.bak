/* profile.css
   Style specyficzne dla profilu gracza.
   Wspólne elementy topbara i utility zostają w style.css.
*/

.profile-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 24px 16px 60px;
}

.profile-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 24px;
    margin-top: 24px;
}

.profile-avatar-card {
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin-bottom: 16px;
}

.profile-avatar-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: 14px;
}

.profile-avatar-img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(200, 168, 75, .4);
    display: block;
}

.profile-avatar-placeholder {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: rgba(200, 168, 75, .15);
    border: 2px solid rgba(200, 168, 75, .35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    font-weight: 700;
    color: var(--gold);
}

.profile-avatar-overlay {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, .5);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    opacity: 0;
    transition: opacity .2s;
    cursor: pointer;
}

.profile-avatar-wrap:hover .profile-avatar-overlay {
    opacity: 1;
}

.profile-username {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
}

.profile-company {
    font-size: 12px;
    color: var(--gold);
    margin-bottom: 8px;
}

.profile-avatar-hint {
    font-size: 11px;
    color: rgba(255, 255, 255, .3);
    margin-top: 8px;
}

.profile-stats-card {
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 12px;
    padding: 16px;
}

.profile-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255, 255, 255, .05);
    font-size: 12px;
}

.profile-stat:last-child {
    border-bottom: none;
}

.profile-stat-label {
    color: rgba(255, 255, 255, .45);
}

.profile-stat-value {
    font-weight: 600;
    color: var(--text);
    text-align: right;
}

.profile-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.profile-card {
    background: rgba(255, 255, 255, .04);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 12px;
    padding: 24px;
}

.profile-card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--gold);
    margin: 0 0 20px 0;
}

.profile-field {
    margin-bottom: 16px;
}

.profile-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, .55);
    margin-bottom: 6px;
    letter-spacing: .5px;
    text-transform: uppercase;
}

.profile-input {
    width: 100%;
    box-sizing: border-box;
    background: rgba(255, 255, 255, .06);
    border: 1px solid rgba(255, 255, 255, .12);
    border-radius: 7px;
    padding: 10px 14px;
    font-size: 14px;
    color: var(--text);
    font-family: inherit;
    transition: border-color .2s;
}

.profile-input:focus {
    outline: none;
    border-color: rgba(200, 168, 75, .5);
}

.profile-hint {
    display: block;
    font-size: 11px;
    color: rgba(255, 255, 255, .3);
    margin-top: 5px;
}

.profile-password-wrap {
    position: relative;
}

.profile-password-wrap .profile-input {
    padding-right: 42px;
}

.profile-pass-toggle {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    font-size: 16px;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    color: rgba(255, 255, 255, .4);
}

.profile-pass-toggle:hover {
    color: rgba(255, 255, 255, .8);
}

.profile-pass-strength,
.profile-pass-match {
    font-size: 11px;
    font-weight: 600;
    margin-top: 5px;
    min-height: 16px;
}

.profile-bm-heading {
    color: var(--gold);
    font-size: .95rem;
    margin: 0 0 .75rem;
    font-weight: 600;
}

.profile-bm-score--low {
    color: var(--green);
}

.profile-bm-score--mid {
    color: var(--gold);
}

.profile-bm-score--high {
    color: var(--red);
}

@media (max-width: 700px) {
    .profile-grid {
        grid-template-columns: 1fr;
    }
}
