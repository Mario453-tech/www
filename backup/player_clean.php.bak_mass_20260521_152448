<?php
require_once __DIR__ . '/init.php';
AdminAuth::requireLogin();

$db  = Database::getInstance()->getConnection();
$pid = (int)($_GET['id'] ?? 0);

GameLog::step('admin/player', 'init', 1, 'start', ['pid' => $pid]);

if (!$pid) {
    GameLog::warn('admin/player', 'brak pid - redirect', []);
    header('Location: /admin/players.php');
    exit();
}

//  FUNKCJE POBIERANIA DANYCH 

function fetchPlayer(PDO $db, int $pid): array|false
{
    try {
        $stmt = $db->prepare("
            SELECT p.*, s.capacity, s.used
            FROM players p
            LEFT JOIN storage s ON p.id = s.player_id
            WHERE p.id = :id
        ");
        $stmt->execute([':id' => $pid]);
        $row = $stmt->fetch();
        GameLog::dbResult('admin/player', 'fetchPlayer', $row ? 1 : 0);
        return $row;
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchPlayer FAILED', $e, ['pid' => $pid]);
        return false;
    }
}

function fetchWells(PDO $db, int $pid): array
{
    try {
        $stmt = $db->prepare("
            SELECT w.id, w.status, w.base_production_per_hour, w.technical_condition,
                   w.level, w.upkeep_cost_per_hour,
                   COALESCE(w.location_name, wl.name, '—') AS display_name,
                   wr.name AS region_name
            FROM wells w
            LEFT JOIN world_locations wl ON wl.id = w.location_id
            LEFT JOIN world_regions   wr ON wr.id = w.region_id
            WHERE w.player_id = :id AND w.status != 'sold'
            ORDER BY w.id
        ");
        $stmt->execute([':id' => $pid]);
        $rows = $stmt->fetchAll();
        GameLog::dbResult('admin/player', 'fetchWells', count($rows));
        return $rows;
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchWells FAILED', $e, ['pid' => $pid]);
        return [];
    }
}

function fetchLoans(PDO $db, int $pid): array
{
    try {
        $s = $db->prepare("
            SELECT id, principal_amount, remaining_amount, status,
                   installment_amount, next_payment_at, created_at
            FROM loans
            WHERE player_id=:pid
            ORDER BY created_at DESC
        ");
        $s->execute([':pid' => $pid]);
        $rows = $s->fetchAll();
        GameLog::dbResult('admin/player', 'fetchLoans', count($rows));
        return $rows;
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchLoans FAILED', $e, ['pid' => $pid]);
        return [];
    }
}

function fetchActiveLoansCount(PDO $db, int $pid): int
{
    try {
        $s = $db->prepare("SELECT COUNT(*) FROM loans WHERE player_id=:pid AND status IN ('active','late')");
        $s->execute([':pid' => $pid]);
        return (int)$s->fetchColumn();
    } catch (Throwable $e) {
        return 0;
    }
}

function fetchTrustScore(PDO $db, int $pid): array
{
    try {
        $s = $db->prepare("SELECT score, last_event, last_updated FROM bank_trust_scores WHERE player_id=:pid");
        $s->execute([':pid' => $pid]);
        $row = $s->fetch();
        GameLog::dbResult('admin/player', 'fetchTrustScore', $row ? 1 : 0);
        return $row ?: ['score' => 50, 'last_event' => null, 'last_updated' => null];
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchTrustScore FAILED', $e, ['pid' => $pid]);
        return ['score' => 50, 'last_event' => null, 'last_updated' => null];
    }
}

function fetchTrustLog(PDO $db, int $pid, int $page = 1, int $perPage = 10): array
{
    try {
        $offset = ($page - 1) * $perPage;
        $s = $db->prepare("
            SELECT id, event, delta, note, created_at
            FROM bank_trust_log
            WHERE player_id=:pid
            ORDER BY created_at DESC
            LIMIT :lim OFFSET :off
        ");
        $s->bindValue(':pid', $pid, PDO::PARAM_INT);
        $s->bindValue(':lim', $perPage, PDO::PARAM_INT);
        $s->bindValue(':off', $offset, PDO::PARAM_INT);
        $s->execute();
        $rows = $s->fetchAll();
        GameLog::dbResult('admin/player', 'fetchTrustLog', count($rows));
        return $rows;
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchTrustLog FAILED', $e, ['pid' => $pid]);
        return [];
    }
}

function fetchTrustLogCount(PDO $db, int $pid): int
{
    try {
        $s = $db->prepare("SELECT COUNT(*) FROM bank_trust_log WHERE player_id=:pid");
        $s->execute([':pid' => $pid]);
        return (int)$s->fetchColumn();
    } catch (Throwable $e) {
        return 0;
    }
}

function fetchNegotiations(PDO $db, int $pid): array
{
    try {
        $s = $db->prepare("
            SELECT bn.*, l.remaining_amount, l.principal_amount
            FROM bank_negotiations bn
            JOIN loans l ON l.id = bn.loan_id
            WHERE bn.player_id=:pid ORDER BY bn.requested_at DESC LIMIT 20
        ");
        $s->execute([':pid' => $pid]);
        $rows = $s->fetchAll();
        GameLog::dbResult('admin/player', 'fetchNegotiations', count($rows));
        return $rows;
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchNegotiations FAILED', $e, ['pid' => $pid]);
        return [];
    }
}

function fetchNegEvents(PDO $db, int $negId): array
{
    try {
        $s = $db->prepare("
            SELECT * FROM bank_negotiation_events
            WHERE negotiation_id=:nid ORDER BY created_at DESC LIMIT 5
        ");
        $s->execute([':nid' => $negId]);
        return $s->fetchAll();
    } catch (Throwable $e) {
        GameLog::error('admin/player', 'fetchNegEvents FAILED', $e, ['neg_id' => $negId]);
