<?php
$_codexGuardStart = class_exists('GameLog', false) ? GameLog::pageStart('admin/alerts.php') : microtime(true);
try {

require_once __DIR__ . '/init.php';
AdminAuth::requireLogin();

$db = Database::getInstance()->getConnection();

//  Progi alertów — domyślne wartości 
$THRESHOLD_DEFAULTS = [
    'alert_loss_pct_warn'      => 8.0,
    'alert_loss_pct_critical'  => 15.0,
    'alert_price_high'         => 140.0,
    'alert_price_low'          => 70.0,
    'alert_roi_days_min'       => 2.0,
    'alert_roi_days_max'       => 6.0,
    'alert_condition_critical' => 40.0,
    'alert_wear_critical'      => 80.0,
    'alert_storage_full_pct'   => 90.0,
];

//  Zapisz progi jeśli POST 
$threshMsg = '';
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['save_thresholds'])) {
    if (!CSRF::validateToken($_POST['csrf_token'] ?? '')) {
        $threshMsg = 'error:' . t('common.csrf_error');
    } else {
        $upsert = $db->prepare("
            INSERT INTO well_config (`key`, `value`) VALUES (?, ?)
            ON DUPLICATE KEY UPDATE `value` = VALUES(`value`)
        ");
        foreach ($THRESHOLD_DEFAULTS as $key => $default) {
            $val = isset($_POST[$key]) ? (float)$_POST[$key] : $default;
            $upsert->execute([$key, $val]);
        }
        AdminLog::log('alerts_thresholds_save', t('admin.alerts.log_saved'), null, AdminAuth::getAdminUsername());
        $threshMsg = 'ok:' . t('admin.alerts.msg_saved');
    }
}

//  Wczytaj progi z well_config (fallback na domyślne) 
$cfgRows = $db->query("
    SELECT `key`, `value` FROM well_config
    WHERE `key` LIKE 'alert_%'
")->fetchAll(PDO::FETCH_KEY_PAIR);

$THRESHOLDS = [
    'loss_pct_warn'      => (float)($cfgRows['alert_loss_pct_warn']      ?? $THRESHOLD_DEFAULTS['alert_loss_pct_warn']),
    'loss_pct_critical'  => (float)($cfgRows['alert_loss_pct_critical']  ?? $THRESHOLD_DEFAULTS['alert_loss_pct_critical']),
    'price_high'         => (float)($cfgRows['alert_price_high']         ?? $THRESHOLD_DEFAULTS['alert_price_high']),
    'price_low'          => (float)($cfgRows['alert_price_low']          ?? $THRESHOLD_DEFAULTS['alert_price_low']),
    'roi_days_min'       => (float)($cfgRows['alert_roi_days_min']       ?? $THRESHOLD_DEFAULTS['alert_roi_days_min']),
    'roi_days_max'       => (float)($cfgRows['alert_roi_days_max']       ?? $THRESHOLD_DEFAULTS['alert_roi_days_max']),
    'condition_critical' => (float)($cfgRows['alert_condition_critical'] ?? $THRESHOLD_DEFAULTS['alert_condition_critical']),
    'wear_critical'      => (float)($cfgRows['alert_wear_critical']      ?? $THRESHOLD_DEFAULTS['alert_wear_critical']),
    'storage_full_pct'   => (float)($cfgRows['alert_storage_full_pct']   ?? $THRESHOLD_DEFAULTS['alert_storage_full_pct']),
];

//  Zbierz dane do alertów 
$alerts = [];

// 1. Cena ropy
$market = $db->query("SELECT current_price, base_price FROM market_state WHERE id = 1")->fetch();
$currentPrice = (float)($market['current_price'] ?? 70);
$basePrice    = (float)($market['base_price'] ?? 100);

if ($currentPrice > $THRESHOLDS['price_high']) {
    $alerts[] = [
        'level' => 'warning',
        'icon'  => '📈',
        'title' => t('admin.alerts.alert_price_high_title'),
        'msg'   => t('admin.alerts.alert_price_high_msg', ['price' => $currentPrice, 'threshold' => $THRESHOLDS['price_high']]),
        'action'=> '<a href="/admin/market.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_market') . '</a>',
    ];
}
if ($currentPrice < $THRESHOLDS['price_low']) {
    $alerts[] = [
        'level' => 'critical',
        'icon'  => '📉',
        'title' => t('admin.alerts.alert_price_low_title'),
        'msg'   => t('admin.alerts.alert_price_low_msg', ['price' => $currentPrice, 'threshold' => $THRESHOLDS['price_low']]),
        'action'=> '<a href="/admin/market.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_market') . '</a>',
    ];
}

// 2. Pipeline loss
$pipeStats = [];
try {
    $pipeStats = $db->query("
        SELECT
            AVG(CASE WHEN status='active' THEN transport_loss END) AS avg_loss,
            SUM(status='active' AND condition_pct < 30) AS critical_cond_count,
            SUM(status='active' AND transport_loss > 15) AS high_loss_count
        FROM pipelines
    ")->fetch();
} catch (Throwable $e) {}

$avgLoss = (float)($pipeStats['avg_loss'] ?? 0);
if ($avgLoss > $THRESHOLDS['loss_pct_critical']) {
    $alerts[] = [
        'level' => 'critical',
        'icon'  => '🛢️',
        'title' => t('admin.alerts.alert_loss_critical_title'),
        'msg'   => t('admin.alerts.alert_loss_critical_msg', ['loss' => round($avgLoss,1), 'threshold' => $THRESHOLDS['loss_pct_critical']]),
        'action'=> '<a href="/admin/transport_loss.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_transport') . '</a>',
    ];
} elseif ($avgLoss > $THRESHOLDS['loss_pct_warn']) {
    $alerts[] = [
        'level' => 'warning',
        'icon'  => '🛢️',
        'title' => t('admin.alerts.alert_loss_warn_title'),
        'msg'   => t('admin.alerts.alert_loss_warn_msg', ['loss' => round($avgLoss,1), 'threshold' => $THRESHOLDS['loss_pct_warn']]),
        'action'=> '<a href="/admin/transport_loss.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_transport') . '</a>',
    ];
}

$critCond = (int)($pipeStats['critical_cond_count'] ?? 0);
if ($critCond > 0) {
    $alerts[] = [
        'level' => 'critical',
        'icon'  => '💥',
        'title' => t('admin.alerts.alert_pipe_crit_title', ['count' => $critCond]),
        'msg'   => t('admin.alerts.alert_pipe_crit_msg', ['count' => $critCond]),
        'action'=> '<a href="/admin/pipelines.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_pipelines') . '</a>',
    ];
}

// 3. Stan techniczny odwiertów
$condStats = $db->query("
    SELECT
        SUM(technical_condition < 40) AS critical_count,
        SUM(technical_condition < 60) AS warning_count,
        AVG(technical_condition) AS avg_condition,
        SUM(wear_level > 80) AS high_wear_count,
        SUM(status = 'blowout') AS blowout_count
    FROM wells
    WHERE status NOT IN ('seized')
")->fetch();

$critCond2 = (int)($condStats['critical_count'] ?? 0);
if ($critCond2 > 0) {
    $alerts[] = [
        'level' => 'warning',
        'icon'  => '⚠️',
        'title' => t('admin.alerts.alert_well_cond_title', ['count' => $critCond2]),
        'msg'   => t('admin.alerts.alert_well_cond_msg', ['count' => $critCond2]),
        'action'=> '<a href="/admin/wells.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_wells') . '</a>',
    ];
}

$blowouts = (int)($condStats['blowout_count'] ?? 0);
if ($blowouts > 0) {
    $alerts[] = [
        'level' => 'critical',
        'icon'  => '🔴',
        'title' => t('admin.alerts.alert_blowout_title', ['count' => $blowouts]),
        'msg'   => t('admin.alerts.alert_blowout_msg', ['count' => $blowouts]),
        'action'=> '<a href="/admin/wells.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_wells') . '</a>',
    ];
}

$highWear = (int)($condStats['high_wear_count'] ?? 0);
if ($highWear > 0) {
    $alerts[] = [
        'level' => 'warning',
        'icon'  => '⚙️',
        'title' => t('admin.alerts.alert_wear_title', ['count' => $highWear]),
        'msg'   => t('admin.alerts.alert_wear_msg', ['count' => $highWear, 'threshold' => $THRESHOLDS['wear_critical']]),
        'action'=> null,
    ];
}

// 4. Magazyn pełny
$storageStmt = $db->prepare("
    SELECT
        SUM(used / capacity > ?) AS full_count,
        AVG(used / capacity * 100) AS avg_fill_pct
    FROM storage
    WHERE capacity > 0
");
$storageStmt->execute([$THRESHOLDS['storage_full_pct'] / 100]);
$storageStats = $storageStmt->fetch();

$fullStorages = (int)($storageStats['full_count'] ?? 0);
if ($fullStorages > 0) {
    $alerts[] = [
        'level' => 'warning',
        'icon'  => '🛢️',
        'title' => t('admin.alerts.alert_storage_title', ['count' => $fullStorages]),
        'msg'   => t('admin.alerts.alert_storage_msg', ['count' => $fullStorages, 'threshold' => $THRESHOLDS['storage_full_pct']]),
        'action'=> null,
    ];
}

// 5. Gracze z problemami finansowymi
$playerProblems = $db->query("
    SELECT
        SUM(status = 'bankrupt') AS bankrupt_count,
        SUM(status = 'under_bailiff') AS bailiff_count,
        SUM(status = 'financial_risk') AS risk_count,
        SUM(cash < 0) AS negative_cash_count
    FROM players
")->fetch();

$bankrupts = (int)($playerProblems['bankrupt_count'] ?? 0);
if ($bankrupts > 0) {
    $alerts[] = [
        'level' => 'warning',
        'icon'  => '💸',
        'title' => t('admin.alerts.alert_bankrupt_title', ['count' => $bankrupts]),
        'msg'   => t('admin.alerts.alert_bankrupt_msg', ['count' => $bankrupts]),
        'action'=> '<a href="/admin/players.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_players') . '</a>',
    ];
}

$negativeCash = (int)($playerProblems['negative_cash_count'] ?? 0);
if ($negativeCash > 0) {
    $alerts[] = [
        'level' => 'critical',
        'icon'  => '❌',
        'title' => t('admin.alerts.alert_negative_cash_title', ['count' => $negativeCash]),
        'msg'   => t('admin.alerts.alert_negative_cash_msg', ['count' => $negativeCash]),
        'action'=> '<a href="/admin/players.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_players') . '</a>',
    ];
}

// 6. ROI — szacunkowy
$roiStats = $db->query("
    SELECT
        p.cash,
        SUM(w.base_production_per_hour) AS base_prod_sum
    FROM players p
    LEFT JOIN wells w ON w.player_id = p.id AND w.status = 'active'
    WHERE p.status = 'active'
    GROUP BY p.id
    HAVING base_prod_sum > 0
")->fetchAll();

if (!empty($roiStats)) {
    $oilPrice = max(1.0, $currentPrice);
    $roiDays  = [];
    foreach ($roiStats as $r) {
        $revenuePerDay = (float)$r['base_prod_sum'] * $oilPrice * 24 * 0.7;
        if ($revenuePerDay > 0) {
            $roi = max(0.1, (float)$r['cash'] / $revenuePerDay);
            $roiDays[] = $roi;
        }
    }
    if (!empty($roiDays)) {
        $avgRoi = array_sum($roiDays) / count($roiDays);
        if ($avgRoi < $THRESHOLDS['roi_days_min']) {
            $alerts[] = [
                'level' => 'warning',
                'icon'  => '📊',
                'title' => t('admin.alerts.alert_roi_short_title'),
                'msg'   => t('admin.alerts.alert_roi_short_msg', ['roi' => round($avgRoi,1), 'threshold' => $THRESHOLDS['roi_days_min']]),
                'action'=> '<a href="/admin/balance.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_balance') . '</a>',
            ];
        } elseif ($avgRoi > $THRESHOLDS['roi_days_max']) {
            $alerts[] = [
                'level' => 'warning',
                'icon'  => '📊',
                'title' => t('admin.alerts.alert_roi_long_title'),
                'msg'   => t('admin.alerts.alert_roi_long_msg', ['roi' => round($avgRoi,1), 'threshold' => $THRESHOLDS['roi_days_max']]),
                'action'=> '<a href="/admin/balance.php" class="btn btn-secondary btn-sm">→ ' . t('admin.alerts.link_balance') . '</a>',
            ];
        }
    }
}

// 7. Ostatni tick — sprawdź systemowy timestamp ticka (well_config), fallback na players
$lastTickTs  = (int)$db->query("SELECT `value` FROM well_config WHERE `key` = 'last_system_tick_at' LIMIT 1")->fetchColumn();
if (!$lastTickTs) {
    $lastTickStr = $db->query("SELECT MAX(last_tick_at) FROM players")->fetchColumn();
    $lastTickTs  = $lastTickStr ? (int)strtotime($lastTickStr) : 0;
}
$lastTick = $lastTickTs ? date('Y-m-d H:i:s', $lastTickTs) : null;
if ($lastTickTs) {
    $tickAge = (time() - $lastTickTs) / 60;
    if ($tickAge > 15) {
        $alerts[] = [
            'level' => 'critical',
            'icon'  => '⏰',
            'title' => t('admin.alerts.alert_cron_title'),
            'msg'   => t('admin.alerts.alert_cron_msg', ['minutes' => round($tickAge)]),
            'action'=> '<a href="/admin/force_tick.php" class="btn btn-danger btn-sm">→ ' . t('admin.alerts.link_force_tick') . '</a>',
        ];
    }
}

// Posortuj: critical pierwsze
usort($alerts, fn($a, $b) => ($a['level'] === 'critical' ? -1 : 1));

$threshLabels = [
    'loss_pct_warn'      => [t('admin.alerts.thresh_loss_warn'),      '%',   0.1, 50],
    'loss_pct_critical'  => [t('admin.alerts.thresh_loss_critical'),  '%',   0.1, 50],
    'price_high'         => [t('admin.alerts.thresh_price_high'),     '$',   1,  999],
    'price_low'          => [t('admin.alerts.thresh_price_low'),      '$',   1,  999],
    'roi_days_min'       => [t('admin.alerts.thresh_roi_min'),        t('common.days'), 0.1, 30],
    'roi_days_max'       => [t('admin.alerts.thresh_roi_max'),        t('common.days'), 0.1, 30],
    'condition_critical' => [t('admin.alerts.thresh_condition'),      '%',   1,  100],
    'wear_critical'      => [t('admin.alerts.thresh_wear'),           '',    1,  100],
    'storage_full_pct'   => [t('admin.alerts.thresh_storage'),        '%',   1,  100],
];
$cfgKeys = [
    'loss_pct_warn'      => 'alert_loss_pct_warn',
    'loss_pct_critical'  => 'alert_loss_pct_critical',
    'price_high'         => 'alert_price_high',
    'price_low'          => 'alert_price_low',
    'roi_days_min'       => 'alert_roi_days_min',
    'roi_days_max'       => 'alert_roi_days_max',
    'condition_critical' => 'alert_condition_critical',
    'wear_critical'      => 'alert_wear_critical',
    'storage_full_pct'   => 'alert_storage_full_pct',
];

$viewData = [
    'alerts'       => $alerts,
    'threshMsg'    => $threshMsg,
    'THRESHOLDS'   => $THRESHOLDS,
    'threshLabels' => $threshLabels,
    'cfgKeys'      => $cfgKeys,
    'currentPrice' => $currentPrice,
    'avgLoss'      => $avgLoss,
    'lastTick'     => $lastTick,
];

$pageTitle = t('admin.alerts.title');
require_once __DIR__ . '/partials/header.php';
require __DIR__ . '/../templates/views/admin/alerts/main.php';
require_once __DIR__ . '/partials/footer.php';

} catch (Throwable $e) {
    if (class_exists('GameLog', false)) GameLog::error('admin/alerts.php', t('common.unhandled_exception'), $e);
    echo t('common.app_error');
} finally {
    if (class_exists('GameLog', false)) GameLog::pageEnd('admin/alerts.php', $_codexGuardStart);
}
