function adminFinanceLoadConfig(PDO $db): array
{
    $config = [];
    try {
        $rows = $db->query("SELECT `key`, value FROM well_config WHERE category = 'finance'")->fetchAll(PDO::FETCH_ASSOC);
        foreach ($rows as $row) {
            $config[$row['key']] = (float)$row['value'];
        }
    } catch (Throwable $e) {
        GameLog::error('admin/finance.php', 'load config FAILED', $e);
    }

    try {
        $runtimeRows = $db->query("
            SELECT `key`, value
            FROM well_config
            WHERE `key` IN ('global_tax_multiplier','global_opex_multiplier','global_loss_multiplier')
        ")->fetchAll(PDO::FETCH_ASSOC);
        foreach ($runtimeRows as $row) {
            $mappedKey = match ($row['key']) {
                'global_tax_multiplier'  => 'global_tax_modifier',
                'global_opex_multiplier' => 'global_cost_modifier',
                'global_loss_multiplier' => 'global_loss_modifier',
                default                  => null,
            };
            if ($mappedKey !== null) {
                $config[$mappedKey] = (float)$row['value'];
            }
        }
    } catch (Throwable $e) {
        GameLog::error('admin/finance.php', 'load runtime config FAILED', $e);
    }

    return $config + adminFinanceConfigDefaults();
}

function adminFinanceLoadSavingsMultipliers(PDO $db): array
{
    $mults = adminFinanceMultiplierDefaults();
    try {
        $multRows = $db->query("SELECT `key`, value FROM well_config WHERE `key` LIKE 'sp_%'")->fetchAll(PDO::FETCH_KEY_PAIR);
        foreach ($mults as $key => &$value) {
            if (isset($multRows[$key]) && is_numeric($multRows[$key])) {
                $value = round((float)$multRows[$key], 4);
            }
        }
        unset($value);
    } catch (Throwable $e) {
        GameLog::error('admin/finance.php', 'load multipliers FAILED', $e);
    }

    return $mults;
}

