// Konfiguracja
$config = [];
try {
    $rows = $db->query("SELECT `key`, value FROM well_config WHERE category='finance'")->fetchAll();
    foreach ($rows as $r) $config[$r['key']] = (float)$r['value'];
} catch (Throwable $e) {}
$config += ['global_tax_modifier'=>1.0,'global_cost_modifier'=>1.0,'global_loss_modifier'=>1.0];

// Historia do wykresu (ostatnie 24h globalna)
$globalHistory = [];
try {
    $globalHistory = $db->prepare("
        SELECT
            DATE_FORMAT(tick_at, '%d.%m %H:%i') AS label,
            SUM(revenue)     AS revenue,
            SUM(net_profit)  AS net_profit,
            SUM(loss_value)  AS loss_value,
            AVG(oil_price)   AS oil_price
        FROM finance_logs
        WHERE tick_at >= DATE_SUB(NOW(), INTERVAL ? HOUR)
        GROUP BY DATE_FORMAT(tick_at, '%Y-%m-%d %H:%i')
        ORDER BY tick_at ASC
    ");
    $globalHistory->execute([$hours]);
    $globalHistory = $globalHistory->fetchAll(PDO::FETCH_ASSOC);
} catch (Throwable $e) {}

function fmtA(float $v, bool $sign = false): string {
    $s = number_format(abs($v), 0, ',', ' ') . ' PLN';
    if ($sign) $s = ($v >= 0 ? '+' : 'Ă˘Ââ€™') . $s;
    elseif ($v < 0) $s = 'Ă˘Ââ€™' . $s;
    return $s;
}

