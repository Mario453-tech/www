        $keys = [
            'global_tax_modifier'  => 'MnoÄąÄ˝nik podatkÄ‚Ĺ‚w globalny',
            'global_cost_modifier' => 'MnoÄąÄ˝nik kosztÄ‚Ĺ‚w globalny',
