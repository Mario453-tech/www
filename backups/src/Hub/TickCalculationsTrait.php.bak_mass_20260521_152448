<?php

/**
 * HubTickCalculationsTrait — pure calculations for one hub tick.
 * No DB access. Used by HubTickService.
 */
trait HubTickCalculationsTrait
{
    /**
     * Oblicza czynnik przepustowości na podstawie kondycji (progowe, nie liniowe).
     * Calculates throughput factor based on condition (threshold-based, not linear).
     */
    private function calcConditionFactor(float $condPct): float
    {
        if ($condPct <= self::COND_CRITICAL) {
            return self::THROUGHPUT_FACTOR_CRITICAL;
        }
        if ($condPct <= self::COND_DAMAGED) {
            return self::THROUGHPUT_FACTOR_DAMAGED;
        }
        return $condPct / 100.0;
    }

    /**
     * Bezposrednie straty wolumenu z powodu zlego stanu technicznego.
     * Direct volume loss due to poor technical condition.
     * Przy kondycji ≥70% — brak strat.
     * At condition >=70% — no losses.
     */
    private function calcConditionLoss(float $condPct, float $processedBbl, bool $overloaded): float
    {
        if ($condPct >= 70.0 || $processedBbl < 0.001) {
            return 0.0;
        }

        $lossPct = match(true) {
            $condPct <= self::COND_CRITICAL => mt_rand(15, 25),
            $condPct <= self::COND_DAMAGED  => mt_rand(8, 15),
            $condPct <= self::COND_DEGRADED => mt_rand(3, 8),
            default                         => mt_rand(1, 3),
        };

        if ($overloaded) {
            $lossPct = min(40, (int)round($lossPct * 1.8));
        }

        return round($processedBbl * $lossPct / 100.0, 2);
    }

    private function deriveStatus(string $currentStatus, float $newCondition, bool $overloaded): string
    {
        if (in_array($currentStatus, ['disabled', 'building', 'paused'], true)) {
            return $currentStatus;
        }
        if ($newCondition <= self::COND_CRITICAL) {
            return 'critical';
        }
        if ($newCondition <= self::COND_DAMAGED) {
            return 'damaged';
        }
        if ($overloaded) {
            return 'overloaded';
        }
        if (in_array($currentStatus, ['overloaded', 'damaged', 'critical'], true)) {
            return 'active';
        }
        return $currentStatus;
    }

    /**
     * @param array<string, mixed> $hub
     * @param array<string, mixed> $result
     */
    private function calculateRealCapacity(array $hub, array $result): float
    {
        $modeMultipliers = $this->hubSvc->getWorkModeMultipliers($hub['work_mode'] ?? 'standard');
        $conditionFactor = $this->calcConditionFactor($result['new_condition']);
        $throughputMult  = $modeMultipliers['throughput_mult'] ?? 1.0;
        return round((float)$hub['nominal_capacity_bph'] * $conditionFactor * $throughputMult, 2);
    }

    /**
     * Wynik gdy hub jest nieaktywny (disabled / building / paused).
     * Result when the hub is inactive (disabled / building / paused).
     * @param array<string, mixed> $hub
     * @return array<string, mixed>
     */
    private function buildEmptyResult(array $hub, float $inputBbl, float $deltaHours): array
    {
        $fallback = $this->applyFallback($inputBbl, $deltaHours);

        return [
            'processed_bbl'      => $fallback['effective_bbl'],
            'buffered_bbl'       => 0.0,
            'lost_bbl'           => $fallback['lost_bbl'],
            'condition_lost_bbl' => 0.0,
            'load_pct'           => 0.0,
            'overloaded'         => false,
            'new_buffer'         => (float)$hub['buffer_current_bbl'],
            'wear_added'         => 0.0,
            'new_condition'      => (float)$hub['condition_pct'],
            'new_efficiency'     => (float)$hub['efficiency_pct'],
            'new_status'         => $hub['status'],
            'incident_flag'      => false,
        ];
    }
}
