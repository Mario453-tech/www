/* market.css
   Styles for the oil market module (Oil Market + tabs).
   Czarny rynek zostaje w black_market.css.
*/

/*
   TABS
 */

.market-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    padding: 4px;
    background: linear-gradient(145deg, #161622, #0f0f18);
    border: 1px solid rgba(200,168,75,.15);
    border-radius: 10px;
    overflow-x: auto;
    scrollbar-width: none;
}
.market-tabs::-webkit-scrollbar { display: none; }

.market-tab {
    padding: .55rem 1rem;
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
    color: rgba(232,232,240,.55);
    font-weight: 700;
    font-size: .82rem;
    letter-spacing: .04em;
    border-radius: 8px;
    transition: all .15s;
    white-space: nowrap;
    flex-shrink: 0;
}

.market-tab:hover {
    color: var(--text);
    background: rgba(255, 255, 255, .06);
}

.market-tab.active {
    color: var(--gold2, #e8cc7a);
    background: rgba(200,168,75,.14);
    border-color: rgba(200,168,75,.35);
    box-shadow: 0 1px 6px rgba(200,168,75,.1);
}

.market-tab-content {
    display: none;
}

.market-tab-content.active {
    display: block;
}

/*
   WYKRES CEN
 */

.price-chart-wrap {
    margin: 1rem 0;
    background: linear-gradient(145deg, #161622, #0f0f18);
    border: 1px solid rgba(200,168,75,.15);
    border-radius: 10px;
    padding: 14px 16px;
}

.price-chart-title {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(200,168,75,.6);
    margin: 0 0 12px;
}

.price-chart-bars {
    display: flex;
    gap: 3px;
    align-items: flex-end;
    height: 90px;
}

.price-chart-bar {
    flex: 1;
    background: linear-gradient(to top, var(--gold) 0%, rgba(200, 168, 75, .4) 100%);
    border-radius: 3px 3px 0 0;
    min-height: 4px;
    transition: opacity .15s;
}

.price-chart-bar:hover {
    opacity: .75;
}

.price-chart-legend {
    display: flex;
    justify-content: space-between;
    font-size: .78rem;
    color: var(--text3);
    margin-top: 8px;
    padding-top: 6px;
    border-top: 1px solid var(--border2);
}

/*
   SALE FORM
 */

.form-sell {
    display: flex;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 12px;
}

.form-sell-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 140px;
}

.form-sell-label {
    font-size: .8rem;
    font-weight: 600;
    color: var(--text3);
    letter-spacing: .04em;
    text-transform: uppercase;
}

.form-sell-input {
    padding: .5rem .8rem;
    background: #0f0f18;
    border: 1px solid rgba(200,168,75,.2);
    border-radius: 8px;
    color: var(--text);
    font-size: .95rem;
    font-weight: 600;
    min-width: 0;
    transition: border-color .15s;
}

.form-sell-input:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(200, 168, 75, .15);
}

/*
   AKTYWNE OFERTY (my-offers)
 */

.my-offers-list {
    display: grid;
    font-size: .88rem;
}

.my-offers-head,
.my-offers-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 2fr;
    gap: .5rem;
    padding: .6rem .75rem;
    align-items: center;
}

.my-offers-head {
    font-weight: 700;
    font-size: .75rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 1px solid var(--border);
}

.my-offers-row {
    border-bottom: 1px solid rgba(255, 255, 255, .04);
    transition: background .12s;
}

.my-offers-row:hover {
    background: rgba(200, 168, 75, .04);
}

.my-offers-row:last-child {
    border-bottom: none;
}

/*
   OFFER LIST (offers-list, public users)
 */

.offers-list {
    display: grid;
    font-size: .88rem;
}

.offers-list-head,
.offers-list-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: .5rem;
    padding: .6rem .75rem;
}

.offers-list-head {
    font-weight: 700;
    font-size: .75rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 1px solid var(--border);
}

.offers-list-row {
    border-bottom: 1px solid rgba(255, 255, 255, .04);
    transition: background .12s;
}

.offers-list-row:hover {
    background: rgba(255, 255, 255, .03);
}

/*
   RESPONSIVE
 */

@media (max-width: 700px) {
    .market-tabs {
        gap: 3px;
        padding: 4px;
    }

    .market-tab {
        padding: .55rem .9rem;
        font-size: .85rem;
    }

    .form-sell {
        flex-direction: column;
        align-items: stretch;
    }

    .form-sell-field {
        min-width: 0;
    }

    .my-offers-list,
    .offers-list {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .my-offers-head,
    .my-offers-row {
        min-width: 480px;
    }

    .offers-list-head,
    .offers-list-row {
        min-width: 320px;
    }
}

@media (max-width: 480px) {
    .market-tab { padding: .45rem .75rem; font-size: .78rem; }
    .price-chart-bars { height: 70px; }
    .form-sell { flex-direction: column; }
    .form-sell-field { min-width: 0; width: 100%; }
}
