/*
   DZIA PRAWNY — STYL WIDOKU GRACZA
   Legal Department — player-facing view styles.
   Zaley od: variables.css, style.css (.card, .btn-primary).
   Depends on: variables.css, style.css (.card, .btn-primary).
*/

/* Naglwek sekcji (h3 wewntrz .card) / Section heading inside .card */
.card h3 {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
}

.card h3::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 13px;
    background: var(--gold);
    border-radius: 2px;
    flex-shrink: 0;
}

/* Lista regionw / Region list container */
.legal-region-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

/* Karta pojedynczego regionu / Single region card */
.legal-region-card {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(200,168,75,.15);
    border-left: 3px solid rgba(200,168,75,.3);
    border-radius: var(--radius);
    padding: 16px 18px;
    transition: border-color .2s, background .2s;
}

.legal-region-card:hover {
    background: rgba(255,255,255,.05);
    border-color: rgba(200,168,75,.3);
    border-left-color: rgba(200,168,75,.6);
}

/* Warianty stanu karty / Card state variants */
.legal-region-card--active {
    border-left-color: var(--green);
    background: rgba(78,201,122,.03);
}
.legal-region-card--active:hover {
    border-left-color: var(--green);
    background: rgba(78,201,122,.05);
}

.legal-region-card--pending {
    border-left-color: var(--gold);
}

.legal-region-card--locked {
    border-left-color: var(--red);
    opacity: .85;
}

/* Wiersz: nazwa + odznaka / Row: name + badge */
.legal-region-name {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 10px;
    flex-wrap: wrap;
}

/* Odznaki statusu / Status badges */
.legal-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
}

.legal-badge--granted {
    background: rgba(78,201,122,.15);
    color: var(--green);
    border: 1px solid rgba(78,201,122,.3);
}

.legal-badge--pending {
    background: rgba(200,168,75,.15);
    color: var(--gold);
    border: 1px solid rgba(200,168,75,.35);
}

.legal-badge--delayed {
    background: rgba(240,160,80,.15);
    color: var(--orange);
    border: 1px solid rgba(240,160,80,.35);
}

.legal-badge--no-decision {
    background: rgba(255,255,255,.06);
    color: rgba(232,232,240,.45);
    border: 1px solid rgba(255,255,255,.1);
}

.legal-badge--refused {
    background: rgba(224,85,85,.15);
    color: var(--red);
    border: 1px solid rgba(224,85,85,.3);
}

.legal-badge--none {
    background: rgba(255,255,255,.05);
    color: rgba(232,232,240,.35);
    border: 1px solid rgba(255,255,255,.08);
}

/* Metadane regionu — tabsy waciwoci / Region meta — property tags */
.legal-region-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 12px;
}

.legal-region-meta span {
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 4px;
    padding: 4px 10px;
    font-size: 11px;
    color: rgba(232,232,240,.6);
    line-height: 1.4;
}

/* Opnienie / Delay count pill */
.legal-delay-count {
    background: rgba(240,160,80,.1) !important;
    border-color: rgba(240,160,80,.25) !important;
    color: var(--orange) !important;
}

/* Kolory poziomu ryzyka / Risk level colors */
.legal-risk-low      { color: var(--green);  font-weight: 600; }
.legal-risk-medium   { color: var(--gold);   font-weight: 600; }
.legal-risk-high     { color: var(--orange); font-weight: 600; }
.legal-risk-critical { color: var(--red);    font-weight: 600; }

/* Cooldown / Cooldown notice */
.legal-cooldown {
    color: var(--red) !important;
    border-color: rgba(224,85,85,.25) !important;
    background: rgba(224,85,85,.08) !important;
}

/* Przycisk zoenia wniosku / Submit button row */
.legal-submit-form {
    margin-top: 4px;
}

.legal-submit-btn {
    min-width: 160px;
}

/* Brak rodkw / Insufficient funds notice */
.legal-insufficient {
    font-size: 12px;
    color: rgba(224,85,85,.8);
    padding: 6px 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.legal-insufficient::before {
    content: '!';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(224,85,85,.15);
    border: 1px solid rgba(224,85,85,.3);
    font-size: 11px;
    font-weight: 700;
    color: var(--red);
    flex-shrink: 0;
}

/* === RESPONSYWNO MOBILNA / MOBILE RESPONSIVE === */

@media (max-width: 600px) {
    .legal-region-name {
        font-size: 14px;
    }

    .legal-region-meta {
        gap: 5px;
    }

    .legal-region-meta span {
        font-size: 10px;
        padding: 3px 8px;
    }

    .legal-submit-btn {
        width: 100%;
    }
}
