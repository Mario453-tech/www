                <span><?= t('legal.required_capital_label') ?>: <strong><?= number_format($reqCap, 0, ',', ' ') ?> PLN</strong></span>
                <span class="legal-capital-missing"><?= t('legal.capital_missing', ['amount' => number_format($missing, 0, ',', ' ')]) ?></span>
            </div>
        </div>
    <?php endforeach ?>
    </div>
</section>
<?php endif ?>

