        <div class="loan-paid-off-icon">🎉</div>
        <div class="loan-paid-off-text"><?= $success ?></div>
    </div>
    <?php else: ?>
    <div class="success"><?= $success ?></div>
    <?php endif ?>
<?php endif ?>