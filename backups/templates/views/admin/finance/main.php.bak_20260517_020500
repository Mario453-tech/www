            ['d2_domain_safety',    'd2_metric_disasters',      null,                   'sp_safety_disaster_agg'],
        ];
        $multValClass = static function(?string $key, array $m): string {
            if ($key === null) return '';
            $v = $m[$key] ?? 1.0;
            if ($v < 0.999) return 'fin-green';
            if ($v > 1.001) return 'fin-orange';
            return 'fin-stat-neutral';
        };
        $multInput = static function(?string $key, array $m, string $cls): string {
            if ($key === null) {
                return '<span class="fin-stat-neutral" style="font-size:13px">—</span>';
            }
            $v = number_format($m[$key] ?? 1.0, 4, '.', '');
            return '<input type="number" name="' . htmlspecialchars($key) . '" value="' . $v . '"
                        min="0.50" max="2.00" step="0.01"
                        class="fin-mult-input ' . $cls . '"
                        title="' . htmlspecialchars($key) . '">';
        };
        $prevDomain = '';
        foreach ($d2rows as [$domKey, $metricKey, $modKey, $aggKey]):
            $domain  = t('admin.finance.' . $domKey);
            $metric  = t('admin.finance.' . $metricKey);
            $isNew   = $domain !== $prevDomain;
            $prevDomain = $domain;
            $clsMod  = $multValClass($modKey, $mults);
            $clsAgg  = $multValClass($aggKey, $mults);
        ?>
        <div class="fin-effects-row <?= $isNew ? 'fin-effects-domain-row' : '' ?>">
