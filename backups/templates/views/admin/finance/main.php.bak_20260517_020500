            <span class="fin-effects-cell <?= $clsMod ?>"><?= $multInput($modKey, $mults, $clsMod) ?></span>
            <span class="fin-effects-cell <?= $clsAgg ?>"><?= $multInput($aggKey, $mults, $clsAgg) ?></span>
