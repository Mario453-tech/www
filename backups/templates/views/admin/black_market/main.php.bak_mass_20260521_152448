<script>
function bmShowTab(tab) {
    document.querySelectorAll('.admin-tab').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.admin-tab-content').forEach(function(p) { p.classList.remove('active'); });
    var panel = document.getElementById('bm-tab-' + tab);
    var btn   = document.getElementById('bm-btn-' + tab);
    if (panel) panel.classList.add('active');
    if (btn)   btn.classList.add('active');
    try { localStorage.setItem('bm_admin_tab', tab); } catch(e) {}
}
document.addEventListener('DOMContentLoaded', function() {
    var saved = '';
    try { saved = localStorage.getItem('bm_admin_tab') || ''; } catch(e) {}
    var tabs = ['stats','players','tx','config','help'];
    bmShowTab(tabs.indexOf(saved) >= 0 ? saved : 'stats');
});
</script>

