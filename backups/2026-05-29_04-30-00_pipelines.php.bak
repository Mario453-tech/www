<?php
$_codexGuardStart = class_exists('GameLog', false) ? GameLog::pageStart('admin/pipelines.php') : microtime(true);
try {

require_once __DIR__ . '/init.php';
AdminAuth::requireLogin();

$db = Database::getInstance()->getConnection();
$pipelineSvc = new WellPipelineService($db);
$msg = '';
$err = '';

$historyFilters = [
    'player' => trim((string)($_GET['hplayer'] ?? $_POST['hplayer'] ?? '')),
    'type' => trim((string)($_GET['htype'] ?? $_POST['htype'] ?? '')),
    'days' => max(0, (int)($_GET['hdays'] ?? $_POST['hdays'] ?? 0)),
    'per_page' => (int)($_GET['hper'] ?? $_POST['hper'] ?? 20),
    'page' => max(1, (int)($_GET['hpage'] ?? 1)),
];
if (!in_array($historyFilters['per_page'], [10, 20, 50, 100], true)) {
    $historyFilters['per_page'] = 20;
}

$buildHistoryWhere = static function (array $filters, string $eventAlias = 'e', string $playerAlias = 'p'): array {
    $where = [];
    $params = [];

    if (($filters['player'] ?? '') !== '') {
        $where[] = "({$playerAlias}.username LIKE ? OR {$playerAlias}.company_name LIKE ? OR {$eventAlias}.player_id = ?)";
        $needle = '%' . (string)$filters['player'] . '%';
        $params[] = $needle;
        $params[] = $needle;
        $params[] = ctype_digit((string)$filters['player']) ? (int)$filters['player'] : 0;
    }

    if (($filters['type'] ?? '') !== '') {
        $where[] = "{$eventAlias}.event_type = ?";
        $params[] = (string)$filters['type'];
    }

    if ((int)($filters['days'] ?? 0) > 0) {
        $where[] = "{$eventAlias}.created_at >= DATE_SUB(NOW(), INTERVAL ? DAY)";
        $params[] = (int)$filters['days'];
    }

    return [$where ? 'WHERE ' . implode(' AND ', $where) : '', $params];
};

// Actions
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!CSRF::validateToken($_POST['csrf_token'] ?? '')) {
        die('<p class="alert alert-error">' . t('common.csrf_error') . '</p>');
    }

    $action = (string)($_POST['action'] ?? '');

    if ($action === 'save_pipeline_profiles') {
        try {
            foreach ($pipelineSvc->getProfileTypes() as $type) {
                $pipelineSvc->saveProfileSettings(
                    $type,
                    (float)($_POST['price_pct'][$type] ?? 100.0),
                    (float)($_POST['capacity_pct'][$type] ?? 100.0),
                    (float)($_POST['durability_pct'][$type] ?? 100.0)
                );
            }
            AdminLog::log('pipeline_profiles_update', 'Admin updated pipeline type profiles');
            $msg = t('admin.pipelines.msg_profiles_saved');
        } catch (Throwable $e) {
            $err = t('admin.pipelines.err_profiles_save') . $e->getMessage();
        }
    } elseif ($action === 'grant_pipeline') {
        $wellId = (int)($_POST['well_id'] ?? 0);
        $requestedType = trim((string)($_POST['pipeline_type'] ?? 'standard'));
        $type = $pipelineSvc->normalizePipelineType($requestedType);

        try {
            if ($wellId <= 0) {
                throw new RuntimeException(tPlain('admin.pipelines.err_grant_missing'));
            }

            $wellStmt = $db->prepare(
                "SELECT w.id, w.player_id, w.well_type, w.status, w.base_production_per_hour,
                        COALESCE(NULLIF(w.well_name, ''), CONCAT('Odwiert #', w.id)) AS well_label,
                        w.location_name,
                        p.username,
                        p.company_name
                   FROM wells w
                   JOIN players p ON p.id = w.player_id
                  WHERE w.id = ?
                  LIMIT 1"
            );
            $wellStmt->execute([$wellId]);
            $well = $wellStmt->fetch(PDO::FETCH_ASSOC);
            if (!$well) {
                throw new RuntimeException(tPlain('admin.pipelines.err_grant_well'));
            }
            if ((string)($well['well_type'] ?? 'onshore') === 'offshore') {
                throw new RuntimeException(tPlain('admin.pipelines.err_grant_offshore'));
            }
            if (in_array((string)($well['status'] ?? ''), ['sold', 'seized', 'blowout'], true)) {
                throw new RuntimeException(tPlain('admin.pipelines.err_grant_well'));
            }

            $hubStmt = $db->prepare(
                "SELECT a.hub_id, h.name AS hub_name
                   FROM logistics_hub_assignments a
                   JOIN logistics_hubs h ON h.id = a.hub_id
                  WHERE a.well_id = ?
                    AND a.status = 'active'
                    AND h.status NOT IN ('disabled', 'building')
                  LIMIT 1"
            );
            $hubStmt->execute([$wellId]);
            $hub = $hubStmt->fetch(PDO::FETCH_ASSOC);
            if (!$hub) {
                throw new RuntimeException(tPlain('admin.pipelines.err_grant_no_hub'));
            }

            $existingStmt = $db->prepare('SELECT id FROM well_pipelines WHERE well_id = ? LIMIT 1');
            $existingStmt->execute([$wellId]);
            if ($existingStmt->fetchColumn()) {
                throw new RuntimeException(tPlain('admin.pipelines.err_grant_exists'));
            }

            $profile = $pipelineSvc->getProfile($type);
            $baseProd = (float)($well['base_production_per_hour'] ?? 100.0);
            $capacity = max(1.0, round($baseProd * ((float)$profile['capacity_pct'] / 100.0), 2));
            $name = tPlain('pipeline.default_name', ['id' => $wellId]);

            $db->beginTransaction();
            $insertStmt = $db->prepare(
                "INSERT INTO well_pipelines
                    (player_id, well_id, hub_id, name, pipeline_type, status, condition_pct, transport_loss,
                     nominal_capacity_bph, real_capacity_bph, degradation_rate_per_hour, incident_risk_mult,
                     opex_per_tick, opex_per_bbl, build_cost, last_inspected_at, created_at, updated_at)
                 VALUES (?, ?, ?, ?, ?, 'active', 100.0, 0.0, ?, ?, ?, ?, ?, ?, ?, NOW(), NOW(), NOW())"
            );
            $insertStmt->execute([
                (int)$well['player_id'],
                $wellId,
                (int)$hub['hub_id'],
                $name,
                $type,
                $capacity,
                $capacity,
                (float)$profile['degradation_rate_per_hour'],
                (float)$profile['incident_risk_mult'],
                (float)$profile['opex_per_tick'],
                (float)$profile['opex_per_bbl'],
                (float)$profile['build_cost'],
            ]);
            $pipelineId = (int)$db->lastInsertId();

            $eventMessage = tPlain('admin.pipelines.event_admin_granted', [
                'pipeline' => $pipelineId,
                'well' => $wellId,
                'type' => tPlain('logistics.pipeline.type_' . $type),
                'hub' => (string)$hub['hub_name'],
            ]);
            $pipelineSvc->recordEvent((int)$well['player_id'], $wellId, $pipelineId, 'admin_pipeline_granted', 'info', $eventMessage);
            AdminLog::log('pipeline_grant', "Admin granted pipeline #{$pipelineId} to well #{$wellId}", (int)$well['player_id'], 'pipeline', $pipelineId);
            $db->commit();

            $msg = t('admin.pipelines.msg_granted', [
                'player' => (string)$well['username'],
                'well' => $wellId,
                'hub' => (string)$hub['hub_name'],
            ]);
        } catch (Throwable $e) {
            if ($db->inTransaction()) {
                $db->rollBack();
            }
            $err = t('admin.pipelines.err_grant') . $e->getMessage();
        }
    } elseif ($action === 'delete_history_event') {
        $eventId = (int)($_POST['event_id'] ?? 0);
        try {
            if ($eventId > 0) {
                $stmt = $db->prepare('DELETE FROM well_pipeline_events WHERE id = ?');
                $stmt->execute([$eventId]);
                AdminLog::log('pipeline_history_delete_event', "Admin deleted pipeline event #{$eventId}", null, 'pipeline_event', $eventId);
                $msg = t('admin.pipelines.msg_history_deleted', ['count' => $stmt->rowCount()]);
            }
        } catch (Throwable $e) {
            $err = t('admin.pipelines.err_history_delete') . $e->getMessage();
        }
    } elseif ($action === 'delete_history_filtered') {
        try {
            [$whereSql, $params] = $buildHistoryWhere($historyFilters, 'e', 'p');
            $stmt = $db->prepare(
                "DELETE e
                   FROM well_pipeline_events e
                   LEFT JOIN players p ON p.id = e.player_id
                   {$whereSql}"
            );
            $stmt->execute($params);
            $deleted = $stmt->rowCount();
            AdminLog::log('pipeline_history_delete_filtered', "Admin deleted {$deleted} pipeline history events");
            $msg = t('admin.pipelines.msg_history_deleted', ['count' => $deleted]);
        } catch (Throwable $e) {
            $err = t('admin.pipelines.err_history_delete') . $e->getMessage();
        }
    }
}

// Summary cards
$stats = [
    'total' => 0,
    'active_count' => 0,
    'building_count' => 0,
    'problem_count' => 0,
];
try {
    $stats = $db->query(
        "SELECT COUNT(*) AS total,
                SUM(status = 'active') AS active_count,
                SUM(status = 'building') AS building_count,
                SUM(status IN ('degraded','critical','damaged','leak','disabled')) AS problem_count
           FROM well_pipelines"
    )->fetch(PDO::FETCH_ASSOC) ?: $stats;
} catch (Throwable $e) {
    GameLog::error('admin/pipelines.php', 'Pipeline stats failed', $e);
}

// Wells eligible for an admin-granted pipeline.
$grantableWells = [];
try {
    $grantableWells = $db->query(
        "SELECT w.id AS well_id,
                w.player_id,
                COALESCE(NULLIF(w.well_name, ''), CONCAT('Odwiert #', w.id)) AS well_label,
                w.location_name,
                p.username,
                p.company_name,
                h.id AS hub_id,
                h.name AS hub_name
           FROM wells w
           JOIN players p ON p.id = w.player_id
           JOIN logistics_hub_assignments a ON a.well_id = w.id AND a.status = 'active'
           JOIN logistics_hubs h ON h.id = a.hub_id AND h.status NOT IN ('disabled', 'building')
           LEFT JOIN well_pipelines wp ON wp.well_id = w.id
          WHERE wp.id IS NULL
            AND COALESCE(w.well_type, 'onshore') <> 'offshore'
            AND w.status NOT IN ('sold', 'seized', 'blowout')
          ORDER BY p.username ASC, w.id ASC"
    )->fetchAll(PDO::FETCH_ASSOC);
} catch (Throwable $e) {
    GameLog::error('admin/pipelines.php', 'Grantable wells lookup failed', $e);
}

$historyTypes = [];
try {
    $historyTypes = $db->query(
        "SELECT event_type, COUNT(*) AS cnt
           FROM well_pipeline_events
          GROUP BY event_type
          ORDER BY event_type ASC"
    )->fetchAll(PDO::FETCH_ASSOC);
} catch (Throwable $e) {
    GameLog::error('admin/pipelines.php', 'Pipeline history type lookup failed', $e);
}

[$historyWhereSql, $historyParams] = $buildHistoryWhere($historyFilters, 'e', 'p');
$historyTotal = 0;
$historyRows = [];
try {
    $countStmt = $db->prepare(
        "SELECT COUNT(*)
           FROM well_pipeline_events e
           LEFT JOIN players p ON p.id = e.player_id
           LEFT JOIN wells w ON w.id = e.well_id
           LEFT JOIN well_pipelines wp ON wp.id = e.pipeline_id
           {$historyWhereSql}"
    );
    $countStmt->execute($historyParams);
    $historyTotal = (int)$countStmt->fetchColumn();

    $historyPages = max(1, (int)ceil($historyTotal / $historyFilters['per_page']));
    $historyFilters['page'] = min($historyFilters['page'], $historyPages);
    $offset = ($historyFilters['page'] - 1) * $historyFilters['per_page'];

    $historyStmt = $db->prepare(
        "SELECT e.*,
                p.username,
                p.company_name,
                COALESCE(NULLIF(w.well_name, ''), CONCAT('Odwiert #', e.well_id)) AS well_label,
                w.location_name,
                wp.name AS pipeline_name,
                wp.pipeline_type,
                wp.status AS pipeline_status
           FROM well_pipeline_events e
           LEFT JOIN players p ON p.id = e.player_id
           LEFT JOIN wells w ON w.id = e.well_id
           LEFT JOIN well_pipelines wp ON wp.id = e.pipeline_id
           {$historyWhereSql}
          ORDER BY e.created_at DESC, e.id DESC
          LIMIT {$historyFilters['per_page']} OFFSET {$offset}"
    );
    $historyStmt->execute($historyParams);
    $historyRows = $historyStmt->fetchAll(PDO::FETCH_ASSOC);
} catch (Throwable $e) {
    GameLog::error('admin/pipelines.php', 'Pipeline history lookup failed', $e);
}

$viewData = [
    'msg' => $msg,
    'err' => $err,
    'stats' => $stats,
    'pipelineProfiles' => $pipelineSvc->getEditableProfiles(),
    'grantableWells' => $grantableWells,
    'historyTypes' => $historyTypes,
    'historyFilters' => $historyFilters,
    'historyRows' => $historyRows,
    'historyTotal' => $historyTotal,
];

$pageTitle = t('admin.pipelines.title');
require_once __DIR__ . '/partials/header.php';
require __DIR__ . '/../templates/views/admin/pipelines/main.php';
require_once __DIR__ . '/partials/footer.php';

} catch (Throwable $e) {
    if (class_exists('GameLog', false)) GameLog::error('admin/pipelines.php', tPlain('common.unhandled_exception'), $e);
    echo t('common.app_error');
} finally {
    if (class_exists('GameLog', false)) GameLog::pageEnd('admin/pipelines.php', $_codexGuardStart);
}
