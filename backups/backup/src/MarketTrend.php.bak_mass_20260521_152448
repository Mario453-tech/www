<?php

class MarketTrend
{
    /** Minimum time (minutes) between consecutive trend activations */
    const COOLDOWN_MINUTES = 30;

    /** Probability (%) of activating a new trend when none is active and cooldown has passed */
    const ACTIVATION_CHANCE = 10;

    private PDO $db;

    public function __construct()
    {
        $this->db = Database::getInstance()->getConnection();
    }

    // Retrieval

    /** @return array<string, mixed>|null */
    public function getActiveTrend(): ?array
    {
        try {
            $stmt = $this->db->prepare("
                SELECT * FROM market_trends
                WHERE active = TRUE
                  AND activated_at IS NOT NULL
                  AND activated_at > DATE_SUB(NOW(), INTERVAL duration_hours HOUR)
                ORDER BY activated_at DESC
                LIMIT 1
            ");
            $stmt->execute();
            $row = $stmt->fetch();
            return $row ?: null;
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getActiveTrend FAILED', $e);
            return null;
        }
    }

    /** @return array<string, mixed>|null */
    public function getTrend(int $trendId): ?array
    {
        try {
            $stmt = $this->db->prepare("SELECT * FROM market_trends WHERE id = :id");
            $stmt->execute([':id' => $trendId]);
            $row = $stmt->fetch();
            return $row ?: null;
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getTrend FAILED', $e, ['id' => $trendId]);
            return null;
        }
    }

    /** @return list<array<string, mixed>> */
    public function getAllTrends(): array
    {
        try {
            return $this->db->query(
                "SELECT * FROM market_trends ORDER BY category, trend_name"
            )->fetchAll();
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getAllTrends FAILED', $e);
            return [];
        }
    }

    public function getTrendsByCategory(string $category): array
    {
        try {
            $stmt = $this->db->prepare("
                SELECT * FROM market_trends
                WHERE category = :category
                ORDER BY trend_name
            ");
            $stmt->execute([':category' => $category]);
            return $stmt->fetchAll();
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getTrendsByCategory FAILED', $e);
            return [];
        }
    }

    public function getTrendHistory(int $limit = 10): array
    {
        try {
            $stmt = $this->db->prepare("
                SELECT * FROM market_trends
                WHERE activated_at IS NOT NULL
                ORDER BY activated_at DESC
                LIMIT :limit
            ");
            $stmt->bindValue(':limit', $limit, PDO::PARAM_INT);
            $stmt->execute();
            return $stmt->fetchAll();
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getTrendHistory FAILED', $e);
            return [];
        }
    }

    // Activation

    public function activateTrend(int $trendId): bool
    {
        try {
            $trend = $this->getTrend($trendId);
            if (!$trend) {
                GameLog::warn('MarketTrend', 'activateTrend: trend not found', ['id' => $trendId]);
                return false;
            }

            // Deactivate all previously active trends
            $this->db->query("UPDATE market_trends SET active = FALSE");

            // Activate the new one
            $this->db->prepare("
                UPDATE market_trends
                SET active = TRUE, activated_at = NOW()
                WHERE id = :id
            ")->execute([':id' => $trendId]);

            GameLog::info('MarketTrend', 'activateTrend: activated', [
                'id'       => $trendId,
                'name'     => $trend['trend_name'],
                'modifier' => $trend['price_modifier'],
                'duration' => $trend['duration_hours'] . 'h',
            ]);

            return true;

        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'activateTrend FAILED', $e, ['id' => $trendId]);
            return false;
        }
    }

    /**
     * Deactivates trends whose duration_hours have elapsed.
     */
    public function deactivateExpiredTrends(): void
    {
        try {
            $this->db->prepare("
                UPDATE market_trends
                SET active = FALSE
                WHERE active = TRUE
                  AND activated_at < DATE_SUB(NOW(), INTERVAL duration_hours HOUR)
            ")->execute();
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'deactivateExpiredTrends FAILED', $e);
        }
    }

    /**
     * Rolls and activates a new trend if:
     *  - no trend is currently active,
     *  - cooldown has passed (30 min since last activation),
     *  - random roll succeeds (10% chance).
     *
     * Cooldown prevents a new trend from firing immediately after the previous one ends.
     *
     * @return array|null  Active trend (new or existing), null if none
     */
    public function checkAndActivateRandomTrend(): ?array
    {
        try {
            $activeTrend = $this->getActiveTrend();

            // A trend is already active — do nothing
            if ($activeTrend) {
                return $activeTrend;
            }

            // Check cooldown — when was any trend last active?
            if ($this->isCooldownActive()) {
                GameLog::info('MarketTrend', 'checkAndActivate: cooldown active — skipping');
                return null;
            }

            // Roll 10% activation chance
            if (rand(1, 100) > self::ACTIVATION_CHANCE) {
                return null;
            }

            // Pick a random inactive trend
            $randomTrend = $this->getRandomInactiveTrend();
            if (!$randomTrend) {
                GameLog::warn('MarketTrend', 'checkAndActivate: no available trends');
                return null;
            }

            $activated = $this->activateTrend((int)$randomTrend['id']);
            if (!$activated) {
                return null;
            }

            // Fetch fresh data after activation
            return $this->getTrend((int)$randomTrend['id']);

        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'checkAndActivateRandomTrend FAILED', $e);
            return null;
        }
    }

    // Helpers

    /**
     * Returns true if the cooldown since the last trend activation has not yet elapsed.
     */
    private function isCooldownActive(): bool
    {
        try {
            $lastActivated = $this->db->query("
                SELECT MAX(activated_at) FROM market_trends
                WHERE activated_at IS NOT NULL
            ")->fetchColumn();

            if (!$lastActivated) {
                return false; // No trend has ever been active — no cooldown
            }

            $minutesSince = (time() - strtotime($lastActivated)) / 60;
            return $minutesSince < self::COOLDOWN_MINUTES;

        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'isCooldownActive FAILED', $e);
            return false; // On error, allow activation to proceed
        }
    }

    private function getRandomInactiveTrend(): ?array
    {
        try {
            $stmt = $this->db->query("
                SELECT * FROM market_trends
                WHERE active = FALSE
                  AND message_template != ''
                ORDER BY RAND()
                LIMIT 1
            ");
            $row = $stmt->fetch();
            return $row ?: null;
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getRandomInactiveTrend FAILED', $e);
            return null;
        }
    }

    public function getTrendMessage(array $trend): string
    {
        try {
            $template = $trend['message_template'] ?? '';
            if (empty($template)) return '';

            $percent = abs(round(((float)$trend['price_modifier'] - 1) * 100));
            return str_replace(
                ['{name}', '{percent}'],
                [$trend['trend_name'], $percent],
                $template
            );
        } catch (Throwable $e) {
            GameLog::error('MarketTrend', 'getTrendMessage FAILED', $e);
            return '';
        }
    }
}
