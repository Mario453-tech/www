<?php

/**
 * HubAdminActionsTrait — admin-facing hub mutations: build, repair, upgrade, toggle, rename.
 *
 * Hubs are SYSTEM-OWNED infrastructure (player_id = 0).
 * All mutating operations are admin-only; $adminId is used for logging only,
 * NOT as an ownership filter in SQL.
 *
 * Used by HubService.
 */
trait HubAdminActionsTrait
{
    /**
     * Creates a new system hub (admin only).
     * Hub is inserted with player_id = 0 (system-owned).
     *
     * @param int                  $adminId
     * @param array<string, mixed> $params  [name, hub_type, acquisition_type, region_id, zone_key]
     * @return array{success: bool, hub_id?: int, error?: string}
     */
    public function buildHub(int $adminId, array $params): array
    {
        $name            = trim($params['name']             ?? '');
        $hubType         = $params['hub_type']               ?? '';
        $acquisitionType = $params['acquisition_type']       ?? 'new';
        $regionId        = (int)($params['region_id']       ?? 0);
        $zoneKey         = $params['zone_key']               ?? '';

        if ($name === '' || strlen($name) > 120) {
            return ['success' => false, 'error' => 'invalid_name'];
        }
        if (!in_array($hubType, ['small', 'medium', 'large'], true)) {
            return ['success' => false, 'error' => 'invalid_type'];
        }
        if (!in_array($acquisitionType, ['new', 'used', 'rental'], true)) {
            return ['success' => false, 'error' => 'invalid_acquisition'];
        }
        if ($regionId <= 0) {
            return ['success' => false, 'error' => 'invalid_region'];
        }

        $defaults     = $this->getHubTypeDefaults($hubType, 1);
        $acqDefaults  = $this->getAcquisitionDefaults($acquisitionType);
        $now          = date('Y-m-d H:i:s');
        $regionMult   = max(0.1, (float)$this->cfg('region', $regionId . '.build_cost_mult', '1.0'));
        $buildCost    = round((float)$defaults['build_cost'] * $regionMult * (float)$acqDefaults['build_cost_mult'], 2);
        $condMin      = min((float)$acqDefaults['start_condition_min'], (float)$acqDefaults['start_condition_max']);
        $condMax      = max((float)$acqDefaults['start_condition_min'], (float)$acqDefaults['start_condition_max']);
        $initialCond  = round(mt_rand((int)round($condMin * 100), (int)round($condMax * 100)) / 100, 2);
        $leaseFee     = round((float)$acqDefaults['lease_fee_per_tick'], 2);

        try {
            $this->db->prepare(
                "INSERT INTO logistics_hubs
                    (player_id, region_id, zone_key, name, hub_type, acquisition_type, status, work_mode,
                     level, slot_limit, condition_pct, initial_condition_pct, wear_level, efficiency_pct,
                     nominal_capacity_bph, real_capacity_bph,
                     buffer_capacity_bbl, buffer_current_bbl,
                     opex_per_tick, lease_fee_per_tick, build_cost, repair_cost_estimate, last_maintenance_at,
                     created_at, updated_at)
                 VALUES
                    (0, ?, ?, ?, ?, ?, 'active', 'standard',
                     1, ?, ?, ?, 0.0000, ?,
                     ?, ?,
                     ?, 0.00,
                     ?, ?, ?, 0.00, ?,
                     ?, ?)"
            )->execute([
                $regionId, $zoneKey, $name, $hubType, $acquisitionType,
                $defaults['slot_limit'],
                $initialCond,
                $initialCond,
                min(100.0, $initialCond),
                $defaults['nominal_bph'],
                $defaults['nominal_bph'],
                $defaults['buffer_bbl'],
                $defaults['opex_per_tick'],
                $leaseFee,
                $buildCost,
                $now,
                $now, $now,
            ]);

            $hubId = (int)$this->db->lastInsertId();

            GameLog::info('HubService', 'System hub created by admin', [
                'hub_id'    => $hubId,
                'admin_id'  => $adminId,
                'type'      => $hubType,
                'acquisition_type' => $acquisitionType,
                'region_id' => $regionId,
                'zone'      => $zoneKey,
            ]);

            return ['success' => true, 'hub_id' => $hubId];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'buildHub failed', $e, ['admin_id' => $adminId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Repairs a hub, restoring condition to 100% (admin only).
     * @return array{success: bool, error?: string}
     */
    public function repairHub(int $hubId, int $adminId): array
    {
        $hub = $this->getHub($hubId);
        if (!$hub) {
            return ['success' => false, 'error' => 'not_found'];
        }
        if ((float)$hub['condition_pct'] >= 100.0) {
            return ['success' => false, 'error' => 'already_full'];
        }

        try {
            $this->db->prepare(
                "UPDATE logistics_hubs
                    SET condition_pct        = 100.00,
                        wear_level           = 0.0000,
                        efficiency_pct       = 100.00,
                        status               = IF(status = 'damaged', 'active', status),
                        repair_cost_estimate = 0.00,
                        last_maintenance_at  = NOW(),
                        updated_at           = NOW()
                  WHERE id = ?"
            )->execute([$hubId]);

            GameLog::info('HubService', 'Hub repaired', [
                'hub_id'   => $hubId,
                'admin_id' => $adminId,
            ]);

            return ['success' => true];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'repairHub failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Upgrades a hub level (max defined by config, admin only).
     * @return array{success: bool, new_level?: int, error?: string}
     */
    public function upgradeHub(int $hubId, int $adminId): array
    {
        $hub = $this->getHub($hubId);
        if (!$hub) {
            return ['success' => false, 'error' => 'not_found'];
        }

        $currentLevel = (int)$hub['level'];
        $defaults     = $this->getHubTypeDefaults($hub['hub_type'], $currentLevel);

        if ($currentLevel >= $defaults['max_level']) {
            return ['success' => false, 'error' => 'max_level'];
        }

        $newLevel    = $currentLevel + 1;
        $newDefaults = $this->getHubTypeDefaults($hub['hub_type'], $newLevel);
        $lvlDelta    = $newDefaults['nominal_bph'] - (float)$hub['nominal_capacity_bph'];

        try {
            $this->db->prepare(
                "UPDATE logistics_hubs
                    SET level                = ?,
                        slot_limit           = ?,
                        nominal_capacity_bph = ?,
                        real_capacity_bph    = LEAST(real_capacity_bph + ?, nominal_capacity_bph + ?),
                        buffer_capacity_bbl  = ?,
                        updated_at           = NOW()
                  WHERE id = ?"
            )->execute([
                $newLevel,
                $newDefaults['slot_limit'],
                $newDefaults['nominal_bph'],
                $lvlDelta, $lvlDelta,
                $newDefaults['buffer_bbl'],
                $hubId,
            ]);

            GameLog::info('HubService', 'Hub upgraded', [
                'hub_id'    => $hubId,
                'admin_id'  => $adminId,
                'new_level' => $newLevel,
            ]);

            return ['success' => true, 'new_level' => $newLevel];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'upgradeHub failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Sets the work mode (eco|standard|max) for a hub (admin only).
     * @return array{success: bool, error?: string}
     */
    public function setWorkMode(int $hubId, int $adminId, string $workMode): array
    {
        if (!in_array($workMode, ['eco', 'standard', 'max'], true)) {
            return ['success' => false, 'error' => 'invalid_mode'];
        }
        if (!$this->getHub($hubId)) {
            return ['success' => false, 'error' => 'not_found'];
        }

        try {
            $this->db->prepare(
                "UPDATE logistics_hubs SET work_mode = ?, updated_at = NOW() WHERE id = ?"
            )->execute([$workMode, $hubId]);

            GameLog::info('HubService', 'Hub work mode changed', [
                'hub_id'   => $hubId,
                'admin_id' => $adminId,
                'mode'     => $workMode,
            ]);

            return ['success' => true];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'setWorkMode failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Pauses or resumes a hub (admin only).
     * @return array{success: bool, new_status?: string, error?: string}
     */
    public function toggleHubPause(int $hubId, int $adminId): array
    {
        $hub = $this->getHub($hubId);
        if (!$hub) {
            return ['success' => false, 'error' => 'not_found'];
        }

        $newStatus = ($hub['status'] === 'paused') ? 'active' : 'paused';

        try {
            $this->db->prepare(
                "UPDATE logistics_hubs SET status = ?, updated_at = NOW() WHERE id = ?"
            )->execute([$newStatus, $hubId]);

            GameLog::info('HubService', 'Hub pause toggled', [
                'hub_id'     => $hubId,
                'admin_id'   => $adminId,
                'new_status' => $newStatus,
            ]);

            return ['success' => true, 'new_status' => $newStatus];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'toggleHubPause failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Renames a hub (admin only).
     * @return array{success: bool, error?: string}
     */
    public function renameHub(int $hubId, int $adminId, string $name): array
    {
        $name = trim($name);
        if ($name === '' || strlen($name) > 120) {
            return ['success' => false, 'error' => 'invalid_name'];
        }
        if (!$this->getHub($hubId)) {
            return ['success' => false, 'error' => 'not_found'];
        }

        try {
            $this->db->prepare(
                "UPDATE logistics_hubs SET name = ?, updated_at = NOW() WHERE id = ?"
            )->execute([$name, $hubId]);

            GameLog::info('HubService', 'Hub renamed', [
                'hub_id'   => $hubId,
                'admin_id' => $adminId,
                'name'     => $name,
            ]);

            return ['success' => true];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'renameHub failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Sets hub status directly (admin only).
     * @return array{success: bool, error?: string}
     */
    public function adminSetStatus(int $hubId, string $status): array
    {
        if (!in_array($status, ['active', 'paused', 'damaged', 'disabled', 'building'], true)) {
            return ['success' => false, 'error' => 'invalid_status'];
        }

        try {
            $this->db->prepare(
                "UPDATE logistics_hubs SET status = ?, updated_at = NOW() WHERE id = ?"
            )->execute([$status, $hubId]);

            return ['success' => true];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'adminSetStatus failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }

    /**
     * Force-updates hub condition and wear (admin only).
     * @return array{success: bool, error?: string}
     */
    public function adminSetCondition(int $hubId, float $conditionPct, float $wearLevel): array
    {
        $conditionPct = max(0.0, min(100.0, $conditionPct));
        $wearLevel    = max(0.0, $wearLevel);

        try {
            $status = ($conditionPct < 30.0) ? 'damaged' : null;
            $sql    = $status
                ? "UPDATE logistics_hubs SET condition_pct = ?, wear_level = ?, status = ?, updated_at = NOW() WHERE id = ?"
                : "UPDATE logistics_hubs SET condition_pct = ?, wear_level = ?, updated_at = NOW() WHERE id = ?";
            $params = $status
                ? [$conditionPct, $wearLevel, $status, $hubId]
                : [$conditionPct, $wearLevel, $hubId];

            $this->db->prepare($sql)->execute($params);

            return ['success' => true];
        } catch (Throwable $e) {
            GameLog::error('HubService', 'adminSetCondition failed', $e, ['hub_id' => $hubId]);
            return ['success' => false, 'error' => 'db_error'];
        }
    }
}
