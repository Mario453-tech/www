<?php

/**
 * HubEventsTrait — event creation and repair cost calculation.
 * Shared by HubService and HubAssignmentService.
 */
trait HubEventsTrait
{
    /**
     * Creates a logistics event record (for any player or system event).
     */
    public function createEvent(
        int $playerId,
        ?int $hubId,
        ?int $wellId,
        string $eventType,
        string $severity,
        string $title,
        string $message
    ): void {
        try {
            $this->db->prepare(
                "INSERT INTO logistics_hub_events
                    (player_id, hub_id, well_id, event_type, severity, title, message, created_at)
                 VALUES (?, ?, ?, ?, ?, ?, ?, NOW())"
            )->execute([$playerId, $hubId, $wellId, $eventType, $severity, $title, $message]);
        } catch (Throwable $e) {
            GameLog::error('HubService', 'createEvent failed', $e);
        }
    }

    /**
     * Calculates estimated repair cost for a hub.
     * @param array<string, mixed> $hub
     */
    public function getRepairCost(array $hub): float
    {
        $damage  = max(0.0, 100.0 - (float)$hub['condition_pct']);
        $base    = $this->cfgFloat('hub_type', $hub['hub_type'] . '.build_cost', 50000.0);
        $costPct = $this->cfgFloat('hub_type', $hub['hub_type'] . '.repair_cost_pct', 0.40);
        return round($base * ($damage / 100.0) * $costPct, 2);
    }
}
