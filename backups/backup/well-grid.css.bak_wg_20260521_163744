/* SVG icon helper  wgIco() output */
.wg-ico {
    display: inline-block;
    width:  1em;
    height: 1em;
    vertical-align: -0.125em;
    overflow: visible;
}

/* Arrow rotation for collapse/expand toggles */
.wg-section-arrow .wg-ico,
.wg-storage-arrow .wg-ico,
.wg-equipment-arrow .wg-ico,
.wg-layer-arrow .wg-ico {
    transition: transform 0.2s ease;
}
.wg-arrow-open .wg-ico {
    transform: rotate(180deg);
}

.well-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
}

/* <details> karta */
details.well-card {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius, 8px);
    overflow: hidden;
    transition: border-color .2s;
}
details.well-card:hover        { border-color: rgba(255,255,255,.16); }
details.well-card.well-card-paused { border-color: rgba(230,180,60,.2); background: rgba(230,180,60,.03); }
details.well-card.well-card-seized { border-color: rgba(224,85,85,.25); background: rgba(224,85,85,.04); }

details.well-card summary.well-card-summary {
    list-style: none;
    cursor: pointer;
    padding: 14px 16px;
    outline: none;
    user-select: none;
}
details.well-card summary::-webkit-details-marker { display: none; }

.well-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
}
.well-card-header h3 {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    color: var(--text);
}

.well-status-badge {
    font-size: 12px;
    font-weight: 600;
    border-radius: 20px;
    padding: 2px 10px;
    white-space: nowrap;
}
.well-status-badge.success { background: rgba(78,201,122,.12); color: #4ec97a; border: 1px solid rgba(78,201,122,.2); }
.well-status-badge.warning { background: rgba(230,180,60,.12); color: #e6b43c; border: 1px solid rgba(230,180,60,.2); }
.well-status-badge.danger  { background: rgba(224,85,85,.12);  color: #e05555; border: 1px solid rgba(224,85,85,.2); }

.well-card-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 12px;
    color: var(--text-muted, rgba(232,232,240,.6));
}
.well-card-stats span strong { color: var(--text); }

.well-expand-hint {
    font-size: 11px;
    color: rgba(232,232,240,.25);
    text-align: right;
    margin-top: 8px;
}
details.well-card summary:hover .well-expand-hint { color: rgba(232,232,240,.5); }

.well-detail-section {
    border-top: 1px solid rgba(255,255,255,.07);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

/* Alerty statusu */
.well-alert {
    font-size: 13px;
    border-radius: 6px;
    padding: 10px 14px;
    line-height: 1.5;
}
.well-alert a { color: var(--gold, #c8a84b); }
.well-alert--warning { background: rgba(230,180,60,.08); border: 1px solid rgba(230,180,60,.2); color: rgba(232,232,240,.8); }
.well-alert--danger  { background: rgba(224,85,85,.08);  border: 1px solid rgba(224,85,85,.2);  color: rgba(232,232,240,.8); }

/* Statystyki odwiertu */
.well-detail-stats { display: flex; flex-direction: column; gap: 6px; }
.well-detail-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--text-muted, rgba(232,232,240,.6));
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
}
.well-detail-row strong { color: var(--text); font-weight: 600; }

