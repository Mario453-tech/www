.wg-storage-track  { height: 5px; background: rgba(255,255,255,.07); border-radius: 3px; overflow: hidden; margin-bottom: 8px; }
.wg-storage-fill   { height: 100%; background: #20b2aa; border-radius: 3px; }
.wg-storage-footer { display: flex; justify-content: space-between; align-items: center; }
.wg-storage-cost   { font-size: 12px; color: rgba(232,232,240,.4); }
.wg-storage-budget { font-size: 11px; font-weight: 600; }

/*  Responsive  */
@media (max-width: 640px) {
    .wg-kpi-grid  { grid-template-columns: repeat(3, 1fr); gap: 4px; }
    .wg-kpi-value { font-size: 14px; }
    .wg-well-name { font-size: 15px; }
    .wg-cur-stats { grid-template-columns: repeat(2, 1fr); }
    .wg-mult-grid { grid-template-columns: repeat(2, 1fr); }
}
