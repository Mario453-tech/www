/* ═══════════════════════════════════════════════════════════════
   TEMPLATE EDITOR — Panel admina, edytor header/footer/nawigacji
   ═══════════════════════════════════════════════════════════════ */

.te-tabs        { display: flex; gap: 4px; margin-bottom: 16px; border-bottom: 1px solid var(--border); padding-bottom: 0; }
.te-tab         { padding: 8px 16px; font-size: .85rem; text-decoration: none; color: var(--muted);
                  border-radius: 6px 6px 0 0; border: 1px solid transparent; border-bottom: none;
                  margin-bottom: -1px; }
.te-tab:hover   { color: var(--text); background: rgba(255,255,255,.04); }
.te-tab.active  { color: var(--accent); border-color: var(--border); background: var(--card); }

.te-layout      { display: grid; grid-template-columns: 220px 1fr; gap: 16px; align-items: start; }
.te-sidebar     { background: var(--card); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
.te-sidebar-hdr { padding: 10px 14px; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em;
                  color: var(--muted); border-bottom: 1px solid var(--border); }
.te-list        { list-style: none; margin: 0; padding: 0; }
.te-list li a   { display: flex; align-items: center; gap: 8px; padding: 9px 14px;
                  font-size: .85rem; color: var(--text); text-decoration: none;
                  border-bottom: 1px solid rgba(255,255,255,.04); }
.te-list li a:hover  { background: rgba(255,255,255,.05); }
.te-list li a.active { background: rgba(200,168,75,.12); color: #c8a84b; font-weight: 600; }
.te-icon        { font-size: 1rem; min-width: 20px; text-align: center; }
.te-sort        { margin-left: auto; font-size: .7rem; color: var(--muted); }
.te-badge       { font-size: .7rem; padding: 1px 6px; border-radius: 10px;
                  background: rgba(224,85,85,.2); color: #e05555; }
.te-ok          { font-size: .7rem; color: #4ec97a; }

.te-add-form        { padding: 10px 14px; border-top: 1px solid var(--border); }
.te-add-form label  { font-size: .7rem; color: var(--muted); display: block; margin-bottom: 2px; margin-top: 6px; }
.te-add-form input  { width: 100%; }

.te-editor      { background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 20px; }
.te-editor h2   { font-size: 1rem; margin-bottom: 16px; color: var(--accent); }
.te-meta        { display: grid; grid-template-columns: 60px 1fr 1fr 120px; gap: 10px; margin-bottom: 14px; align-items: start; }
.te-meta label  { font-size: .75rem; color: var(--muted); display: block; margin-bottom: 4px; }
.te-meta input  { width: 100%; }
.te-meta small  { display: block; margin-top: 3px; }

.te-preview     { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08);
                  border-radius: 8px; padding: 12px 16px; margin-top: 12px; }

.te-config-wrap { max-width: 760px; }
.te-label       { display: block; font-size: .8rem; color: var(--muted); margin-bottom: 5px; }

.te-footer-preview { font-size: .85rem; color: rgba(232,232,240,.6);
                     padding: 10px 14px; background: rgba(255,255,255,.02);
                     border-radius: 6px; }

@media (max-width: 700px) {
    .te-layout { grid-template-columns: 1fr; }
    .te-meta   { grid-template-columns: 1fr 1fr; }
}
