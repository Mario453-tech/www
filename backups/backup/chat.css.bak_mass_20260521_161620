/* 
   CHAT + NEWS Ś wrapper i panel aktualnoťci
    */

/* Wrapper: newsy po lewej, czat po prawej */
.chat-news-wrapper {
    display: flex;
    gap: 12px;
    align-items: stretch;
    max-height: 350px !important;
}

/* Panel aktualnoťci Ś zajmuje ~30% szerokoťci */
.news-panel {
    flex: 0 0 30%;
    min-width: 180px;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    overflow: hidden;
}

.news-panel h2 {
    padding: 12px 16px 10px;
    margin: 0;
    font-size: .85rem;
    border-bottom: 1px solid var(--brd, rgba(255,255,255,.08));
}

.news-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
}

.news-list::-webkit-scrollbar { width: 4px; }
.news-list::-webkit-scrollbar-track { background: transparent; }
.news-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 2px; }

.news-item {
    border-bottom: 1px solid rgba(255,255,255,.06);
    padding-bottom: 8px;
}
.news-item:last-child { border-bottom: none; padding-bottom: 0; }

.news-item--pinned {
    background: rgba(200,168,75,.07);
    border-left: 2px solid rgba(200,168,75,.5);
    padding: 6px 8px;
    border-radius: 0 4px 4px 0;
    margin: 0 -4px;
}

.news-item-title {
    font-size: .78rem;
    font-weight: 600;
    color: rgba(232,232,240,.9);
    margin-bottom: 3px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.news-item-pin {
    color: #c8a84b;
    font-size: .7rem;
}

.news-item-content {
    font-size: .74rem;
    color: rgba(232,232,240,.65);
    line-height: 1.45;
    word-break: break-word;
}

.news-item-date {
    font-size: .66rem;
    color: rgba(232,232,240,.3);
    margin-top: 4px;
}

.news-loading {
    color: rgba(232,232,240,.35);
    font-size: .75rem;
    text-align: center;
    margin: auto;
}

/* Czat zajmuje pozosta│e ~70% (flex:1) */
.chat-box {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    min-height: 210px;
    gap: 0;
    padding: 0;
    overflow: hidden;
}

.chat-box h2 {
    padding: 12px 16px 10px;
    margin: 0;
    font-size: .85rem;
    border-bottom: 1px solid var(--brd, rgba(255,255,255,.08));
}

.chat-messages {
    flex: 1 1 auto;
    min-height: 150px;
    overflow-y: auto;
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    scroll-behavior: smooth;
}

.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 2px; }

.chat-loading {
    color: rgba(232,232,240,.35);
    font-size: .75rem;
    text-align: center;
    margin: auto;
}

/*  Pojedyncza wiadomoťŠ Ś uk│ad b╣belkowy  */
.chat-msg {
    display: flex;
    flex-direction: column;
    margin-bottom: 10px;
    animation: chatFadeIn .15s ease;
}

@keyframes chatFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* Nag│ˇwek: avatar + nick + spacer + czas */
.chat-msg-header {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 3px;
}

/* Elastyczny separator nick  czas */
.chat-msg-spacer { flex: 1; min-width: 4px; }

/* Avatar Ś kˇ│ko 28Î28 */
.chat-msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
}
/* Fallback inicja│owy */
.chat-msg-avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(200,168,75,.12);
    border: 1px solid rgba(200,168,75,.28);
    color: var(--gold, #c8a84b);
    font-size: .62rem;
    font-weight: 700;
}

/* Nick */
.chat-msg-author {
    font-weight: 600;
    font-size: .78rem;
    color: rgba(232,232,240,.85);
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex-shrink: 0;
}
.chat-msg--mine  .chat-msg-author { color: #6fcf97; }
.chat-msg--admin .chat-msg-author { color: #c8a84b; font-weight: 700; }

/* Czas */
.chat-msg-time {
    color: rgba(232,232,240,.3);
    font-size: .68rem;
    white-space: nowrap;
    flex-shrink: 0;
}

/* Znaczek pin w nicku */
.chat-pin-badge { font-size: .65rem; margin-right: 2px; }

/*  B╣belek treťci  */
.chat-msg-bubble {
    max-width: 85%;
    padding: 6px 10px;
    border-radius: 4px 12px 12px 12px;
    background: rgba(255,255,255,.055);
    color: rgba(232,232,240,.88);
    font-size: .81rem;
    line-height: 1.45;
    word-break: break-word;
    overflow-wrap: break-word;
    min-width: 0;
    align-self: flex-start;
}
/* Moje wiadomoťci Ś b╣belek po prawej, z│oty akcent */
.chat-msg-bubble--mine {
    background: rgba(200,168,75,.13);
    border: 1px solid rgba(200,168,75,.22);
    border-radius: 12px 4px 12px 12px;
    align-self: flex-end;
}
/* Wiadomoťci admina */
.chat-msg-bubble--admin,
.chat-msg--admin .chat-msg-bubble {
    background: rgba(200,168,75,.10);
    border-left: 2px solid rgba(200,168,75,.5);
    border-radius: 0 12px 12px 0;
    color: rgba(232,232,240,.95);
}
/* Przypiŕte */
.chat-msg--pinned .chat-msg-bubble {
    border: 1px solid rgba(200,168,75,.35);
}

/*  Formularz  */
.chat-form {
    display: flex;
    gap: 6px;
    padding: 8px 12px;
    border-top: 1px solid var(--brd, rgba(255,255,255,.08));
    margin-top: auto;
    flex-shrink: 0;
}

.chat-input {
    flex: 1;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 4px;
    color: #e8e8f0;
    font-size: .82rem;
    padding: 5px 10px;
    outline: none;
    transition: border-color .15s;
}

.chat-input:focus {
    border-color: var(--orange, #c8a84b);
}

.chat-send {
    padding: 5px 14px;
    font-size: .8rem;
    white-space: nowrap;
}

/*  System / info  */
.chat-msg--system .chat-msg-author { color: rgba(232,232,240,.4); font-weight: normal; }
.chat-msg--system .chat-msg-bubble { color: rgba(232,232,240,.4); font-style: italic; background: transparent; }

/*  Pasek przypiŕtych Ś sta│y, poza scrollem  */
.chat-pinned-bar {
    border-bottom: 1px solid rgba(200,168,75,.25);
    background: rgba(200,168,75,.06);
    padding: 6px 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    max-height: 110px;
    overflow-y: auto;
}

.chat-pinned-bar::-webkit-scrollbar { width: 3px; }
.chat-pinned-bar::-webkit-scrollbar-thumb { background: rgba(200,168,75,.3); border-radius: 2px; }

.chat-pinned-bar-label {
    font-size: .62rem;
    color: rgba(200,168,75,.55);
    text-transform: uppercase;
    letter-spacing: .06em;
    font-weight: 600;
    margin-bottom: 2px;
}

.chat-pinned-entry {
    display: flex;
    gap: 5px;
    font-size: .76rem;
    line-height: 1.35;
    align-items: flex-start;
}

.chat-pinned-entry-icon {
    color: #c8a84b;
    flex-shrink: 0;
    font-size: .7rem;
    padding-top: 1px;
}

.chat-pinned-entry-text {
    color: rgba(232,232,240,.88);
    word-break: break-word;
}

/*  Przyciski report i DM Ś w nag│ˇwku wiadomoťci  */
.chat-msg-opts {
    display: inline-flex;
    gap: 4px;
    opacity: 0;
    transition: opacity .15s;
    flex-shrink: 0;
}
.chat-msg:hover .chat-msg-opts { opacity: 1; }
.chat-report-btn, .chat-dm-btn {
    background: none; border: none; cursor: pointer;
    font-size: 11px; padding: 1px 4px;
    color: rgba(255,255,255,.35);
    border-radius: 3px; text-decoration: none;
    transition: color .15s, background .15s;
}
.chat-report-btn:hover { color: #e24b4a; background: rgba(226,75,74,.12); }
.chat-dm-btn:hover { color: #378add; background: rgba(55,138,221,.12); }

/*  RESPONSIVE Ś mobile  */

/* Zabezpieczenie min-width:0 dla flex dzieci Ś zapobiega │amaniu po znaku */
.chat-pinned-entry-text,
.chat-msg-bubble { min-width: 0; overflow-wrap: break-word; word-break: break-word; }
.chat-pinned-entry { min-width: 0; }

/* Breakpoint 750px Ś bezpieczny dla wszystkich telefonˇw (360ľ480px viewport) */
@media (max-width: 750px) {
    /* news + chat stack pionowo */
    .chat-news-wrapper {
        flex-direction: column;
        gap: 8px;
    }

    /* panel newsˇw Ś ca│a szerokoťŠ */
    .news-panel {
        flex: none !important;
        max-width: none !important;
        min-width: 0 !important;
        width: 100% !important;
    }
    .news-list { max-height: 160px; }

    /* okno czatu Ś pe│na szerokoťŠ */
    .chat-box {
        width: 100% !important;
        min-width: 0 !important;
        flex: none !important;
    }
    .chat-messages { height: 200px; }

    /* b╣belek Ś pe│na szerokoťŠ na mobile */
    .chat-msg-bubble,
    .chat-msg-bubble--mine { max-width: 92%; }

    /* avatar mniejszy na mobile */
    .chat-msg-avatar { width: 24px; height: 24px; }

    /* nick Ś nieco krˇtszy */
    .chat-msg-author {
        max-width: 110px;
        font-size: .74rem;
    }
    .chat-msg-time { font-size: .62rem; }

    /* pasek przypiŕtych Ś kompaktowy */
    .chat-pinned-bar {
        max-height: 90px;
        padding: 5px 10px;
    }

    /* formularz */
    .chat-form {
        padding: 6px 8px;
        gap: 5px;
    }
    .chat-input  { font-size: .8rem; }
    .chat-send   { padding: 5px 10px; font-size: .75rem; white-space: nowrap; }
}

/* DM Ś Wiadomoťci prywatne  */
.dm-wrap { max-width: 900px; margin: 0 auto; }
.dm-layout {
    display: flex;
    height: 520px;
    overflow: hidden;
    padding: 0;
    gap: 0;
}

/* sidebar listy rozmˇw */
.dm-sidebar {
    width: 220px;
    flex-shrink: 0;
    border-right: 1px solid rgba(255,255,255,.07);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.dm-sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    font-size: .8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: rgba(232,232,240,.5);
    border-bottom: 1px solid rgba(255,255,255,.07);
}
.dm-sidebar-new { position: relative; }
.dm-select-modal {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    background: var(--bg3, #1a1a2a);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 6px;
    min-width: 160px;
    z-index: 50;
    box-shadow: 0 8px 24px rgba(0,0,0,.4);
    max-height: 220px;
    overflow-y: auto;
}
.dm-select-item {
    padding: 8px 14px;
    font-size: .82rem;
    cursor: pointer;
    transition: background .12s;
}
.dm-select-item:hover { background: rgba(255,255,255,.07); }

.dm-conv-list {
    flex: 1;
    overflow-y: auto;
}
.dm-conv-list::-webkit-scrollbar { width: 3px; }
.dm-conv-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 2px; }

.dm-conv-item {
    padding: 10px 12px;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,.04);
    transition: background .12s;
}
.dm-conv-item:hover, .dm-conv-item.active {
    background: rgba(200,168,75,.09);
}
.dm-conv-name { font-size: .83rem; font-weight: 600; margin-bottom: 2px; }
.dm-conv-preview { font-size: .75rem; color: rgba(232,232,240,.45); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* g│ˇwne okno */
.dm-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.dm-main-header {
    padding: 10px 14px;
    font-size: .84rem;
    font-weight: 600;
    border-bottom: 1px solid rgba(255,255,255,.07);
    flex-shrink: 0;
}
.dm-messages {
    flex: 1;
    overflow-y: auto;
    padding: 10px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    scroll-behavior: smooth;
}
.dm-messages::-webkit-scrollbar { width: 4px; }
.dm-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 2px; }

.dm-form {
    display: flex;
    gap: 6px;
    padding: 8px 12px;
    border-top: 1px solid rgba(255,255,255,.07);
    flex-shrink: 0;
}
.dm-empty {
    color: rgba(232,232,240,.35);
    font-size: .8rem;
    text-align: center;
    padding: 24px 0;
}

/* DM Ś mobile */
@media (max-width: 600px) {
    .dm-layout {
        flex-direction: column;
        height: auto;
        max-height: none;
    }
    .dm-sidebar {
        width: 100%;
        border-right: none;
        border-bottom: 1px solid rgba(255,255,255,.07);
        max-height: 180px;
    }
    .dm-conv-list { max-height: 130px; }
    .dm-messages  { min-height: 200px; max-height: 260px; }
    .dm-select-modal { right: auto; left: 0; }
}

/* DM refresh */
.dm-wrap { max-width: 1120px; }
.dm-layout { min-height: 620px; height: clamp(620px, 72vh, 860px); }
.dm-sidebar { width: 260px; background: rgba(15,16,26,.35); }
.dm-sidebar-actions { display:flex; align-items:center; gap:8px; }
.dm-unread-pill,
.dm-conv-unread {
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .72rem;
    font-weight: 700;
    background: rgba(200,168,75,.16);
    border: 1px solid rgba(200,168,75,.32);
    color: #e8cc7a;
}
.dm-conv-top {
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    margin-bottom: 4px;
}
.dm-conv-name { font-size: .88rem; font-weight: 700; }
.dm-main-header {
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:16px;
    padding: 12px 16px;
    font-size: .9rem;
    font-weight: 700;
}
.dm-main-header__identity { display:flex; align-items:center; gap:8px; }
.dm-main-header__icon { color:#e8cc7a; }
.dm-main-header__meta { font-size:.76rem; color:rgba(232,232,240,.42); }
.dm-main { min-height: 0; }
.dm-messages { flex: 1 1 auto; min-height: 0; padding: 16px; gap: 8px; background: linear-gradient(180deg, rgba(255,255,255,.01), rgba(0,0,0,.05)); }
.dm-composer {
    position: relative;
    padding: 10px 12px 12px;
    border-top: 1px solid rgba(255,255,255,.07);
    background: rgba(11,12,20,.7);
    margin-top: auto;
    flex-shrink: 0;
}
.dm-form { align-items:flex-end; gap:10px; }
.dm-form-main {
    flex: 1;
    min-width: 0;
    display:flex;
    align-items:flex-end;
    gap:10px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.09);
    border-radius: 10px;
    padding: 10px 12px;
}
.dm-input {
    min-height: 24px;
    max-height: 140px;
    resize: none;
    border: none;
    background: transparent;
    padding: 0;
    line-height: 1.45;
}
.dm-input:focus { border:none; }
.dm-toolbar {
    display:flex;
    align-items:center;
    gap:6px;
    flex-shrink:0;
}
.dm-tool-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.04);
    color: rgba(232,232,240,.74);
    cursor: pointer;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size: 1rem;
    transition: border-color .15s, color .15s, background .15s;
}
.dm-tool-btn:hover {
    color: #e8cc7a;
    border-color: rgba(200,168,75,.26);
    background: rgba(200,168,75,.08);
}
.dm-send-btn { min-width: 110px; align-self: stretch; }
.dm-popover {
    position: absolute;
    bottom: 78px;
    right: 12px;
    background: #171826;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 10px;
    box-shadow: 0 16px 30px rgba(0,0,0,.35);
    z-index: 40;
}
.dm-popover--emoji {
    padding: 10px;
    display:grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
}
.dm-emoji-btn {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.04);
    cursor:pointer;
    font-size: 1.05rem;
}
.dm-popover--settings { width: 240px; padding: 12px; }
.dm-popover__title {
    font-size: .76rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: rgba(232,232,240,.5);
    margin-bottom: 10px;
}
.dm-setting {
    display:flex;
    gap:10px;
    align-items:flex-start;
    padding: 8px 0;
}
.dm-setting strong { display:block; font-size:.84rem; }
.dm-setting small { display:block; color:rgba(232,232,240,.45); line-height:1.35; }
.dm-attachment-preview { margin-bottom: 10px; }
.dm-attachment-preview__card {
    display:flex;
    align-items:center;
    gap:12px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    padding: 8px 10px;
}
.dm-attachment-preview__img {
    width: 52px;
    height: 52px;
    border-radius: 8px;
    object-fit: cover;
}
.dm-attachment-preview__meta { flex:1; min-width:0; }
.dm-attachment-preview__meta strong,
.dm-attachment-preview__meta small {
    display:block;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
}
.dm-attachment-preview__meta small { color:rgba(232,232,240,.5); }
.dm-attachment-preview__remove,
.dm-attachment-delete {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid rgba(224,85,85,.22);
    background: rgba(224,85,85,.08);
    color: #f28d8d;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
}
.dm-attachment { position: relative; }
.dm-attachment-link { display:block; }
.dm-attachment-image {
    display:block;
    max-width: min(320px, 100%);
    width: 100%;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,.08);
}
.dm-attachment-delete { position: absolute; top: 8px; right: 8px; }
.dm-message-text { margin-top: 8px; }
.dm-empty--centered { margin: auto; }
.dm-toast {
    position: fixed;
    right: 18px;
    bottom: 18px;
    max-width: 320px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,.1);
    background: rgba(14,15,24,.95);
    color: #f1f1f7;
    box-shadow: 0 16px 28px rgba(0,0,0,.28);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .18s, transform .18s;
    z-index: 80;
}
.dm-toast--show { opacity: 1; transform: translateY(0); }
.dm-toast--error { border-color: rgba(224,85,85,.25); }
.nav-dm-badge {
    display:inline-flex;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    margin-left: 6px;
    align-items:center;
    justify-content:center;
    font-size: .68rem;
    font-weight: 700;
    background: rgba(200,168,75,.14);
    border: 1px solid rgba(200,168,75,.28);
    color: #e8cc7a;
}
@media (max-width: 900px) {
    .chat-box { min-height: 180px; }
    .chat-messages { min-height: 110px; }
    .dm-layout { min-height: 560px; height: clamp(560px, 68vh, 760px); }
    .dm-sidebar { width: 230px; }
}
@media (max-width: 700px) {
    .dm-layout { flex-direction: column; min-height: 0; height: auto; }
    .dm-sidebar {
        width: 100%;
        border-right: none;
        border-bottom: 1px solid rgba(255,255,255,.07);
        max-height: 210px;
    }
    .dm-main { min-height: 420px; }
    .dm-messages { min-height: 260px; max-height: none; }
    .dm-main-header {
        flex-direction: column;
        align-items: flex-start;
    }
    .dm-form {
        flex-direction: column;
        align-items: stretch;
    }
