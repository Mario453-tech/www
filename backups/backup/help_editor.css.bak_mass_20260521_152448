/* ═══════════════════════════════════════════════════════════════
   HELP EDITOR — Panel admina, edytor instrukcji obsługi
   ═══════════════════════════════════════════════════════════════ */

.he-layout      { display: grid; grid-template-columns: 220px 1fr; gap: 16px; align-items: start; }
.he-sidebar     { background: var(--card); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
.he-sidebar-hdr { padding: 10px 14px; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em;
                  color: var(--muted); border-bottom: 1px solid var(--border); }
.he-list        { list-style: none; margin: 0; padding: 0; }
.he-list li a   { display: flex; align-items: center; gap: 8px; padding: 9px 14px;
                  font-size: .85rem; color: var(--text); text-decoration: none;
                  border-bottom: 1px solid rgba(255,255,255,.04); }
.he-list li a:hover   { background: rgba(255,255,255,.05); }
.he-list li a.active  { background: rgba(200,168,75,.12); color: #c8a84b; font-weight: 600; }
.he-list li a .he-badge { margin-left: auto; font-size: .7rem; padding: 1px 6px; border-radius: 10px;
                           background: rgba(224,85,85,.2); color: #e05555; }
.he-list li a .he-ok    { margin-left: auto; font-size: .7rem; color: #4ec97a; }
.he-add-form    { padding: 10px 14px; border-top: 1px solid var(--border); }
.he-add-form input { width: 100%; margin-bottom: 6px; }

.he-editor      { background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 20px; }
.he-editor h2   { font-size: 1rem; margin-bottom: 16px; color: var(--accent); }
.he-meta        { display: grid; grid-template-columns: 60px 1fr 80px 60px; gap: 10px; margin-bottom: 14px; align-items: end; }
.he-meta label  { font-size: .75rem; color: var(--muted); display: block; margin-bottom: 4px; }
.he-meta input  { width: 100%; }
.he-tinymce     { margin-bottom: 14px; }

.he-form-label  { font-size: .75rem; color: var(--muted); display: block; margin-bottom: 3px; margin-top: 6px; }
.he-add-btn     { width: 100%; margin-top: 8px; }
.he-meta-info   { font-size: .8rem; color: var(--muted); margin-bottom: 12px; }
.he-empty       { padding: 10px 14px; font-size: .8rem; color: var(--muted); }
.he-checkbox    { width: auto; }

/* Hidden form (delete confirm) */
.form-hidden    { display: none; }

/* Preview panel below editor */
.he-preview-wrap   { margin-top: 20px; border-top: 1px solid var(--border); padding-top: 16px; }
.he-preview-body   { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
                     border-radius: 6px; padding: 14px 18px; font-size: 13px;
                     color: rgba(200,200,220,.8); line-height: 1.7; }
.he-preview-body h3   { color: var(--orange, #e8a020); margin: 0 0 8px; font-size: 15px; }
.he-preview-body p    { margin: 0 0 8px; }
.he-preview-body ul   { padding-left: 20px; margin: 0 0 8px; }
.he-preview-body code { background: rgba(255,255,255,.08); padding: 1px 5px; border-radius: 3px; font-size: 12px; }

@media (max-width: 700px) {
    .he-layout  { grid-template-columns: 1fr; }
    .he-meta    { grid-template-columns: 1fr 1fr; }
}
