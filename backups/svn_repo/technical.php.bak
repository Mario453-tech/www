                <span class="ws-empty-label">— nie przypisano —</span>
                <button type="button" class="btn-ws-assign"
                    onclick="wsOpenAssign(<?= $wsId ?>, 'operator', '<?= htmlspecialchars($ws['well_name']) ?>')">
                    + Przypisz
                </button>
            </div>
            <?php endif ?>
        </div>

        <!-- Technik -->
        <div class="ws-role-row">
            <div class="ws-role-label">
                <span class="ws-role-icon">🔧</span>
                <span>Technik</span>
                <span class="ws-role-req">(degradacja)</span>
            </div>
            <?php if ($hasTe): ?>
            <div class="ws-assigned">
                <span class="ws-person-name"><?= htmlspecialchars($ws['technician']['name']) ?></span>
                <span class="ws-skill-badge">skl <?= $ws['technician']['skill'] ?>/10</span>
                <button type="button" class="btn-ws-remove"
                    onclick="wsUnassign(<?= $wsId ?>, 'technician', this)">✕</button>
            </div>
            <?php else: ?>
            <div class="ws-empty">
                <span class="ws-empty-label">— nie przypisano —</span>
