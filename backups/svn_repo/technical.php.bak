                <div class="ws-modal-sub" id="ws-modal-sub"></div>
            </div>
            <button type="button" class="ws-modal-close" onclick="wsCloseModal()">×</button>
        </div>
        <div class="ws-modal-body" id="ws-modal-body">
            <div class="ws-loading">Ładowanie...</div>
        </div>
    </div>
</div>

<?php endif ?>

<?php if ($activeTab === 'prod'): ?>

<div class="prod-grid">
    <div class="prod-stat"><div class="prod-val"><?= number_format($totalProd, 1) ?></div><div class="prod-unit">bbl/godz</div></div>
    <div class="prod-stat"><div class="prod-val c-blue"><?= number_format($totalProd * 24, 0, '.', ' ') ?></div><div class="prod-unit">bbl/dobę</div></div>
    <div class="prod-stat"><div class="prod-val c-green"><?= count($activeWells) ?> / <?= count($wells) ?></div><div class="prod-unit">aktywnych odwiertów</div></div>
    <div class="prod-stat"><div class="prod-val c-gold"><?= number_format($totalProd * 24 * 30, 0, '.', ' ') ?></div><div class="prod-unit">prognoza 30 dni</div></div>
    <div class="prod-stat"><div class="prod-val <?= $avgCond >= 70 ? 'c-green' : 'c-warn' ?>"><?= $avgCond ?>%</div><div class="prod-unit">śr. stan techniczny</div></div>
</div>

<?php
$pausedStaffCount = count(array_filter($wells, fn($w) => $w['status'] === 'paused_staff'));
$pausedCashCount  = count(array_filter($wells, fn($w) => $w['status'] === 'paused_cash'));
$disasterCount    = count(array_filter($wells, fn($w) => in_array($w['status'], ['blowout','contaminated'])));
?>
<?php if ($pausedStaffCount > 0): ?>
<div class="msg-bar msg-warn">⏸ <?= $pausedStaffCount ?> odwiert(y) wstrzymanych — brak wymaganego personelu. <a href="?tab=candidates" class="link-gold">Zleć rekrutację →</a></div>
<?php endif ?>
<?php if ($pausedCashCount > 0): ?>
<div class="msg-bar msg-error">💸 <?= $pausedCashCount ?> odwiert(y) wstrzymanych — brak środków na OPEX.</div>
<?php endif ?>
<?php if ($disasterCount > 0): ?>
<div class="msg-bar msg-error">🚨 <?= $disasterCount ?> aktywna katastrofa przemysłowa — <a href="?tab=safety" class="link-gold">przejdź do BHP →</a></div>
<?php endif ?>

<?php if (!empty($activeWells)): ?>
<div class="g-card">
    <div class="g-card-title">Produkcja na odwiert</div>
    <div class="data-list">
        <div class="data-list-head cols-prod">
            <span>#</span><span>Lokalizacja</span><span>Produkcja</span><span>Ciśnienie</span><span>Stan tech.</span><span>Udział</span>
        </div>
        <?php foreach ($activeWells as $w):
            $cond    = (float)$w['technical_condition'];
            $p       = (float)($w['pressure'] ?? 1.0);
            $effProd = (float)$w['base_production_per_hour'] * max(0.1, $cond/100) * $p;
            $share   = $totalProd > 0 ? round($effProd / $totalProd * 100, 1) : 0;
        ?>
        <div class="data-list-row cols-prod">
            <span class="dlc sm">#<?= $w['id'] ?></span>
            <span class="dlc"><?= htmlspecialchars($w['location_name'] ?? 'Pole') ?></span>
            <span class="dlc c-gold fw7"><?= number_format($effProd, 1) ?> bbl/h</span>
            <span class="dlc"><?= number_format($p, 3) ?></span>
            <span class="dlc <?= $cond >= 70 ? 'c-good' : ($cond >= 40 ? 'c-warn' : 'c-bad') ?> fw6"><?= round($cond, 1) ?>%</span>
            <span class="dlc sm"><?= $share ?>%</span>
        </div>
        <?php endforeach ?>
    </div>
</div>
<?php endif ?>

<?php endif ?>

<!-- ══════════════════════════════════════
     ZAKŁADKA: INFRASTRUKTURA
══════════════════════════════════════ -->
<?php if ($activeTab === 'infra'): ?>

<?php foreach ($pipelines as $pipe):
    $flow         = min((float)$pipe['capacity_bbl_h'], $totalProd);
    $util         = $pipe['capacity_bbl_h'] > 0 ? round($flow / $pipe['capacity_bbl_h'] * 100, 1) : 0;
    $losses       = round($flow * ($pipe['transport_loss'] / 100), 1);
    $isBottleneck = $totalProd > $pipe['capacity_bbl_h'];
    $utilCls      = $util >= 90 ? 'c-bad' : ($util >= 70 ? 'c-warn' : 'c-green');
    $utilBarCls   = $util >= 90 ? 'util-bad' : ($util >= 70 ? 'util-warn' : 'util-ok');
?>
<div class="pipe-card">
    <div class="pipe-hdr">
        <div>
            <div class="pipe-label">Infrastruktura</div>
            <div class="pipe-name"><?= htmlspecialchars($pipe['name']) ?></div>
        </div>
        <span class="badge <?= $isBottleneck ? 'b-broken' : 'b-active' ?>"><?= $isBottleneck ? 'Wąskie gardło' : 'Sprawny' ?></span>
    </div>
    <?php if ($isBottleneck): ?>
    <div class="pipe-alert">Panie Dyrektorze, rurociąg osiągnął maksymalną przepustowość. Zlec inspekcję — Inżynier Rurociągów.</div>
    <?php endif ?>
    <div class="pipe-stats">
        <div><div class="w-stat-lbl">Przepustowość</div><div class="w-stat-val c-blue"><?= number_format($pipe['capacity_bbl_h']) ?> bbl/h</div></div>
        <div><div class="w-stat-lbl">Aktualny przepływ</div><div class="w-stat-val c-gold"><?= number_format($flow, 1) ?> bbl/h</div></div>
        <div><div class="w-stat-lbl">Straty transportowe</div><div class="w-stat-val c-bad"><?= $pipe['transport_loss'] ?>% (<?= $losses ?> bbl/h)</div></div>
        <div><div class="w-stat-lbl">Wykorzystanie</div><div class="w-stat-val <?= $utilCls ?>"><?= $util ?>%</div></div>
    </div>
    <div class="util-bar"><div class="util-fill <?= $utilBarCls ?>" style="--bar-w:<?= min(100,$util) ?>%"></div></div>
    <div class="pipe-footer">Stan rurociągu: <?= $pipe['condition_pct'] ?>% · Inspekcja redukuje straty (Inżynier Rurociągów)</div>
</div>
<?php endforeach ?>

<?php endif ?>

<!-- ══════════════════════════════════════
     ZAKŁADKA: BEZPIECZEŃSTWO
══════════════════════════════════════ -->
<?php if ($activeTab === 'safety'): ?>

<?php
// ── Panel statusu BHP ───────────────────────────────────
$hseActive   = $hseBonus['active_hse'] > 0;
$failRedPct  = (int)round((1 - $hseBonus['failure_reduction'])  * 100);
$catRedPct   = (int)round((1 - $hseBonus['catastrophe_mult'])   * 100);
$repRedPct   = (int)round((1 - $hseBonus['repair_cost_mult'])   * 100);
$degradRedPct= (int)round((1 - $hseBonus['degrade_mult'])       * 100);
$uptimePct   = round($hseBonus['uptime_bonus'] * 100, 1);
?>
<div class="hse-panel <?= $hseActive ? 'hse-panel--active' : 'hse-panel--inactive' ?>">
    <div class="hse-panel-hdr">
        <span class="hse-icon"><?= $hseActive ? '🟢' : '🔴' ?></span>
        <span class="hse-title">SYSTEM BHP</span>
        <span class="hse-status-badge <?= $hseActive ? 'hse-badge--on' : 'hse-badge--off' ?>">
            <?= $hseActive ? 'AKTYWNY' : 'BRAK OCHRONY' ?>
        </span>
        <?php if ($hseBonus['audit_bonus']): ?>
            <span class="hse-audit-badge">📋 Aktywny audyt +bonus</span>
        <?php endif ?>
    </div>

    <?php if ($hseActive): ?>
    <div class="hse-metrics">
        <div class="hse-metric hse-good">
            <div class="hse-metric-val">-<?= $failRedPct ?>%</div>
            <div class="hse-metric-lbl">Szansa awarii</div>
        </div>
        <div class="hse-metric hse-good">
            <div class="hse-metric-val">-<?= $catRedPct ?>%</div>
            <div class="hse-metric-lbl">Ryzyko katastrofy</div>
        </div>
        <div class="hse-metric hse-good">
            <div class="hse-metric-val">-<?= $repRedPct ?>%</div>
            <div class="hse-metric-lbl">Koszt napraw</div>
        </div>
        <div class="hse-metric hse-good">
            <div class="hse-metric-val">-<?= $degradRedPct ?>%</div>
            <div class="hse-metric-lbl">Degradacja stanu</div>
        </div>
        <?php if ($uptimePct > 0): ?>
        <div class="hse-metric hse-good">
            <div class="hse-metric-val">+<?= $uptimePct ?>%</div>
            <div class="hse-metric-lbl">Uptime odwiertu</div>
        </div>
        <?php endif ?>
    </div>
    <div class="hse-note">
        Ochrona oparta na <?= $hseBonus['active_hse'] ?> pracowniku/ach BHP.
        Metryki obliczane przy każdym ticku systemowym.
        <?php if ($hseBonus['audit_bonus']): ?>
            <strong>Aktywny efekt audytu bezpieczeństwa (72h).</strong>
        <?php endif ?>
    </div>
    <?php else: ?>
    <div class="hse-warning-block">
        <p class="hse-warn-title">⚠️ Brak aktywnego personelu BHP</p>
        <p>Twoje odwierty pracują bez żadnej ochrony bezpieczeństwa.</p>
        <ul class="hse-risk-list">
            <li>🔴 Pełna szansa awarii — stan techniczny spada szybciej</li>
            <li>🔴 Brak redukcji kosztów napraw — awarie w pełni kosztowne</li>
            <li>🔴 Ryzyko blowout przy stanie &lt;30% — katastrofalne straty</li>
        </ul>
        <p class="hse-fix-hint">→ Zatrudnij <strong>Oficera BHP</strong> lub <strong>Inżyniera BHP</strong> z zakładki Kandydaci.</p>
    </div>
    <?php endif ?>
</div>

<?php
// ── Panel procedur BHP ──────────────────────────────────
$pLevel     = $procStatus['level'];
$pIntegrity = $procStatus['integrity'];
$pFactor    = $hseBonus['proc_factor'];

// Klasa CSS na podstawie stanu integralności
$integrityCls = $pIntegrity > 60 ? 'proc-integrity--ok'
              : ($pIntegrity > 30  ? 'proc-integrity--warn'
              :                      'proc-integrity--crit');

// Status tekstowy
$integrityStatus = $pIntegrity > 60 ? '🟢 Stabilne'
                 : ($pIntegrity > 30  ? '🟡 Zużycie — wykonaj przegląd'
                 :                      '🔴 Krytyczne — procedury niemal nieaktywne');

// Koszt kolejnego upgrade
$nextLevel  = $pLevel + 1;
$upgradeCost = TechnicalTeamService::PROCEDURE_UPGRADE_COSTS[$nextLevel] ?? null;
$repairCost  = $pLevel > 0 ? 500_000 * $pLevel : 0;

// Sprawdź warunki upgrade procedur
$auditDone   = false;
$hasHseStaff = ['officer' => false, 'engineer' => false];
try {
    // Warunek 1: audyt wykonany
    $auditCheckStmt = $db->prepare("
        SELECT id FROM technical_tasks
        WHERE player_id = ? AND task_type = 'safety_audit' AND status = 'completed'
        LIMIT 1
    ");
    $auditCheckStmt->execute([$playerId]);
    $auditDone = (bool)$auditCheckStmt->fetch();

    // Warunek 2: aktywny Oficer BHP i Inżynier BHP
    $hseStaffStmt = $db->prepare("
        SELECT spec_code FROM technical_staff
        WHERE player_id = ?
          AND spec_code IN ('safety_officer','safety_engineer')
          AND status IN ('active','busy')
          AND (fired_at IS NULL OR fired_at > NOW())
    ");
    $hseStaffStmt->execute([$playerId]);
    foreach ($hseStaffStmt->fetchAll() as $hs) {
        if ($hs['spec_code'] === 'safety_officer')  $hasHseStaff['officer']  = true;
        if ($hs['spec_code'] === 'safety_engineer') $hasHseStaff['engineer'] = true;
    }
} catch (Throwable $e) {
    GameLog::error('technical.php', 'auditCheck/hseStaff FAIL', $e);
}

$canUpgradeProcedures = $auditDone && $hasHseStaff['officer'] && $hasHseStaff['engineer'];
?>
<div class="proc-panel">
    <div class="proc-panel-hdr">
        <span class="proc-icon">📋</span>
        <span class="proc-title">PROCEDURY BHP</span>
        <span class="proc-level-badge">Poziom <?= $pLevel ?>/5</span>
        <?php if ($pLevel > 0): ?>
            <span class="proc-status-badge <?= $integrityCls ?>"><?= $integrityStatus ?></span>
        <?php endif ?>
    </div>

    <?php if ($pLevel > 0): ?>
    <div class="proc-body">

        <?php /* Pasek integralności */ ?>
        <div class="proc-integrity-row">
            <span class="proc-integrity-lbl">Integralność systemu</span>
            <div class="proc-bar-wrap">
                <div class="proc-bar-fill <?= $integrityCls ?>" style="width:<?= $pIntegrity ?>%"></div>
            </div>
            <span class="proc-integrity-val <?= $integrityCls ?>"><?= number_format($pIntegrity, 1) ?>%</span>
        </div>

        <?php /* Metryki efektów */ ?>
        <?php if ($pFactor > 0): ?>
        <div class="proc-metrics">
            <?php
            $pFailPct  = (int)round((1 - (1.0 - 0.20 * $pFactor)) * 100);
            $pCatPct   = (int)round((1 - (1.0 - 0.40 * $pFactor)) * 100);
            $pDegPct   = (int)round((1 - (1.0 - 0.25 * $pFactor)) * 100);
            $pRepPct   = (int)round((1 - (1.0 - 0.10 * $pFactor)) * 100);
            ?>
            <div class="proc-metric"><div class="proc-metric-val">-<?= $pFailPct ?>%</div><div class="proc-metric-lbl">Szansa awarii</div></div>
            <div class="proc-metric"><div class="proc-metric-val">-<?= $pCatPct ?>%</div><div class="proc-metric-lbl">Ryzyko katastrofy</div></div>
            <div class="proc-metric"><div class="proc-metric-val">-<?= $pDegPct ?>%</div><div class="proc-metric-lbl">Degradacja stanu</div></div>
            <div class="proc-metric"><div class="proc-metric-val">-<?= $pRepPct ?>%</div><div class="proc-metric-lbl">Koszt napraw</div></div>
        </div>
        <?php else: ?>
        <div class="proc-integrity-zero">⚠️ Integralność = 0% — procedury są wdrożone, ale nieaktywne. Wykonaj przegląd BHP.</div>
        <?php endif ?>

        <?php /* Przycisk przeglądu */ ?>
        <?php if ($pIntegrity < 100): ?>
        <form method="post" class="proc-action-form">
            <input type="hidden" name="_token" value="<?= htmlspecialchars($csrf) ?>">
            <input type="hidden" name="action" value="repair_procedure_integrity">
            <button type="submit" class="btn-proc-repair">
                🔍 Wykonaj przegląd BHP (+30% integralności) — koszt: $<?= number_format($repairCost, 0, '.', ' ') ?>
            </button>
        </form>
        <?php endif ?>

    </div>
    <?php else: ?>
    <div class="proc-empty">
        <p>Brak wdrożonych procedur BHP. Procedury stanowią trzecią warstwę ochrony — działają nawet bez aktywnego inżyniera.</p>
        <ul class="proc-benefit-list">
            <li>📉 Poziom 1: -4% awarii, -8% katastrof, -5% degradacji</li>
            <li>📉 Poziom 3: -12% awarii, -24% katastrof, -15% degradacji</li>
            <li>📉 Poziom 5: -20% awarii, -40% katastrof, -25% degradacji</li>
        </ul>
        <p class="proc-note">Procedury <strong>degradują się z czasem</strong> (-2%/h bez inżyniera, -0,5%/h z inżynierem). Wymagają regularnych przeglądów.</p>
    </div>
    <?php endif ?>

    <?php /* Upgrade do następnego poziomu */ ?>
    <?php if ($pLevel < 5): ?>
    <div class="proc-upgrade-section">
        <div class="proc-upgrade-hdr">Wdróż procedury poziomu <?= $nextLevel ?>/5</div>
        <?php if (!$canUpgradeProcedures): ?>
            <div class="proc-upgrade-blocked">
                <?php if (!$hasHseStaff['officer'] || !$hasHseStaff['engineer']): ?>
                    🔒 Wymagany aktywny personel BHP:
                    <ul class="tech-missing-list">
                        <?php if (!$hasHseStaff['officer']): ?><li>Brak <strong>Oficera BHP</strong></li><?php endif ?>
                        <?php if (!$hasHseStaff['engineer']): ?><li>Brak <strong>Inżyniera BHP</strong></li><?php endif ?>
                    </ul>
                    <div class="tech-hire-hint">→ Zatrudnij w zakładce <a href="?tab=candidates" class="tech-gold-link">Kandydaci</a>.</div>
                <?php elseif (!$auditDone): ?>
                    🔒 Wymagany ukończony audyt bezpieczeństwa. Zlec zadanie <strong>„Audyt bezpieczeństwa"</strong> Inżynierowi BHP lub Oficerowi BHP.
                <?php endif ?>
            </div>
        <?php else: ?>
            <div class="proc-upgrade-info">
                Koszt: <strong>$<?= number_format($upgradeCost, 0, '.', ' ') ?></strong>
                · Integralność po wdrożeniu zostanie przywrócona do 100%.
            </div>
            <form method="post" class="proc-action-form">
                <input type="hidden" name="_token" value="<?= htmlspecialchars($csrf) ?>">
                <input type="hidden" name="action" value="upgrade_procedures">
                <button type="submit" class="btn-proc-upgrade">
                    ⬆️ Wdróż procedury poziomu <?= $nextLevel ?> — $<?= number_format($upgradeCost, 0, '.', ' ') ?>
                </button>
            </form>
        <?php endif ?>
    </div>
    <?php endif ?>

</div>

<?php
// Pogrupuj brokenWells po typie problemu
$wellsByStatus = [];
foreach ($brokenWells as $w) {
    $wellsByStatus[$w['status']][] = $w;
}

$statusInfo = [
    'paused_staff'   => ['icon' => '⏸', 'title' => 'Brak wymaganego personelu',      'cls' => 'hse-panel--inactive', 'badge_cls' => 'hse-badge--off', 'badge' => 'BRAK PERSONELU'],
    'paused_cash'    => ['icon' => '💸', 'title' => 'Brak środków na OPEX',           'cls' => 'hse-panel--inactive', 'badge_cls' => 'hse-badge--off', 'badge' => 'BRAK ŚRODKÓW'],
    'broken'         => ['icon' => '🔴', 'title' => 'Awaria techniczna',              'cls' => 'hse-panel--inactive', 'badge_cls' => 'hse-badge--off', 'badge' => 'AWARIA'],
    'blowout'        => ['icon' => '🚨', 'title' => 'Niekontrolowany wypływ (Blowout)', 'cls' => 'hse-panel--inactive', 'badge_cls' => 'hse-badge--off', 'badge' => 'KATASTROFA'],
    'contaminated'   => ['icon' => '☣️', 'title' => 'Skażenie złoża',                'cls' => 'hse-panel--inactive', 'badge_cls' => 'hse-badge--off', 'badge' => 'SKAŻENIE'],
];

$actionHint = [
    'paused_staff'   => 'Zatrudnij brakujących specjalistów w zakładce <a href="?tab=candidates" class="link-gold">Kandydaci</a>.',
    'paused_cash'    => 'Sprzedaj ropę lub zdobądź finansowanie. Odwiert wznowi się automatycznie.',
    'broken'         => 'Zlec zadanie <strong>Naprawa awarii</strong> Inżynierowi Utrzymania Ruchu.',
    'blowout'        => 'Zlec zadanie <strong>Opanowanie wypływu</strong> Inżynierowi Wiercenia lub Inżynierowi Utrzymania Ruchu.',
    'contaminated'   => 'Zlec zadanie <strong>Rehabilitacja złoża</strong> Inżynierowi Złoża.',
];
?>

<?php if (!empty($brokenWells)): ?>
<?php foreach ($statusInfo as $stCode => $stMeta): ?>
<?php if (!empty($wellsByStatus[$stCode])): ?>
<div class="hse-panel <?= $stMeta['cls'] ?>" class="tech-mb">
    <div class="hse-panel-hdr">
        <span class="hse-icon"><?= $stMeta['icon'] ?></span>
        <span class="hse-title"><?= $stMeta['title'] ?></span>
        <span class="hse-status-badge <?= $stMeta['badge_cls'] ?>"><?= $stMeta['badge'] ?></span>
    </div>
    <div class="hse-warning-block">
        <ul class="hse-risk-list">
        <?php foreach ($wellsByStatus[$stCode] as $w):
            $cond = round((float)$w['technical_condition'], 1);
            $condCls = $cond >= 70 ? 'c-good' : ($cond >= 40 ? 'c-warn' : 'c-bad');
        ?>
            <li>
                <span class="fw7">Odwiert #<?= $w['id'] ?></span>
                <span class="c-muted fs12"> · <?= htmlspecialchars($w['location_name'] ?? '') ?></span>
                <span class="<?= $condCls ?> fw7"> · Stan: <?= $cond ?>%</span>
                <?php if ($stCode === 'paused_staff' && !empty($w['paused_staff_reason'])): ?>
                <br><span class="c-muted fs12" class="tech-ml">Brakuje: <?= htmlspecialchars(implode(', ', array_map(fn($c) => [
                    'safety_officer'=>'Oficer BHP','safety_engineer'=>'Inżynier BHP',
                    'maintenance_engineer'=>'Inżynier Utrzymania Ruchu','production_engineer'=>'Inżynier Produkcji'
                ][$c] ?? $c, explode(',', $w['paused_staff_reason'])))) ?></span>
                <?php endif ?>
            </li>
        <?php endforeach ?>
        </ul>
        <p class="hse-fix-hint">→ <?= $actionHint[$stCode] ?? '' ?></p>
    </div>
</div>
<?php endif ?>
<?php endforeach ?>
<?php endif ?>

<?php
$riskWells = array_filter($wells, fn($w) => $w['status'] === 'active' && $w['technical_condition'] < 60);
if (!empty($riskWells)):
?>
<div class="hse-panel" class="hse-panel hse-panel--warn">
    <div class="hse-panel-hdr">
        <span class="hse-icon">⚠️</span>
        <span class="hse-title">Ryzyko awarii — stan poniżej 60%</span>
        <span class="hse-status-badge" class="hse-badge hse-badge--warn">UWAGA</span>
    </div>
    <div class="hse-warning-block">
        <ul class="hse-risk-list">
        <?php foreach ($riskWells as $w):
            $cond = (float)$w['technical_condition'];
            $risk = round(max(0, (70 - $cond) * 0.5), 1);
        ?>
            <li>
                <span class="fw7 c-warn">Odwiert #<?= $w['id'] ?></span>
                <span class="c-muted fs12"> · <?= htmlspecialchars($w['location_name'] ?? '') ?></span>
                <span class="c-warn fw7"> · Stan: <?= round($cond, 1) ?>%</span>
                <span class="c-bad fs12"> · Ryzyko awarii: <?= $risk ?>%/h</span>
            </li>
        <?php endforeach ?>
        </ul>
        <p class="hse-fix-hint">→ Zlec zadanie <strong>Konserwacja odwiertu</strong> Inżynierowi Wiercenia lub Inżynierowi Utrzymania Ruchu.</p>
    </div>
</div>
<?php endif ?>

<?php if (empty($brokenWells) && empty($riskWells)): ?>
<div class="hse-panel" class="hse-panel hse-panel--ok">
    <div class="hse-panel-hdr">
        <span class="hse-icon">🟢</span>
        <span class="hse-title">Stan techniczny odwiertów</span>
        <span class="hse-status-badge hse-badge--on">SPRAWNE</span>
    </div>
    <div class="hse-note">✓ Brak zagrożeń technicznych — wszystkie odwierty w dobrym stanie.</div>
</div>
<?php endif ?>

<?php
// ── Aktywne katastrofy przemysłowe ────────────────────────
$activeDisasters = [];
try {
    $dsStmt = $db->prepare("
        SELECT d.*, w.location_name AS well_name
        FROM industrial_disasters d
        LEFT JOIN wells w ON w.id = d.well_id
        WHERE d.player_id = ? AND d.status IN ('active','being_repaired')
        ORDER BY d.occurred_at DESC
    ");
    $dsStmt->execute([$playerId]);
    $activeDisasters = $dsStmt->fetchAll();
} catch (Throwable $e) {
    GameLog::error('technical.php', 'activeDisasters query FAILED', $e);
}

$disasterLabels = [
    'blowout'                 => ['icon' => '🚨', 'label' => 'Niekontrolowany wypływ (Blowout)',  'cls' => 'disaster-type-blowout'],
    'pipeline_explosion'      => ['icon' => '💥', 'label' => 'Eksplozja rurociągu',               'cls' => 'disaster-type-pipeline'],
    'reservoir_contamination' => ['icon' => '☣️', 'label' => 'Skażenie złoża',                   'cls' => 'disaster-type-contamination'],
    'surface_spill'           => ['icon' => '🛢️', 'label' => 'Wyciek powierzchniowy',             'cls' => 'disaster-type-spill'],
];

$repairTaskHint = [
    'blowout'                 => 'Zlec zadanie <strong>Opanowanie wypływu</strong> — Inżynier Wiercenia lub Inżynier Utrzymania Ruchu. Czas: 72–120h.',
    'pipeline_explosion'      => 'Zlec zadanie <strong>Naprawa rurociągu</strong> — Inżynier Rurociągów. Czas: 24–48h.',
    'reservoir_contamination' => 'Zlec zadanie <strong>Rehabilitacja złoża</strong> — Inżynier Złoża. Czas: 72–120h.',
    'surface_spill'           => 'Zdarzenie jednorazowe — brak wymaganej naprawy. Sprawdź poziom magazynu.',
];
?>

<?php if (!empty($activeDisasters)): ?>
<div class="section-h">⚠️ Aktywne katastrofy przemysłowe (<?= count($activeDisasters) ?>)</div>
<?php foreach ($activeDisasters as $d):
    $dInfo = $disasterLabels[$d['disaster_type']] ?? ['icon' => '⚠️', 'label' => $d['disaster_type'], 'cls' => ''];
    $hint  = $repairTaskHint[$d['disaster_type']] ?? '';
?>
<div class="disaster-panel">
    <div class="disaster-panel-hdr">
        <span class="disaster-icon"><?= $dInfo['icon'] ?></span>
        <span class="disaster-title <?= $dInfo['cls'] ?>"><?= $dInfo['label'] ?></span>
        <span class="disaster-badge"><?= $d['status'] === 'being_repaired' ? 'W NAPRAWIE' : 'AKTYWNA' ?></span>
    </div>
    <p class="disaster-desc"><?= htmlspecialchars($d['description'] ?? '') ?></p>
    <div class="disaster-stats">
        <?php if ($d['repair_cost'] > 0): ?>
        <div class="disaster-stat">
            <div class="disaster-stat-val cost"><?= number_format($d['repair_cost'], 0, ',', ' ') ?> PLN</div>
            <div class="disaster-stat-lbl">Koszt akcji ratunkowej</div>
        </div>
        <?php endif ?>
        <?php if ($d['env_fine'] > 0): ?>
        <div class="disaster-stat">
            <div class="disaster-stat-val fine"><?= number_format($d['env_fine'], 0, ',', ' ') ?> PLN</div>
            <div class="disaster-stat-lbl">Kara środowiskowa</div>
        </div>
        <?php endif ?>
        <?php if ($d['reservoir_lost'] > 0): ?>
        <div class="disaster-stat">
            <div class="disaster-stat-val loss"><?= number_format($d['reservoir_lost'], 0, ',', ' ') ?> bbl</div>
            <div class="disaster-stat-lbl">Utracone złoże</div>
        </div>
        <?php endif ?>
        <?php if ($d['oil_lost'] > 0): ?>
        <div class="disaster-stat">
            <div class="disaster-stat-val loss"><?= number_format($d['oil_lost'], 0, ',', ' ') ?> bbl</div>
            <div class="disaster-stat-lbl">Utracona ropa</div>
        </div>
        <?php endif ?>
        <div class="disaster-stat">
            <div class="disaster-stat-val" class="wg-disaster-date"><?= date('d.m H:i', strtotime($d['occurred_at'])) ?></div>
            <div class="disaster-stat-lbl">Data zdarzenia</div>
        </div>
    </div>
    <?php if ($hint): ?>
    <div class="disaster-action-hint">🔧 <?= $hint ?></div>
    <?php endif ?>
    <?php if ($d['hse_active']): ?>
    <div class="disaster-hse-note">✓ BHP było aktywne — skutki zostały częściowo ograniczone.</div>
    <?php endif ?>
</div>
<?php endforeach ?>
<?php endif ?>

<?php
// ── Historia awarii (rozszerzona o katastrofy) ─────────────
$failures = [];
try {
    $failStmt = $db->prepare("
        SELECT fl.*, w.location_name
        FROM failure_log fl
        LEFT JOIN wells w ON fl.well_id = w.id
        WHERE fl.player_id = ?
        ORDER BY fl.occurred_at DESC
        LIMIT 20
    ");
    $failStmt->execute([$playerId]);
    $failures = $failStmt->fetchAll();
} catch (Throwable $e) {
    GameLog::error('technical.php', 'failure_log query FAILED', $e);
}
?>
<?php if (!empty($failures)): ?>
<div class="section-h">Historia awarii i katastrof</div>
<div class="disaster-history-hdr">
    <span></span>
    <span>Zdarzenie</span>
    <span>Koszt naprawy</span>
    <span>Kara środow.</span>
    <span>Data</span>
    <span>Status</span>
</div>
<?php
$fTypes = [
    'pump'                    => ['icon' => '🔧', 'label' => 'Awaria pompy',             'cls' => ''],
    'pipeline'                => ['icon' => '🔩', 'label' => 'Uszkodzenie rurociągu',    'cls' => ''],
    'electrical'              => ['icon' => '⚡', 'label' => 'Awaria elektryczna',       'cls' => ''],
    'pressure_drop'           => ['icon' => '📉', 'label' => 'Spadek ciśnienia',         'cls' => ''],
    'blowout'                 => ['icon' => '🚨', 'label' => 'Niekontrolowany wypływ',   'cls' => 'disaster-type-blowout'],
    'pipeline_explosion'      => ['icon' => '💥', 'label' => 'Eksplozja rurociągu',      'cls' => 'disaster-type-pipeline'],
    'reservoir_contamination' => ['icon' => '☣️', 'label' => 'Skażenie złoża',          'cls' => 'disaster-type-contamination'],
    'surface_spill'           => ['icon' => '🛢️', 'label' => 'Wyciek powierzchniowy',   'cls' => 'disaster-type-spill'],
];
foreach ($failures as $f):
    $ft = $fTypes[$f['failure_type']] ?? ['icon' => '?', 'label' => $f['failure_type'], 'cls' => ''];
?>
<div class="disaster-history-row">
    <span class="tech-icon-lg"><?= $ft['icon'] ?></span>
    <span>
        <span class="<?= $ft['cls'] ?>"><?= $ft['label'] ?></span>
        <?php if ($f['well_id'] > 0): ?>
            <small class="c-muted2"> · #<?= $f['well_id'] ?> <?= htmlspecialchars($f['location_name'] ?? '') ?></small>
        <?php endif ?>
    </span>
    <span class="<?= $f['repair_cost'] > 0 ? 'c-bad' : 'c-muted' ?>">
        <?= $f['repair_cost'] > 0 ? number_format($f['repair_cost'], 0, ',', ' ') . ' PLN' : '—' ?>
    </span>
    <span class="<?= ($f['environmental_fine'] ?? 0) > 0 ? 'c-warn' : 'c-muted' ?>">
        <?= ($f['environmental_fine'] ?? 0) > 0 ? number_format($f['environmental_fine'], 0, ',', ' ') . ' PLN' : '—' ?>
    </span>
    <span class="c-muted2 sm"><?= date('d.m H:i', strtotime($f['occurred_at'])) ?></span>
    <span>
        <span class="badge <?= $f['resolved'] ? 'b-active' : 'b-broken' ?>">
            <?= $f['resolved'] ? 'Naprawione' : 'Aktywna' ?>
        </span>
    </span>
</div>
<?php endforeach ?>
<?php endif ?>

<?php if (empty($activeDisasters) && empty($failures) && empty($brokenWells)): ?>
<div class="safety-ok" class="tech-mt">✓ Brak historii awarii ani katastrof. Dobra robota.</div>
<?php endif ?>

<?php endif ?><!-- end safety tab -->

<!-- ══════════════════════════════════════
     ZAKŁADKA: INCYDENTY
══════════════════════════════════════ -->
<?php if ($activeTab === 'incidents'): ?>

<div class="g-card">
    <div class="g-card-title">Dziennik incydentów (ostatnie 50)</div>

    <?php if (empty($incidents)): ?>
    <div class="empty-state">Brak zarejestrowanych incydentów. Pojawią się tutaj po kolejnym tiku gry.</div>
    <?php else: ?>
    <div class="inc-list">
    <?php foreach ($incidents as $inc):
        $lvl     = $inc['level'];
        $cause   = $inc['cause_type'];
        $lvlIcon = match($lvl) { 'micro'=>'🟢','minor'=>'🟡','medium'=>'🟠','major'=>'🔴', default=>'⚪' };
        $lvlCls  = match($lvl) { 'micro'=>'inc-micro','minor'=>'inc-minor','medium'=>'inc-medium','major'=>'inc-major', default=>'' };
        $causeIcon = match($cause) { 'operator'=>'👷','technician'=>'🔧','hse'=>'🦺','system'=>'⚙', default=>'❓' };
    ?>
    <div class="inc-row <?= $lvlCls ?>">
        <div class="inc-icon"><?= $lvlIcon ?></div>
        <div class="inc-body">
            <div class="inc-msg"><?= htmlspecialchars($inc['message']) ?></div>
            <div class="inc-meta">
                <span><?= $causeIcon ?> <?= ucfirst($cause) ?></span>
                <span class="sep">·</span>
                <span>Odwiert #<?= $inc['well_id'] ?><?= $inc['well_name'] ? ' — '.htmlspecialchars($inc['well_name']) : '' ?></span>
                <span class="sep">·</span>
                <span class="<?= $inc['prod_drop'] >= 40 ? 'c-bad' : ($inc['prod_drop'] >= 10 ? 'c-warn' : 'c-muted2') ?>">
                    −<?= $inc['prod_drop'] ?>% produkcji
                </span>
                <?php if ($inc['cost'] > 0): ?>
                <span class="sep">·</span>
                <span class="c-gold">Koszt: $<?= number_format($inc['cost'], 0, '.', ' ') ?></span>
                <?php endif ?>
                <?php if ($inc['deg_damage'] > 0): ?>
                <span class="sep">·</span>
                <span class="c-bad">Stan −<?= $inc['deg_damage'] ?>pkt</span>
                <?php endif ?>
                <span class="sep">·</span>
                <span class="c-muted2"><?= $inc['auto_repair'] ? 'Auto-naprawa' : 'Wymaga technika' ?></span>
                <span class="sep">·</span>
                <span class="c-muted2"><?= date('d.m H:i', strtotime($inc['created_at'])) ?></span>
            </div>
        </div>
        <div class="inc-badge"><?= strtoupper($lvl) ?></div>
    </div>
    <?php endforeach ?>
    </div>
    <?php endif ?>
</div>

<?php endif ?>

<!-- ══════════════════════════════════════
     ZAKŁADKA: RAPORT
══════════════════════════════════════ -->
<?php if ($activeTab === 'report'): ?>

<div class="prod-grid">
    <div class="prod-stat"><div class="prod-val"><?= count($wells) ?></div><div class="prod-unit">Odwiertów</div></div>
    <div class="prod-stat"><div class="prod-val c-green"><?= count($activeWells) ?></div><div class="prod-unit">Aktywnych</div></div>
    <div class="prod-stat"><div class="prod-val <?= $avgCond >= 70 ? 'c-green' : 'c-warn' ?>"><?= $avgCond ?>%</div><div class="prod-unit">Śr. stan tech.</div></div>
    <div class="prod-stat"><div class="prod-val c-bad"><?= count($brokenWells) ?></div><div class="prod-unit">Awarii</div></div>
    <div class="prod-stat"><div class="prod-val c-gold"><?= count($staff) ?></div><div class="prod-unit">Inżynierów</div></div>
    <div class="prod-stat"><div class="prod-val c-blue"><?= count($activeTasks) ?></div><div class="prod-unit">Aktywnych zadań</div></div>
</div>

<div class="g-card">
    <div class="g-card-title">Stan odwiertów</div>
    <div class="data-list">
        <div class="data-list-head cols-wells">
            <span>#</span><span>Lokalizacja</span><span>Status</span><span>Produkcja</span><span>Stan</span><span>Ciśnienie</span><span>Złoże</span>
        </div>
        <?php foreach ($wells as $w):
            $cond    = (float)$w['technical_condition'];
            $condCol = $cond >= 70 ? 'c-good' : ($cond >= 40 ? 'c-warn' : 'c-bad');
            $resPct  = (float)($w['reservoir_max'] ?? 800000) > 0 ? round((float)$w['reservoir_remaining'] / (float)$w['reservoir_max'] * 100, 1) : 0;
            $sLbl    = match($w['status']) { 'active'=>'Aktywny','broken','paused_cash'=>'Awaria',default=>ucfirst($w['status']) };
            $sCls    = match($w['status']) { 'active'=>'b-active','broken','paused_cash'=>'b-broken',default=>'b-paused' };
        ?>
        <div class="data-list-row cols-wells">
            <span class="dlc sm">#<?= $w['id'] ?></span>
            <span class="dlc"><?= htmlspecialchars($w['location_name'] ?? 'Pole') ?></span>
            <span class="dlc"><span class="badge <?= $sCls ?>"><?= $sLbl ?></span></span>
            <span class="dlc c-gold fw7"><?= number_format($w['base_production_per_hour'], 1) ?> bbl/h</span>
            <span class="dlc <?= $condCol ?> fw7"><?= round($cond, 1) ?>%</span>
            <span class="dlc"><?= number_format((float)($w['pressure'] ?? 1.0), 3) ?></span>
            <span class="dlc <?= $resPct < 20 ? 'c-bad' : 'c-muted2' ?>"><?= $resPct ?>%</span>
        </div>
        <?php endforeach ?>
    </div>
</div>

<div class="g-card">
    <div class="g-card-title">Zespół techniczny</div>
    <div class="data-list">
        <div class="data-list-head cols-staff">
            <span>Imię i nazwisko</span><span>Specjalizacja</span><span>Skill</span><span>Status</span><span>Pensja</span>
        </div>
        <?php foreach ($staff as $s): ?>
        <div class="data-list-row cols-staff">
            <span class="dlc fw6"><?= htmlspecialchars($s['first_name'].' '.$s['last_name']) ?></span>
            <span class="dlc"><?= htmlspecialchars($s['spec_name']) ?></span>
            <span class="dlc c-gold fw7"><?= $s['skill_level'] ?>/10</span>
            <span class="dlc"><span class="badge <?= $s['status'] === 'active' ? 'b-active' : 'b-busy' ?>"><?= $s['status'] === 'active' ? 'Dostępny' : 'Zajęty' ?></span></span>
            <span class="dlc sm">$<?= number_format($s['salary'], 0, '.', ' ') ?></span>
        </div>
        <?php endforeach ?>
    </div>
</div>

<?php endif ?>

</div><!-- .t-wrap -->

<script src="/assets/js/technical.js"></script>
<?php GameLog::pageEnd('technical.php', $_pageStart); ?>
