<?php else: ?>
<div class="wells-grid">
<?php foreach ($wells as $w):
    $wId       = (int)$w['id'];
    $cond      = (float)$w['technical_condition'];
    $condFill  = $cond >= 70 ? 'cond-good' : ($cond >= 40 ? 'cond-warn' : 'cond-bad');
    $condCol   = $cond >= 70 ? 'c-good'    : ($cond >= 40 ? 'c-warn'    : 'c-bad');
    $pressure  = (float)($w['pressure'] ?? 1.0);
    $reservoir = (float)($w['reservoir_remaining'] ?? 0);
    $resMax    = (float)($w['reservoir_max'] ?? 800000);
    $resPct    = $resMax > 0 ? round($reservoir / $resMax * 100, 1) : 0;
    $riskScore = (float)($w['risk_score'] ?? 0);
    $status    = $w['status'] ?? 'active';
    $stInfo    = $statusLabels[$status] ?? ['lbl' => $status, 'cls' => 'b-paused', 'icon' => '⏸'];
    $isActive  = $status === 'active';
    $isPaused  = str_starts_with($status, 'paused') || in_array($status, ['broken','seized','blowout','contaminated']);
    $wellTasks = $tasksByWell[$wId] ?? [];

    // Efektywna produkcja uwzględniająca pressure i boost
    $boostPct  = (float)($w['production_boost_pct'] ?? 0);
    $effProd   = (float)$w['base_production_per_hour'] * $pressure * (1 + $boostPct / 100);
    $effProd   = round($effProd, 1);

    // Brakujące spec dla paused_staff
    $missingSpecs = [];
    if ($status === 'paused_staff' && !empty($w['paused_staff_reason'])) {
        foreach (explode(',', $w['paused_staff_reason']) as $code) {
            $code = trim($code);
            if ($code) $missingSpecs[] = $specLabels[$code] ?? $code;
        }
    }

    // Risk color
    $riskCls = $riskScore >= 60 ? 'c-bad' : ($riskScore >= 30 ? 'c-warn' : 'c-good');
?>
<details class="well-card <?= $isPaused ? 'well-card--paused' : '' ?> <?= $status === 'paused_staff' ? 'well-card--staff' : '' ?>">
    <summary class="well-card-summary">

        <!-- Nagłówek -->
        <div class="well-card-hdr">
            <div class="well-card-title">
                <span class="well-num">Odwiert #<?= $wId ?> · <?= strtoupper($w['well_type'] ?? 'onshore') ?></span>
                <span class="well-name"><?= htmlspecialchars($w['location_name'] ?? 'Pole naftowe') ?></span>
            </div>
            <div class="well-card-badges">
                <span class="badge <?= $stInfo['cls'] ?>"><?= $stInfo['icon'] ?> <?= $stInfo['lbl'] ?></span>
                <?php if (!empty($wellTasks)): ?>
                <span class="badge b-busy">⚙ <?= count($wellTasks) ?> zadanie</span>
                <?php endif ?>
            </div>
        </div>

        <!-- Statystyki (zawsze widoczne) -->
        <div class="well-stats">
            <div>
                <div class="w-stat-lbl">Produkcja</div>
                <div class="w-stat-val <?= $isActive ? 'c-gold' : 'c-muted' ?>">
                    <?= $isActive ? $effProd : '—' ?> <?= $isActive ? 'bbl/h' : '' ?>
                </div>
            </div>
            <div>
                <div class="w-stat-lbl">Ciśnienie</div>
                <div class="w-stat-val <?= $pressure < 0.7 ? 'c-bad' : ($pressure < 0.85 ? 'c-warn' : 'c-good') ?>">
                    <?= number_format($pressure, 2) ?>
                </div>
            </div>
            <div>
                <div class="w-stat-lbl">Złoże</div>
                <div class="w-stat-val <?= $resPct < 20 ? 'c-bad' : 'c-good' ?>">
                    <?= number_format($reservoir, 0, '.', ' ') ?> bbl
                </div>
            </div>
            <div>
                <div class="w-stat-lbl">Głębokość</div>
                <div class="w-stat-val c-muted"><?= number_format($w['depth_m'] ?? 2500, 0, '.', ' ') ?> m</div>
            </div>
        </div>

        <!-- Pasek stanu technicznego -->
        <div class="well-cond-wrap">
            <div class="well-cond-row">
                <span class="<?= $condCol ?>">Stan techniczny</span>
                <span class="<?= $condCol ?> fw7"><?= round($cond, 1) ?>%</span>
            </div>
            <div class="cond-bar"><div class="cond-fill <?= $condFill ?>" style="--bar-w:<?= $cond ?>%"></div></div>
        </div>

        <div class="well-expand-hint">▼ szczegóły</div>
    </summary>

    <!-- ── ROZWINIĘTE SZCZEGÓŁY ── -->
    <div class="well-detail">

        <?php if ($status === 'paused_staff'): ?>
        <!-- Diagnoza: brak personelu -->
        <div class="well-diag well-diag--staff">
            <div class="well-diag-title">⏸ Odwiert wstrzymany — brak wymaganego personelu</div>
            <div class="well-diag-body">
                <p class="well-diag-note">Aby odwiert mógł pracować, potrzebujesz jednocześnie:</p>
                <ul class="well-missing-list">
                    <?php foreach ($missingSpecs as $ms): ?>
                    <li class="well-missing-item">🔴 <?= htmlspecialchars($ms) ?></li>
                    <?php endforeach ?>
                </ul>
                <p class="well-diag-note">Odwiert wznowi się <strong>automatycznie</strong> po zatrudnieniu wszystkich brakujących specjalistów.</p>
            </div>
            <a href="?tab=candidates" class="btn btn-primary btn-sm well-diag-btn">Przejdź do Kandydatów →</a>
        </div>

        <?php elseif ($status === 'paused_cash'): ?>
        <!-- Diagnoza: brak kasy -->
        <div class="well-diag well-diag--cash">
            <div class="well-diag-title">💸 Odwiert wstrzymany — brak środków na OPEX</div>
            <div class="well-diag-body">
                <p class="well-diag-note">Koszt operacyjny odwiertu przekroczył dostępne środki. Odwiert wznowi się automatycznie gdy konto będzie zasilone.</p>
                <p class="well-diag-note">OPEX: <strong>$<?= number_format((float)($w['upkeep_cost_per_hour'] ?? 0), 2, '.', ' ') ?>/h</strong></p>
            </div>
            <a href="<?= url('market') ?>" class="btn btn-primary btn-sm well-diag-btn">Sprzedaj ropę →</a>
        </div>

        <?php elseif ($status === 'paused_storage'): ?>
        <!-- Diagnoza: pełny magazyn -->
        <div class="well-diag well-diag--storage">
            <div class="well-diag-title">🏭 Odwiert wstrzymany — magazyn pełny</div>
            <div class="well-diag-body">
                <p class="well-diag-note">Brak miejsca w magazynie. Sprzedaj ropę lub rozbuduj pojemność magazynową.</p>
            </div>
            <a href="<?= url('market') ?>" class="btn btn-primary btn-sm well-diag-btn">Sprzedaj ropę →</a>
        </div>

        <?php elseif ($status === 'blowout'): ?>
        <!-- Diagnoza: blowout -->
        <div class="well-diag well-diag--disaster">
            <div class="well-diag-title">🚨 Niekontrolowany wypływ (Blowout)</div>
            <div class="well-diag-body">
                <p class="well-diag-note">Odwiert wymaga natychmiastowej interwencji. Zlec zadanie <strong>Opanowanie wypływu</strong> Inżynierowi Wiercenia lub Inżynierowi Utrzymania Ruchu.</p>
            </div>
            <a href="?tab=tasks" class="btn btn-primary btn-sm well-diag-btn">Zlec zadanie →</a>
        </div>

        <?php elseif ($status === 'contaminated'): ?>
        <!-- Diagnoza: skażenie złoża -->
        <div class="well-diag well-diag--disaster">
            <div class="well-diag-title">☣️ Skażenie złoża</div>
            <div class="well-diag-body">
                <p class="well-diag-note">Złoże jest skażone — produkcja obniżona. Zlec <strong>Rehabilitację złoża</strong> Inżynierowi Złoża.</p>
            </div>
            <a href="?tab=tasks" class="btn btn-primary btn-sm well-diag-btn">Zlec zadanie →</a>
        </div>

        <?php else: ?>
        <!-- Aktywny odwiert — szczegóły operacyjne -->
        <div class="well-detail-grid">
            <div class="well-detail-stat">
                <div class="well-detail-lbl">Ryzyko awarii</div>
                <div class="well-detail-val <?= $riskCls ?>"><?= number_format($riskScore, 1) ?> / 100</div>
            </div>
            <div class="well-detail-stat">
                <div class="well-detail-lbl">Poziom ryzyka</div>
                <div class="well-detail-val <?= ($w['risk_level'] ?? 10) > 15 ? 'c-bad' : 'c-good' ?>"><?= $w['risk_level'] ?? 10 ?></div>
            </div>
            <div class="well-detail-stat">
                <div class="well-detail-lbl">Tryb produkcji</div>
                <div class="well-detail-val"><?= match($w['production_mode'] ?? 'normal') {
                    'eco'   => '🔋 Eco (-20%)',
                    'boost' => '⚡ Boost (+20%)',
                    default => '⚙ Normalny',
                } ?></div>
            </div>
            <div class="well-detail-stat">
                <div class="well-detail-lbl">Rezerwa złoża</div>
                <div class="well-detail-val <?= $resPct < 20 ? 'c-bad' : ($resPct < 50 ? 'c-warn' : 'c-good') ?>">
                    <?= $resPct ?>%
                </div>
            </div>
            <?php if ($boostPct > 0): ?>
            <div class="well-detail-stat">
                <div class="well-detail-lbl">Bonus produkcji</div>
                <div class="well-detail-val c-green">+<?= number_format($boostPct, 1) ?>%</div>
            </div>
            <?php endif ?>
            <?php if ($pressure !== 1.0): ?>
            <div class="well-detail-stat">
                <div class="well-detail-lbl">Efekt ciśnienia</div>
                <div class="well-detail-val <?= $pressure >= 1.0 ? 'c-green' : 'c-warn' ?>">
                    <?= $pressure >= 1.0 ? '+' : '' ?><?= number_format(($pressure - 1.0) * 100, 1) ?>%
                </div>
            </div>
            <?php endif ?>
        </div>
        <?php endif ?>

        <!-- Aktywne zadania na tym odwiercie -->
        <?php if (!empty($wellTasks)): ?>
        <div class="well-tasks-list">
            <div class="well-tasks-hdr">Aktywne zadania</div>
            <?php foreach ($wellTasks as $t):
                $tEnd  = strtotime($t['end_time']);
                $tLeft = max(0, $tEnd - time());
                $tH    = floor($tLeft / 3600);
                $tM    = floor(($tLeft % 3600) / 60);
            ?>
            <div class="well-task-row">
                <span class="well-task-icon"><?= TechnicalTeamService::TASKS[$t['task_type']]['icon'] ?? '⚙' ?></span>
                <span class="well-task-name"><?= htmlspecialchars($t['title']) ?></span>
                <span class="well-task-who c-muted"><?= htmlspecialchars($t['first_name'] . ' ' . $t['last_name']) ?></span>
                <span class="well-task-time c-warn">
                    <?= $tH > 0 ? "{$tH}h " : '' ?><?= $tM ?>m
                </span>
            </div>
            <?php endforeach ?>
        </div>
        <?php endif ?>

    </div><!-- /.well-detail -->
</details>
<?php endforeach ?>
</div>
<?php endif ?>

<?php endif ?>

