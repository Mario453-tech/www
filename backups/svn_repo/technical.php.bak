<?php endif ?>

<!-- POWIADOMIENIA -->
<?php if (!empty($notifications)): ?>
<div class="notif-wrap" id="notif-panel">
    <div class="notif-hdr">⚠ Komunikaty Działu Technicznego (<?= count($notifications) ?>)</div>
    <?php foreach ($notifications as $n): ?>
    <div class="notif-row" id="notif-<?= $n['id'] ?>">
        <div>
            <div class="notif-msg"><?= htmlspecialchars($n['message']) ?></div>
            <div class="notif-time"><?= date('d.m.Y H:i', strtotime($n['created_at'])) ?></div>
        </div>
        <button class="notif-x" onclick="dismissNotif(<?= $n['id'] ?>)" title="Zatwierdź">✕</button>
    </div>
    <?php endforeach ?>
</div>
<?php endif ?>

<!-- TABS -->
<nav class="t-tabs">
<?php
$tabDefs = [
    'team'        => ['Zespół',          count($staff)],
    'well_staff'  => ['Personel Odwiertów', $wellsWithoutStaff],
    'candidates'  => ['Kandydaci',       $unreviewed],
    'tasks'       => ['Zadania',         count($activeTasks)],
    'wells'       => ['Odwierty',        count($wells)],
    'prod'        => ['Produkcja',       null],
    'infra'       => ['Infrastruktura',  null],
    'safety'      => ['Bezpieczeństwo',  count($brokenWells)],
    'incidents'    => ['Incydenty',       count($incidents)],
    'report'      => ['Raport',          null],
];
foreach ($tabDefs as $id => [$label, $cnt]):
    $isActive = $activeTab === $id;
?>
<a href="?tab=<?= $id ?>" class="t-tab <?= $isActive ? 'active' : '' ?>">
    <?= $label ?>
    <?php if ($cnt !== null && $cnt > 0): ?>
    <span class="tbadge <?= $id === 'team' ? 'tbadge-ok' : '' ?>"><?= $cnt ?></span>
    <?php endif ?>
</a>
<?php endforeach ?>
</nav>

<!-- ══════════════════════════════════════
     ZAKŁADKA: ZESPÓŁ
══════════════════════════════════════ -->
<?php if ($activeTab === 'team'): ?>

<?php if (!$manager): ?>
<div class="msg-bar msg-error">⚠ Brak Kierownika Technicznego. Zatrudnij pracownika w Dziale Kadr (rola: Dział Techniczny).</div>
<?php else: ?>

<div class="g-card">
    <div class="g-card-title">Kierownik Techniczny</div>
    <div class="mgr-card">
        <div class="mgr-avatar">👔</div>
        <div>
            <div class="mgr-name"><?= htmlspecialchars($manager['first_name'].' '.$manager['last_name']) ?></div>
            <div class="mgr-role">Kierownik Techniczny</div>
            <div class="mgr-stats">
                <div class="mgr-stat">Staż: <span><?= (int)($manager['days_employed'] ?? 0) ?> dni</span></div>
                <div class="mgr-stat">Doświadczenie: <span><?= $manager['experience_years'] ?> lat</span></div>
                <div class="mgr-stat">Pensja: <span class="c-gold">$<?= number_format($manager['salary'], 0, '.', ' ') ?>/mies.</span></div>
            </div>
        </div>
    </div>
    <?php if ($mBonus['skill'] > 0): ?>
    <div class="mgr-bonus"><?= htmlspecialchars($mBonus['label']) ?></div>
    <?php endif ?>
</div>

<?php endif ?>

<div class="g-card">
    <div class="g-card-title">Zespół Inżynierów (<?= count($staff) ?>)</div>

    <?php if (empty($staff)): ?>
    <div class="empty-state">Brak inżynierów. Zatrudnij specjalistów poniżej.</div>
    <?php else: ?>
    <div class="staff-grid">
    <?php foreach ($staff as $s):
        $specDef   = TechnicalTeamService::SPECS[$s['spec_code']] ?? ['icon'=>'?','name'=>$s['spec_name']];
        $isBusy    = $s['active_task_id'] !== null;
        $skillFill = (int)$s['skill_level'] * 10;
        $statusCls = $isBusy ? 'b-busy' : 'b-active';
        $statusLbl = $isBusy ? 'W trakcie' : 'Dostępny';

        $progress = 0;
        if ($isBusy && $s['active_task_end']) {
            $taskStmt = $db->prepare("SELECT start_time, end_time FROM technical_tasks WHERE id = ? LIMIT 1");
            $taskStmt->execute([$s['active_task_id']]);
            $taskRow = $taskStmt->fetch();
            if ($taskRow) {
                $total    = strtotime($taskRow['end_time']) - strtotime($taskRow['start_time']);
                $elapsed  = time() - strtotime($taskRow['start_time']);
                $progress = $total > 0 ? min(100, round($elapsed / $total * 100)) : 100;
            }
        }
    ?>
    <div class="staff-card <?= $isBusy ? 'busy' : '' ?>">
        <div class="staff-hdr">
            <div>
                <span class="staff-spec-icon"><?= $specDef['icon'] ?></span>
                <span class="staff-name"><?= htmlspecialchars($s['first_name'].' '.$s['last_name']) ?></span>
                <div class="staff-spec">
                    <?= htmlspecialchars($specDef['name']) ?>
                    <?php if (!empty($s['specialization']) && !empty($s['specialization_name'])): ?>
                    <span class="ts-perk-badge ts-perk--<?= htmlspecialchars($s['spec_rarity'] ?? 'uncommon') ?>"
                          title="Specjalizacja: <?= htmlspecialchars($s['specialization_name']) ?>">
                        ⭐ <?= htmlspecialchars($s['specialization_name']) ?>
                    </span>
                    <?php endif ?>
                </div>
            </div>
            <span class="badge <?= $statusCls ?>"><?= $statusLbl ?></span>
        </div>

        <div class="skill-bar-row">
            <div class="skill-bar-label">
                <span>Skill</span>
                <span class="c-gold fw7"><?= $s['skill_level'] ?>/10</span>
            </div>
            <div class="skill-bar"><div class="skill-fill" style="--bar-w:<?= $skillFill ?>%"></div></div>
        </div>

        <div class="staff-meta">
            <span><?= $s['experience_years'] ?> lat dośw.</span>
            <span class="c-gold">$<?= number_format($s['salary'], 0, '.', ' ') ?>/mies.</span>
            <?php if ($s['queued_tasks'] > 0): ?>
            <span class="c-warn"><?= $s['queued_tasks'] ?> w kolejce</span>
            <?php endif ?>
        </div>

        <?php if ($isBusy): ?>
        <div class="task-running">
            <div class="task-running-label">Aktywne zadanie</div>
            <div class="task-running-title"><?= htmlspecialchars($s['active_task_title'] ?? '') ?></div>
            <div class="task-running-time">
                Koniec: <?= date('d.m H:i', strtotime($s['active_task_end'])) ?>
                · Pozostało: <span class="countdown" data-end="<?= strtotime($s['active_task_end']) ?>"></span>
            </div>
            <div class="task-running-bar"><div class="task-running-fill" style="--bar-w:<?= $progress ?>%"></div></div>
        </div>
        <?php endif ?>

        <?php if (!$isBusy && $manager): ?>
        <div class="staff-actions">
            <details>
                <summary class="task-assign-toggle">+ Zlec zadanie</summary>
                <div class="task-form">
                    <form method="post">
                        <input type="hidden" name="_token" value="<?= $csrf ?>">
                        <input type="hidden" name="action" value="assign_task">
                        <input type="hidden" name="staff_id" value="<?= $s['id'] ?>">
                        <div class="task-form-grid">
                            <div class="form-group form-group--flush">
                                <label class="form-label">Typ zadania</label>
                                <select name="task_type" class="form-input" onchange="toggleWellSelect(this, '<?= $s['id'] ?>')">
                                    <?php foreach (TechnicalTeamService::TASKS as $code => $td):
                                        if (!in_array($s['spec_code'], $td['assignable'])) continue;
                                    ?>
                                    <option value="<?= $code ?>"
                                            data-needs-well="<?= $td['needs_well'] ? '1' : '0' ?>"
                                            data-needs-module="<?= $code === 'install_module' ? '1' : '0' ?>">
                                        <?= $td['icon'] ?> <?= $td['label'] ?> · <?= $td['effect'] ?>
                                    </option>
                                    <?php endforeach ?>
                                </select>
                            </div>
                            <div class="form-group form-group--flush" id="well-sel-<?= $s['id'] ?>">
                                <label class="form-label">Odwiert</label>
                                <select name="well_id" class="form-input">
                                    <option value="">— bez odwiertu —</option>
                                    <?php foreach ($wells as $w): ?>
                                    <option value="<?= $w['id'] ?>">#<?= $w['id'] ?> <?= htmlspecialchars($w['location_name'] ?? 'Odwiert') ?> (<?= $w['status'] ?>)</option>
                                    <?php endforeach ?>
                                </select>
                            </div>
                            <div class="form-group form-group--flush form-group--hidden" id="mod-sel-<?= $s['id'] ?>">
                                <label class="form-label">Moduł</label>
                                <select name="module_type" class="form-input">
                                    <?php foreach (TechnicalTeamService::MODULES as $mCode => $mDef): ?>
                                    <option value="<?= $mCode ?>"><?= $mDef['label'] ?> · <?= $mDef['effect'] ?></option>
                                    <?php endforeach ?>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">Zlec →</button>
                        </div>
                    </form>
                </div>
            </details>
        </div>
        <?php endif ?>

        <?php if (!$isBusy): ?>
        <form method="post" class="fire-form">
            <input type="hidden" name="_token" value="<?= $csrf ?>">
            <input type="hidden" name="action" value="fire_engineer">
            <input type="hidden" name="staff_id" value="<?= $s['id'] ?>">
            <button type="submit" class="btn btn-danger btn-sm"
                    onclick="return confirm('Zwolnić <?= addslashes($s['first_name'].' '.$s['last_name']) ?>?')">Zwolnij</button>
        </form>
