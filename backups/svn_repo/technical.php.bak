        <div class="cand-stat"><div class="cand-stat-lbl">Organizacja</div><div class="cand-stat-val"><?= $c['skill_organization'] ?>/10</div></div>
        <div class="cand-stat"><div class="cand-stat-lbl">Odporność</div><div class="cand-stat-val"><?= $c['skill_stress'] ?>/10</div></div>
        <div class="cand-stat"><div class="cand-stat-lbl">Oczekiwana pensja</div><div class="cand-stat-val c-gold">$<?= number_format($c['expected_salary'],0,'.',' ') ?>/mies.</div></div>
    </div>

    <?php if($reviewed): ?>
    <div class="cand-prev-review">
        <span class="cand-prev-score">Ocena techniczna: <strong><?= $c['technical_score'] ?>/10</strong></span>
