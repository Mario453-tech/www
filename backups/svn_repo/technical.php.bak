                            ✓ Rekomenduję zatrudnienie
                        </label>
                        <label class="rec-btn rec-reject <?= ($reviewed&&!$recHire)?'selected':'' ?>">
                            <input type="radio" name="recommendation" value="reject" <?= ($reviewed&&!$recHire)?'checked':'' ?>>
                            ✗ Nie rekomenduję
