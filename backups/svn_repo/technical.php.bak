<?php if ($activeTab === 'tasks'): ?>

<?php // ── Zadania W TRAKCIE ─────────────────────────── ?>
<?php if (!empty($activeTasks)): ?>
<div class="section-h">W trakcie (<?= count($activeTasks) ?>)</div>
<?php foreach ($activeTasks as $t):
    $taskDef  = TechnicalTeamService::TASKS[$t['task_type']] ?? ['icon' => '⚙', 'label' => $t['task_type'], 'effect' => ''];
    $endTs    = strtotime($t['active_task_end'] ?? $t['end_time']);
    $startTs  = strtotime($t['start_time']);
    $total    = max(1, $endTs - $startTs);
    $elapsed  = time() - $startTs;
    $progress = min(100, max(0, round($elapsed / $total * 100)));
    $overdue  = time() > $endTs;
?>
<div class="task-item in_progress <?= $overdue ? 'task-overdue' : '' ?>">
    <div class="task-icon"><?= $taskDef['icon'] ?></div>
    <div class="task-info">
        <div class="task-title"><?= htmlspecialchars($t['title']) ?></div>
        <div class="task-meta">
            <span><?= htmlspecialchars($t['first_name'] . ' ' . $t['last_name']) ?></span>
            <span class="sep">·</span>
            <span><?= htmlspecialchars($t['spec_name']) ?></span>
            <?php if ($t['well_name']): ?>
                <span class="sep">·</span>
                <span><?= htmlspecialchars($t['well_name']) ?></span>
            <?php endif ?>
            <?php if ($t['cost'] > 0): ?>
                <span class="sep">·</span>
                <span class="c-gold">$<?= number_format($t['cost'], 0, '.', ' ') ?></span>
            <?php endif ?>
        </div>
        <div class="task-prog-row">
            <div class="task-prog-bar"><div class="task-prog-fill" style="--bar-w:<?= $progress ?>%"></div></div>
            <span class="task-prog-pct"><?= $progress ?>%</span>
        </div>
    </div>
    <div class="task-side">
        <div class="task-time">
            <span class="countdown" data-end="<?= $endTs ?>">...</span>
            <div class="task-date">Koniec: <?= date('d.m H:i', $endTs) ?></div>
        </div>
        <?php if (!$overdue): ?>
        <form method="post" class="cancel-form" onsubmit="return confirm('Anulować to zadanie? Pracownik zostanie zwolniony do dyspozycji.')">
            <input type="hidden" name="_token" value="<?= $csrf ?>">
            <input type="hidden" name="action" value="cancel_task">
            <input type="hidden" name="task_id" value="<?= $t['id'] ?>">
            <button type="submit" class="btn-cancel-task" title="Anuluj zadanie">✕ Anuluj</button>
        </form>
        <?php else: ?>
        <span class="task-done-label">⏳ Finalizacja...</span>
        <?php endif ?>
    </div>
</div>
<?php endforeach ?>
<?php endif ?>

