<?php if ($activeTab === 'candidates'): ?>

<!-- ZAPOTRZEBOWANIE NA SPECJALISTÓW -->
<div class="g-card">
    <div class="g-card-title">Zapotrzebowanie na specjalistów</div>

    <?php if ($activeRecruitment): ?>
    <?php
    $secsLeft   = max(0,(int)$activeRecruitment['seconds_remaining']);
    $statusReady = $activeRecruitment['status'] === 'ready';

    // Auto-zamknij: status=ready ale brak żywych kandydatów → martwy request
    if ($statusReady && empty($candidates)) {
        try {
            $db->prepare("UPDATE recruitment_requests SET status='completed' WHERE id=?")
               ->execute([(int)$activeRecruitment['id']]);
            GameLog::info('technical.php', 'auto-completed stale ready recruitment',
                ['req_id' => $activeRecruitment['id']]);
            $activeRecruitment = null;
            $statusReady       = false;
        } catch (Throwable $e) {
            GameLog::error('technical.php', 'auto-complete stale recruitment FAILED', $e);
        }
    }
    ?>
    <?php if ($activeRecruitment): ?>
    <div class="rec-status-bar <?= $statusReady?'rec-ready':'rec-pending' ?>">
        <div class="rec-status-icon"><?= $statusReady?'✓':'⏳' ?></div>
        <div class="rec-status-info">
            <div class="rec-status-title"><?= $statusReady?'Kandydaci gotowi — przewiń w dół aby ocenić':'Dział Kadr szuka kandydatów...' ?></div>
            <div class="rec-status-meta">
                Zlecone przez: Dział Techniczny
                <?php if(!$statusReady && $secsLeft>0): ?>
                · Pozostało: <span class="countdown" data-end="<?= strtotime($activeRecruitment['ready_at']) ?>"></span>
                <?php endif ?>
            </div>
        </div>
        <?php if($statusReady): ?><span class="badge b-active">Gotowe</span><?php endif ?>
    </div>
    <?php endif ?>
    <?php endif ?>

    <?php if (!$activeRecruitment || ($activeRecruitment && $activeRecruitment['status'] === 'ready')): ?>
    <div class="specs-need-grid">
    <?php
    $wellCount = max(1, count($wells));
    // Proporcje: ile pracowników potrzeba na N odwiertów
    // drilling_engineer: 2 na 1 odwiert, reservoir_engineer: 1 na 2 odwierty,
    // production_engineer: 1 na 1, maintenance_engineer: 1 na 1, pipeline_engineer: 1 na 1,
    // safety_officer: 1 na 2 odwierty, safety_engineer: 1 na 2 odwierty
    $staffRatios = [
        'drilling_engineer'    => 2,       // x2 per odwiert
        'reservoir_engineer'   => 0.5,     // 1 na 2 odwierty
        'production_engineer'  => 1,       // 1 na 1
        'maintenance_engineer' => 1,       // 1 na 1
        'pipeline_engineer'    => 1,       // 1 na 1
        'safety_officer'       => 0.5,     // 1 na 2 odwierty
        'safety_engineer'      => 0.5,     // 1 na 2 odwierty
    ];
    foreach(TechnicalTeamService::SPECS as $specCode => $spec):
        $cnt    = count(array_filter($staff, fn($s) => $s['spec_code'] === $specCode));
        $ratio  = $staffRatios[$specCode] ?? 1;
        $needed = max(1, (int)ceil($wellCount * $ratio));
        $needMore = $cnt < $needed;
    ?>
    <div class="spec-need-card <?= $cnt > 0 ? ($needMore ? 'spec-partial' : 'spec-have') : 'spec-missing' ?>">
        <div class="spec-need-icon"><?= $spec['icon'] ?></div>
        <div class="spec-need-name"><?= $spec['name'] ?></div>
        <div class="spec-need-count">
            <span class="<?= $cnt >= $needed ? 'c-green' : ($cnt > 0 ? 'c-warn' : 'c-muted2') ?>">
                <?= $cnt ?> / <?= $needed ?> zatrudnionych
            </span>
        </div>
        <?php if($manager && $needMore): ?>
        <form method="post" class="spec-need-form">
            <input type="hidden" name="_token" value="<?= $csrf ?>">
            <input type="hidden" name="action" value="request_recruitment">
            <input type="hidden" name="spec_code" value="<?= $specCode ?>">
            <div class="spec-need-row">
                <select name="region_code" class="form-input spec-need-region">
                    <option value="PL">🇵🇱 Polska (lok. 6–12h)</option>
                    <option value="EU">🇪🇺 Europa (lok. 6–12h)</option>
                    <option value="NO">🇳🇴 Norwegia (międzyn. 24–48h)</option>
                    <option value="US_CA">🇺🇸 USA/Kanada (międzyn. 24–48h)</option>
                    <option value="ME">🌍 Bliski Wschód (międzyn. 24–48h)</option>
                    <option value="RU">🇷🇺 Rosja (lok. 6–12h)</option>
                    <option value="ASIA">🌏 Azja (międzyn. 24–48h)</option>
                </select>
                <select name="count" class="form-input spec-need-count" title="Ile rekrutacji naraz">
                    <option value="1">×1</option>
                    <option value="2">×2</option>
                    <option value="3">×3</option>
                </select>
            </div>
            <input type="hidden" name="recruitment_type" id="rec-type-<?= $specCode ?>" value="local">
            <button type="submit" class="btn btn-primary btn-sm" onclick="
                var r=this.form.querySelector('[name=recruitment_type]');
                var v=this.form.querySelector('[name=region_code]').value;
                var intl=['NO','US_CA','ME','ASIA'];
                r.value=intl.includes(v)?'international':'local';
            ">Zlec rekrutację →</button>
        </form>
        <?php elseif(!$manager): ?>
        <div class="sm-label c-muted2 mt-sm">Brak Kierownika — nie można zlecić</div>
        <?php else: ?>
        <div class="spec-have-info c-green fs12 mt-xs">✓ Obsadzono</div>
        <?php endif ?>
    </div>
    <?php endforeach ?>
    </div>
    <?php endif ?>
</div>

<?php
// Auto-zakończ rekrutację gdy status=ready i kandydaci już są wygenerowani
if ($activeRecruitment && $activeRecruitment['status'] === 'ready' && !empty($candidates)) {
    $svc->completeRecruitment((int)$activeRecruitment['id']);
    $activeRecruitment = null; // odśwież lokalnie
}
?>

