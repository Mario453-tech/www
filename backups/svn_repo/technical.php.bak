        <span class="t-section">Dział Techniczny</span>
    </div>
    <div class="topbar-right">
        <?php if ($manager): ?>
        <div class="topbar-manager">
            <span class="topbar-manager-name"><?= htmlspecialchars($manager['first_name'].' '.$manager['last_name']) ?></span>
            <span class="topbar-manager-role">Kierownik Techniczny</span>
        </div>
        <?php endif ?>
        <a href="<?= url('home') ?>" class="t-back">← Dashboard</a>
    </div>
</div>

<div class="t-wrap">

<?php if ($msg): ?>
