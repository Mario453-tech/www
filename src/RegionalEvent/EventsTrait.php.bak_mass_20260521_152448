<?php

/**
 * EventsTrait — rolling, saving and resolving regional events.
 */
trait RegionalEventsTrait
{
    /**
     * Check and roll regional events for a player.
     * Called once per tick per player.
     */
    public function processTick(int $playerId, float $deltaHours): void
    {
        try {
            // Fetch distinct regions from the player's active wells
            $stmt = $this->db->prepare("
                SELECT DISTINCT w.region_id, wr.code AS region_code, wr.name AS region_name
                FROM wells w
                JOIN world_regions wr ON wr.id = w.region_id
                WHERE w.player_id = ? AND w.status = 'active' AND w.region_id IS NOT NULL
            ");
            $stmt->execute([$playerId]);
            $regions = $stmt->fetchAll();

            foreach ($regions as $region) {
                $code      = $region['region_code'];
                $chance24h = self::EVENT_CHANCE[$code] ?? 0.0;

                // Scale 24h probability to this tick's deltaHours
                $tickChance = $chance24h * ($deltaHours / 24.0);

                if ((mt_rand(1, 100000) / 100000.0) > $tickChance) continue;

                // Cooldown check — no event fires if one is active or cooling down for this region
                $cooldownCheck = $this->db->prepare("
                    SELECT id FROM regional_events
                    WHERE player_id = ? AND region_id = ?
                      AND (
                          (resolved = 0 AND expires_at > NOW())
                          OR cooldown_until > NOW()
                      )
                    LIMIT 1
                ");
                $cooldownCheck->execute([$playerId, $region['region_id']]);
                if ($cooldownCheck->fetch()) continue;

                $this->triggerEvent($playerId, (int)$region['region_id'], $code, $region['region_name']);
            }
        } catch (Throwable $e) {
            GameLog::error('RegionalEventService', 'processTick FAILED', $e, ['player_id' => $playerId]);
        }
    }

    private function triggerEvent(int $playerId, int $regionId, string $code, string $regionName): void
    {
        try {
            $pool = self::EVENTS[$code] ?? [];
            if (empty($pool)) return;

            $event = $pool[array_rand($pool)];

            $expiresAt     = date('Y-m-d H:i:s', time() + $event['duration_h'] * 3600);
            // Next event in this region not earlier than 8h from now
            $cooldownUntil = date('Y-m-d H:i:s', time() + 8 * 3600);

            // Resolve lang key to translated message before storing
            $message = t($event['msg']);

            $this->db->prepare("
                INSERT INTO regional_events
                    (region_id, player_id, event_type, severity, started_at, expires_at, resolved, message, cooldown_until)
                VALUES (?, ?, ?, ?, NOW(), ?, 0, ?, ?)
            ")->execute([
                $regionId, $playerId,
                $event['type'], $event['severity'],
                $expiresAt, $message, $cooldownUntil,
            ]);

            GameLog::info('RegionalEventService', 'Event triggered', [
                'player_id'  => $playerId,
                'region'     => $code,
                'type'       => $event['type'],
                'severity'   => $event['severity'],
                'duration_h' => $event['duration_h'],
                'expires_at' => $expiresAt,
            ]);

            // Notify player
            try {
                $this->db->prepare("
                    INSERT INTO technical_notifications (player_id, well_id, type, message)
                    VALUES (?, NULL, 'task', ?)
                ")->execute([
                    $playerId,
                    t('regional_event.notify_prefix', ['region' => $regionName]) . $message,
                ]);
            } catch (Throwable $e) {
                GameLog::error('RegionalEventService', 'notify FAILED', $e);
            }

        } catch (Throwable $e) {
            GameLog::error('RegionalEventService', 'triggerEvent FAILED', $e, [
                'player_id' => $playerId,
                'region_id' => $regionId,
            ]);
        }
    }

    /**
     * Mark expired events as resolved.
     */
    public function resolveExpired(): void
    {
        try {
            $affected = $this->db->exec("
                UPDATE regional_events SET resolved = 1
                WHERE resolved = 0 AND expires_at <= NOW()
            ");
            if ($affected > 0) {
                GameLog::info('RegionalEventService', 'Resolved expired events', ['count' => $affected]);
            }
        } catch (Throwable $e) {
            GameLog::error('RegionalEventService', 'resolveExpired FAILED', $e);
        }
    }
}
