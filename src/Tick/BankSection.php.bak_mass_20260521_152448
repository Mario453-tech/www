<?php

/**
 * BankSection — sekcja 3 ticka: system bankowy (odsetki, raty, komornik, negocjacje, HR, bankruci).
 * BankSection — tick section 3: banking system (interest, installments, bailiff, negotiations, HR, bankrupts).
 */
class BankSection
{
    public int  $loanDecisions          = 0;
    public int  $negotiationsResolved   = 0;
    public int  $hrRecruitmentsProcessed = 0;
    public int  $bankruptcyProcessed    = 0;
    public int  $bankruptcyRecovered    = 0;

    private PDO  $db;
    private bool $bankNegAvailable;
    private bool $bankruptcyAvailable;

    public function __construct(PDO $db, bool $bankNegAvailable, bool $bankruptcyAvailable)
    {
        $this->db                  = $db;
        $this->bankNegAvailable    = $bankNegAvailable;
        $this->bankruptcyAvailable = $bankruptcyAvailable;
    }

    public function run(): void
    {
        $this->runInterest();
        $this->runInstallments();
        $this->runBailiff();
        $this->runLoanDecisions();
        $this->runExpireLoans();
        $this->runNegotiations();
        $this->runHR();
        $this->runBankruptcy();
    }

    private function runInterest(): void
    {
        try {
            GameLog::step('tick', 'bank', 1, 'calculateInterest');
            (new InterestEngine())->calculateInterest();
        } catch (Throwable $e) {
            GameLog::error('tick', 'InterestEngine::calculateInterest FAILED', $e);
        }
    }

    private function runInstallments(): void
    {
        try {
            GameLog::step('tick', 'bank', 2, 'processInstallments');
            (new LoanRepository())->processInstallments();
        } catch (Throwable $e) {
            GameLog::error('tick', 'LoanRepository::processInstallments FAILED', $e);
        }
    }

    private function runBailiff(): void
    {
        try {
            GameLog::step('tick', 'bank', 3, 'BailiffService');
            (new BailiffService())->process();
        } catch (Throwable $e) {
            GameLog::error('tick', 'BailiffService::process FAILED', $e);
        }
    }

    private function runLoanDecisions(): void
    {
        try {
            GameLog::step('tick', 'bank', 4, 'loan decisions');
            $decisionService = new LoanDecisionService();
            $pendingStmt     = $this->db->prepare("
                SELECT id FROM loan_applications
                WHERE status = 'pending' AND decision_at <= NOW()
            ");
            $pendingStmt->execute();
            foreach ($pendingStmt->fetchAll() as $app) {
                try {
                    $decisionService->processApplication((int)$app['id']);
                    $this->loanDecisions++;
                } catch (Throwable $e) {
                    GameLog::error('tick', 'processApplication FAILED', $e, ['app_id' => $app['id']]);
                }
            }
        } catch (Throwable $e) {
            GameLog::error('tick', 'loan decisions FAILED', $e);
        }
    }

    private function runExpireLoans(): void
    {
        try {
            $this->db->query("
                UPDATE loan_applications
                SET status = 'expired'
                WHERE status = 'approved'
                  AND expires_at IS NOT NULL
                  AND expires_at < NOW()
            ");
        } catch (Throwable $e) {
            GameLog::error('tick', 'expire loan_applications FAILED', $e);
        }
    }

    private function runNegotiations(): void
    {
        if (!$this->bankNegAvailable) {
            GameLog::warn('tick', 'BankNegotiationService.php not found — blocks 4f-4i disabled');
            return;
        }

        $bankNeg = new BankNegotiationService();

        try {
            GameLog::step('tick', 'bank', 5, 'processPendingNegotiations');
            $this->negotiationsResolved = (int)$bankNeg->processPendingNegotiations();
            GameLog::info('tick', 'negotiations_resolved', ['count' => $this->negotiationsResolved]);
        } catch (Throwable $e) {
            GameLog::error('tick', 'processPendingNegotiations FAILED', $e);
        }

        try {
            GameLog::step('tick', 'bank', 6, 'randomEvents');
            $pendingNegs     = $this->db->query("
                SELECT id FROM bank_negotiations
                WHERE status = 'pending' AND decision_due_at > NOW()
            ")->fetchAll();
            $eventsTriggered = 0;
            foreach ($pendingNegs as $pn) {
                try {
                    $event = $bankNeg->triggerRandomEvent((int)$pn['id']);
                    if ($event) $eventsTriggered++;
                } catch (Throwable $e) {
                    GameLog::error('tick', 'triggerRandomEvent FAILED', $e, ['neg_id' => $pn['id']]);
                }
            }
            GameLog::info('tick', 'negotiation_random_events', ['triggered' => $eventsTriggered]);
        } catch (Throwable $e) {
            GameLog::error('tick', 'randomEvents FAILED', $e);
        }

        try {
            GameLog::step('tick', 'bank', 7, 'checkRecoveryViolations');
            $violations = $bankNeg->checkRecoveryPlanViolations();
            if ($violations > 0) GameLog::info('tick', 'recovery_plan_violations', ['count' => $violations]);
        } catch (Throwable $e) {
            GameLog::error('tick', 'checkRecoveryPlanViolations FAILED', $e);
        }

        try {
            GameLog::step('tick', 'bank', 8, 'checkRecoveryCompleted');
            $completed = $bankNeg->checkRecoveryPlanCompleted();
            if ($completed > 0) GameLog::info('tick', 'recovery_plan_completed', ['count' => $completed]);
        } catch (Throwable $e) {
            GameLog::error('tick', 'checkRecoveryPlanCompleted FAILED', $e);
        }

        try {
            GameLog::step('tick', 'bank', 9, 'checkDeferralSuspensions');
            $deferred = $bankNeg->checkDeferralSuspensions();
            if ($deferred > 0) GameLog::info('tick', 'deferral_bailiffs_reactivated', ['count' => $deferred]);
        } catch (Throwable $e) {
            GameLog::error('tick', 'checkDeferralSuspensions FAILED', $e);
        }
    }

    private function runHR(): void
    {
        try {
            GameLog::step('tick', 'hr', 1, 'processReadyRecruitments');
            $hrSvcTick                     = new HRService();
            $this->hrRecruitmentsProcessed = (int)$hrSvcTick->processReadyRecruitments();
            if ($this->hrRecruitmentsProcessed > 0) {
                GameLog::info('tick', 'processReadyRecruitments', ['processed' => $this->hrRecruitmentsProcessed]);
            }
        } catch (Throwable $e) {
            GameLog::error('tick', 'processReadyRecruitments FAILED', $e);
        }

        try {
            $this->db->prepare("
                UPDATE recruitment_requests SET status = 'completed'
                WHERE status = 'ready' AND ready_at < DATE_SUB(NOW(), INTERVAL 48 HOUR)
            ")->execute();
        } catch (Throwable $e) {
            GameLog::error('tick', 'recruitment_cleanup FAILED', $e);
        }

        try {
            GameLog::step('tick', 'hr', 2, 'headhunter processReady');
            (new HeadhunterService(0))->processReady();
        } catch (Throwable $e) {
            GameLog::error('tick', 'HeadhunterService::processReady FAILED', $e);
        }
    }

    private function runBankruptcy(): void
    {
        if (!$this->bankruptcyAvailable) {
            GameLog::warn('tick', 'BankruptcyService.php not found — block 4k disabled');
            return;
        }

        try {
            GameLog::step('tick', 'bankruptcy', 1, 'start');
            $bankruptStmt = $this->db->prepare("
                SELECT id FROM players
                WHERE status = 'bankrupt' OR COALESCE(recovery_mode, 0) = 1
            ");
            $bankruptStmt->execute();
            $bankruptPlayers = $bankruptStmt->fetchAll();

            GameLog::dbResult('tick', 'bankrupt players', count($bankruptPlayers));

            foreach ($bankruptPlayers as $bPlayer) {
                $bPlayerId = (int)$bPlayer['id'];
                try {
                    $bankruptcyService = new BankruptcyService($bPlayerId);
                    $state             = $bankruptcyService->getState();
                    if (empty($state['is_bankrupt'])) {
                        $this->bankruptcyProcessed++;
                        continue;
                    }
                    $recovered = $bankruptcyService->tryRecover();
                    if ($recovered) {
                        $this->bankruptcyRecovered++;
                        GameLog::info('tick', 'bankruptcy - player recovered', ['player_id' => $bPlayerId]);
                    }
                    $this->bankruptcyProcessed++;
                } catch (Throwable $e) {
                    GameLog::error('tick', 'bankruptcy - player error', $e, ['player_id' => $bPlayerId]);
                }
            }

            GameLog::info('tick', 'bankruptcy - done', [
                'processed' => $this->bankruptcyProcessed,
                'recovered' => $this->bankruptcyRecovered,
            ]);
        } catch (Throwable $e) {
            GameLog::error('tick', 'bankruptcy block FAILED', $e);
        }
    }
}
