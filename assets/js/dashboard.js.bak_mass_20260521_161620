async function hireCandidate(candidateId, candidateName) {
    confirmAction(`Czy na pewno chcesz zatrudniæ: ${candidateName}?`, async function () {
        try {
            const fd = new FormData();
            fd.append('action', 'hire_candidate');
            fd.append('candidate_id', candidateId);
            fd.append('_token', CSRF_TOKEN);

            const res = await fetch(API_URL, { method: 'POST', body: fd });
            const result = await res.json();

            if (result.success) {
                window.showGameToast('Zatrudniono', 'Kandydat zosta³ zatrudniony.', 'success');
                setTimeout(function () { location.reload(); }, 900);
            } else {
                alertError(result.error ? ('B³¹d: ' + result.error) : 'Nie uda³o siê zatrudniæ kandydata.');
            }
        } catch (e) {
            alertError('Wyst¹pi³ b³¹d podczas zatrudniania.');
        }
    }, { type: 'confirm', confirmLabel: 'Zatrudnij' });
}

async function fireEmployee(memberId, memberName) {
    confirmAction(
        `Czy na pewno chcesz zwolniæ: ${memberName}? Ta decyzja jest nieodwracalna.`,
        function () {
            promptInput('Podaj powód zwolnienia:', 'Decyzja dyrektora', async function (reason) {
                try {
                    const fd = new FormData();
                    fd.append('action', 'fire_employee');
                    fd.append('member_id', memberId);
                    fd.append('reason', reason || 'Decyzja dyrektora');
                    fd.append('_token', CSRF_TOKEN);

                    const res = await fetch(API_URL, { method: 'POST', body: fd });
                    const result = await res.json();

                    if (result.success) {
                        window.showGameToast('Zwolniono', 'Pracownik zosta³ zwolniony.', 'success');
                        setTimeout(function () { location.reload(); }, 900);
                    } else {
                        alertError(result.error ? ('B³¹d: ' + result.error) : 'Nie uda³o siê zwolniæ pracownika.');
                    }
                } catch (e) {
                    alertError('Wyst¹pi³ b³¹d podczas zwalniania.');
                }
            }, { title: 'Powód zwolnienia', confirmLabel: 'Zwolnij' });
        },
        { type: 'danger', confirmLabel: 'Zwolnij' }
    );
}

