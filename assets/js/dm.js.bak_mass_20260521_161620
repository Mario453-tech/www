(function () {
    'use strict';

    var cfg = window.DM_CONFIG || {};
    var DM_API = cfg.api || '/src/ChatApi.php';
    var MY_ID = parseInt(cfg.myId || 0, 10);
    var WITH_ID = cfg.withId ? parseInt(cfg.withId, 10) : null;
    var L = cfg.strings || {};

    var lastId = 0;
    var interval = null;
    var conversationsInterval = null;
    var pendingAttachment = null;
    var uploadInFlight = false;
    var settings = {
        enterSends: localStorage.getItem('dm.enterSends') !== '0',
        soundEnabled: localStorage.getItem('dm.soundEnabled') !== '0'
    };

    var EMOJIS = window.EmojiLib.EMOJIS;
    var parseEmojis = window.EmojiLib.parseEmojis;

    function escHtml(s) {
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function dmToast(text, type) {
        if (typeof window.showGameToast === 'function') {
            window.showGameToast(text, type || 'info');
            return;
        }
        var existing = document.getElementById('dmToast');
        if (existing) existing.remove();
        var el = document.createElement('div');
        el.id = 'dmToast';
        el.className = 'dm-toast dm-toast--' + (type || 'info');
        el.textContent = text;
        document.body.appendChild(el);
        requestAnimationFrame(function () { el.classList.add('dm-toast--show'); });
        setTimeout(function () {
            el.classList.remove('dm-toast--show');
            setTimeout(function () { el.remove(); }, 180);
        }, 2800);
    }

    function playDmSound() {
        if (!settings.soundEnabled) return;
        try {
            var ctx = new (window.AudioContext || window.webkitAudioContext)();
            var osc = ctx.createOscillator();
            var gain = ctx.createGain();
            osc.type = 'sine';
            osc.frequency.value = 880;
            gain.gain.value = 0.03;
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.18);
            osc.stop(ctx.currentTime + 0.18);
        } catch (e) {
        }
    }

    function formatConversationPreview(c) {
        if (c.attachment_path && (!c.last_message || c.last_message === L.attachmentPreview)) {
            return L.attachmentPreview || 'Zdjęcie';
        }
        return c.last_message || '';
    }

    function renderConversation(c) {
        var unread = parseInt(c.unread_count || 0, 10);
        return '' +
            '<div class="dm-conv-item' + (WITH_ID === parseInt(c.partner_id, 10) ? ' active' : '') + '" data-partner-id="' + c.partner_id + '" onclick="location.href=\'/dm?with=' + c.partner_id + '\'">' +
                '<div class="dm-conv-top">' +
                    '<div class="dm-conv-name">' + escHtml(c.partner_name) + '</div>' +
                    (unread > 0 ? '<span class="dm-conv-unread">' + unread + '</span>' : '') +
                '</div>' +
                '<div class="dm-conv-preview">' + escHtml(formatConversationPreview(c)) + '</div>' +
            '</div>';
    }

    function renderAttachment(m, mine) {
        if (!m.attachment_path) return '';
        var actions = '';
        if (mine) {
            actions = '' +
                '<button type="button" class="dm-attachment-delete" title="' + escHtml(L.deleteAttachment || 'Usuń zdjęcie') + '"' +
                ' onclick="event.stopPropagation();deleteDmAttachment(' + parseInt(m.id, 10) + ')">' +
                '&#10005;</button>';
        }
        return '' +
            '<div class="dm-attachment">' +
                '<a href="/' + escHtml(m.attachment_path) + '" target="_blank" rel="noopener noreferrer" class="dm-attachment-link">' +
                    '<img class="dm-attachment-image" src="/' + escHtml(m.attachment_path) + '" alt="' + escHtml(L.imageAlt || 'Załączony obraz') + '">' +
                '</a>' +
                actions +
            '</div>';
    }

    function renderMessage(m) {
        var mine = parseInt(m.sender_id || 0, 10) === MY_ID;
        var username = m.username || 'Gracz';
        var avatarPath = m.avatar_path || null;
        var bubbleClass = 'chat-msg-bubble' + (mine ? ' chat-msg-bubble--mine' : '');
        var avatar = avatarPath
            ? '<img class="chat-msg-avatar" src="/' + escHtml(avatarPath) + '" alt="' + escHtml(username.charAt(0).toUpperCase()) + '">'
            : '<span class="chat-msg-avatar chat-msg-avatar--initials">' + escHtml(username.charAt(0).toUpperCase()) + '</span>';
        var body = renderAttachment(m, mine);
        if (m.message) {
            body += '<div class="dm-message-text">' + parseEmojis(escHtml(m.message)).replace(/\n/g, '<br>') + '</div>';
        }

        var header = mine
            ? '<div class="chat-msg-header"><span class="chat-msg-time">' + escHtml(m.time) + '</span><span class="chat-msg-spacer"></span><span class="chat-msg-author">' + escHtml(username) + '</span>' + avatar + '</div>'
            : '<div class="chat-msg-header">' + avatar + '<span class="chat-msg-author">' + escHtml(username) + '</span><span class="chat-msg-spacer"></span><span class="chat-msg-time">' + escHtml(m.time) + '</span></div>';

        return '' +
            '<div class="chat-msg' + (mine ? ' chat-msg--mine' : '') + '" data-id="' + parseInt(m.id, 10) + '">' +
                header +
                '<div class="' + bubbleClass + '">' + body + '</div>' +
            '</div>';
    }

    function setSidebarUnread(total) {
        var pill = document.getElementById('dmUnreadSidebar');
        if (!pill) return;
        if (total > 0) {
            pill.hidden = false;
            pill.textContent = String(total);
        } else {
            pill.hidden = true;
        }
    }

    function renderAttachmentPreview() {
        var box = document.getElementById('dmAttachmentPreview');
        if (!box) return;
        if (!pendingAttachment) {
            box.hidden = true;
            box.innerHTML = '';
            return;
        }
        box.hidden = false;
        box.innerHTML = '' +
            '<div class="dm-attachment-preview__card">' +
                '<img src="' + pendingAttachment.previewUrl + '" class="dm-attachment-preview__img" alt="' + escHtml(L.imageAlt || 'Załączony obraz') + '">' +
                '<div class="dm-attachment-preview__meta">' +
                    '<strong>' + escHtml(pendingAttachment.file.name) + '</strong>' +
                    '<small>' + Math.round(pendingAttachment.file.size / 1024) + ' KB</small>' +
                '</div>' +
                '<button type="button" class="dm-attachment-preview__remove" onclick="removeDmAttachment()" title="' + escHtml(L.attachmentRemove || 'Usuń') + '">&#10005;</button>' +
            '</div>';
    }

    function resizeTextarea() {
        var input = document.getElementById('dmInput');
        if (!input) return;
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 140) + 'px';
    }

    function loadConversations() {
        fetch(DM_API + '?action=conversations', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                var list = document.getElementById('dmConvList');
                if (!list) return;
                if (!d.conversations || !d.conversations.length) {
                    list.innerHTML = '<div class="dm-empty">' + escHtml(L.noConversations || 'Brak rozmów') + '</div>';
                    setSidebarUnread(0);
                    return;
                }
                var totalUnread = 0;
                list.innerHTML = d.conversations.map(function (c) {
                    totalUnread += parseInt(c.unread_count || 0, 10);
                    return renderConversation(c);
                }).join('');
                setSidebarUnread(totalUnread);
            })
            .catch(function () {});
    }

    function updateHeaderMeta() {
        var el = document.getElementById('dmHeaderMeta');
        if (!el) return;
        el.textContent = settings.enterSends ? 'Enter wysyła' : 'Enter = nowa linia';
    }

    function appendMessages(messages, notifyOnIncoming) {
        var box = document.getElementById('dmMessages');
        if (!box || !messages || !messages.length) return;
        messages.forEach(function (m) {
            var messageId = parseInt(m.id, 10);
            if (messageId > lastId) {
                lastId = messageId;
                box.insertAdjacentHTML('beforeend', renderMessage(m));
                if (notifyOnIncoming && parseInt(m.sender_id || 0, 10) !== MY_ID) {
                    playDmSound();
                }
            }
        });
        box.scrollTop = box.scrollHeight;
    }

    function loadMessages() {
        if (!WITH_ID) return;
        fetch(DM_API + '?with=' + WITH_ID, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                var box = document.getElementById('dmMessages');
                if (!box) return;
                box.innerHTML = '';
                lastId = 0;
                appendMessages(d.messages || [], false);
                loadConversations();
            })
            .catch(function () {});
    }

    function pollMessages() {
        if (!WITH_ID) return;
        fetch(DM_API + '?with=' + WITH_ID + '&since=' + lastId, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                appendMessages(d.messages || [], true);
                if ((d.messages || []).length) {
                    loadConversations();
                }
            })
            .catch(function () {});
    }

    function uploadAttachmentInChunks(file) {
        var token = 'dm_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8);
        var chunkSize = 12288;
        var total = Math.ceil(file.size / chunkSize);
        var progressLabel = L.uploading || 'Wgrywanie...';

        return new Promise(function (resolve, reject) {
            var index = 0;

            function sendNext() {
                var start = index * chunkSize;
                var end = Math.min(file.size, start + chunkSize);
                var chunk = file.slice(start, end);
                profileStatus(progressLabel, index + 1, total);

                fetch(DM_API, {
                    method: 'POST',
                    body: chunk,
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/octet-stream',
                        'X-Upload-Action': 'dm_upload_chunk',
                        'X-Upload-Token': token,
                        'X-Upload-Name': file.name,
                        'X-Upload-Mime': file.type || 'application/octet-stream',
                        'X-Upload-Size': String(file.size),
                        'X-Upload-Index': String(index),
                        'X-Upload-Total': String(total),
                        'X-Upload-Receiver': String(WITH_ID || 0),
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (!data || !data.ok) {
                            throw new Error((data && data.error) || (L.uploadInvalid || 'Błąd uploadu'));
                        }
                        index += 1;
                        if (index < total) {
                            sendNext();
                            return;
                        }
                        resolve(token);
                    })
                    .catch(function (err) {
                        reject(err);
                    });
            }

            sendNext();
        });
    }

    function profileStatus(label, current, total) {
        if (!current || !total) {
            dmToast(label, 'info');
            return;
        }
        dmToast((L.uploadProgress || 'Wgrywanie zdjęcia') + ' ' + current + '/' + total, 'info');
    }

    function sendPayload(message, attachmentToken) {
        return fetch(DM_API, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                action: 'send',
                message: message,
                receiver_id: WITH_ID,
                attachment_token: attachmentToken || ''
            })
        }).then(function (r) { return r.json(); });
    }

    function dmSend() {
        if (!WITH_ID || uploadInFlight) return;
        var input = document.getElementById('dmInput');
        var message = input ? input.value.trim() : '';
        if (!message && !pendingAttachment) return;

        uploadInFlight = true;
        var sendButton = document.querySelector('.dm-send-btn');
        if (sendButton) sendButton.disabled = true;

        Promise.resolve()
            .then(function () {
                if (!pendingAttachment) return '';
                return uploadAttachmentInChunks(pendingAttachment.file);
            })
            .then(function (token) {
                return sendPayload(message, token);
            })
            .then(function (data) {
                if (!data || data.error) {
                    throw new Error((data && data.error) || (L.sendError || 'Błąd'));
                }
                if (input) {
                    input.value = '';
                    resizeTextarea();
                }
                pendingAttachment = null;
                renderAttachmentPreview();
                lastId = Math.max(lastId, parseInt(data.id || 0, 10));
                pollMessages();
                loadConversations();
            })
            .catch(function (err) {
                dmToast(err && err.message ? err.message : (L.sendError || 'Błąd'), 'error');
            })
            .finally(function () {
                uploadInFlight = false;
                if (sendButton) sendButton.disabled = false;
            });
    }

    function deleteAttachment(messageId) {
        confirmAction(L.deleteAttachmentConfirm || 'Usunąć zdjęcie?', function () {
            fetch(DM_API, {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'delete_attachment', message_id: messageId })
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data || data.error) {
                        throw new Error((data && data.error) || (L.sendError || 'Błąd'));
                    }
                    dmToast(data.message || (L.attachmentDeleted || 'Usunięto zdjęcie'), 'success');
                    loadMessages();
                })
                .catch(function (err) {
                    dmToast(err && err.message ? err.message : (L.sendError || 'Błąd'), 'error');
                });
        }, { type: 'danger', title: L.deleteAttachment || 'Usuń zdjęcie' });
    }

    function handleAttachmentInput(input) {
        var file = input.files && input.files[0];
        if (!file) return;
        if (!/^image\/(jpeg|png|gif|webp)$/i.test(file.type)) {
            dmToast(L.uploadInvalid || 'Nieprawidłowy plik.', 'error');
            input.value = '';
            return;
        }
        if (file.size > 3 * 1024 * 1024) {
            dmToast(L.uploadLimit || 'Plik jest za duży.', 'error');
            input.value = '';
            return;
        }

        var reader = new FileReader();
        reader.onload = function (e) {
            pendingAttachment = {
                file: file,
                previewUrl: e.target.result
            };
            renderAttachmentPreview();
        };
        reader.readAsDataURL(file);
        input.value = '';
    }

    function removeAttachment() {
        pendingAttachment = null;
        renderAttachmentPreview();
    }

    function toggleMenu(id) {
        var target = document.getElementById(id);
        if (!target) return;
        var otherId = id === 'dmEmojiMenu' ? 'dmSettingsMenu' : 'dmEmojiMenu';
        var other = document.getElementById(otherId);
        if (other) other.hidden = true;
        target.hidden = !target.hidden;
    }

    function buildEmojiMenu() {
        var menu = document.getElementById('dmEmojiMenu');
        if (!menu) return;
        menu.innerHTML = EMOJIS.map(function (emoji) {
            return '<button type="button" class="dm-emoji-btn" onclick="insertDmEmoji(' + JSON.stringify(emoji) + ')">' + emoji + '</button>';
        }).join('');
    }

    function insertEmoji(emoji) {
        var input = document.getElementById('dmInput');
        if (!input) return;
        input.value = (input.value ? input.value + ' ' : '') + emoji + ' ';
        input.focus();
        resizeTextarea();
        document.getElementById('dmEmojiMenu').hidden = true;
    }

    function syncSettingsUi() {
        var enterToggle = document.getElementById('dmEnterToggle');
        var soundToggle = document.getElementById('dmSoundToggle');
        if (enterToggle) enterToggle.checked = settings.enterSends;
        if (soundToggle) soundToggle.checked = settings.soundEnabled;
        updateHeaderMeta();
    }

    function bindSettings() {
        var enterToggle = document.getElementById('dmEnterToggle');
        var soundToggle = document.getElementById('dmSoundToggle');
        if (enterToggle) {
            enterToggle.addEventListener('change', function () {
                settings.enterSends = !!this.checked;
                localStorage.setItem('dm.enterSends', settings.enterSends ? '1' : '0');
                updateHeaderMeta();
            });
        }
        if (soundToggle) {
            soundToggle.addEventListener('change', function () {
                settings.soundEnabled = !!this.checked;
                localStorage.setItem('dm.soundEnabled', settings.soundEnabled ? '1' : '0');
            });
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        buildEmojiMenu();
        syncSettingsUi();
        bindSettings();
        loadConversations();

        if (WITH_ID) {
            loadMessages();
            interval = setInterval(pollMessages, 4000);
        }
        conversationsInterval = setInterval(loadConversations, 12000);

        var input = document.getElementById('dmInput');
        if (input) {
            input.addEventListener('input', resizeTextarea);
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && settings.enterSends && !e.shiftKey) {
                    e.preventDefault();
                    dmSend();
                }
            });
            resizeTextarea();
        }

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.dm-sidebar-new')) {
                var picker = document.getElementById('dmPlayerSelect');
                if (picker) picker.style.display = 'none';
            }
            if (!e.target.closest('#dmEmojiBtn') && !e.target.closest('#dmEmojiMenu')) {
                var emojiMenu = document.getElementById('dmEmojiMenu');
                if (emojiMenu) emojiMenu.hidden = true;
            }
            if (!e.target.closest('#dmSettingsBtn') && !e.target.closest('#dmSettingsMenu')) {
                var settingsMenu = document.getElementById('dmSettingsMenu');
                if (settingsMenu) settingsMenu.hidden = true;
            }
        });
    });

    window.togglePlayerSelect = function () {
        var s = document.getElementById('dmPlayerSelect');
        if (!s) return;
        s.style.display = s.style.display === 'block' ? 'none' : 'block';
    };

    window.startDm = function (id) {
        location.href = '/dm?with=' + id;
    };

    window.dmSend = dmSend;
    window.handleDmAttachment = handleAttachmentInput;
    window.removeDmAttachment = removeAttachment;
    window.toggleDmEmojiMenu = function () { toggleMenu('dmEmojiMenu'); };
    window.toggleDmSettingsMenu = function () { toggleMenu('dmSettingsMenu'); };
    window.insertDmEmoji = insertEmoji;
    window.deleteDmAttachment = deleteAttachment;
})();
