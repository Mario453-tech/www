/* logistics.js — Optymalizator logistyki odwiertów */

var _LL = window.LOGISTICS_LANG || {};
function ll(k, p) {
    var s = _LL[k] || k;
    if (p) Object.keys(p).forEach(function(pk) { s = s.replace(':' + pk, p[pk]); });
    return s;
}

function logisticsMoney(value) {
    return (value || 0).toLocaleString('pl-PL', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' PLN/h';
}

function logisticsCash(value) {
    return (value || 0).toLocaleString('pl-PL', {minimumFractionDigits: 0, maximumFractionDigits: 0}) + ' PLN';
}

async function logisticsApi(action, data) {
    if (typeof LOGISTICS_API === 'undefined') throw new Error(ll('api_missing'));
    const fd = new FormData();
    fd.append('action', action);
    fd.append('_token', window.LOGISTICS_CSRF || '');
    if (data) Object.entries(data).forEach(([k, v]) => fd.append(k, v));
    const method = action === 'summary' || action === 'cooldown' ? 'GET' : 'POST';
    const url    = method === 'GET' ? `${LOGISTICS_API}?action=${action}` : LOGISTICS_API;
    const opts   = method === 'POST'
        ? { method: 'POST', body: fd, headers: {'X-Requested-With': 'XMLHttpRequest'} }
        : { headers: {'X-Requested-With': 'XMLHttpRequest'} };
    const res = await fetch(url, opts);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
}

// ── Słownik typów odwiertów ───────────────────────────────────────────────
function wellTypePL(type) {
    const map = {
        'onshore':  ll('well_type_onshore')  || 'Lądowy',
        'offshore': ll('well_type_offshore') || 'Morski',
    };
    return map[type] || type;
}

// ── Koszty trybów ─────────────────────────────────────────────────────────
const MODE_COSTS = {
    'balans':   2500,
    'max_prod': 5000,
    'min_cost': 1500,
};

function getModeLabel(mode) {
    return ll('mode_' + mode) || mode;
}

// ── Otwórz modal ──────────────────────────────────────────────────────────
function openLogisticsModal() {
    document.getElementById('logistics-modal').style.display = 'flex';
    document.getElementById('logistics-results').style.display = 'none';
    _logisticsResetFooter();
    loadLogisticsSummary();

    // Obsługa kliknięcia kart trybu + pokaż koszt na karcie
    document.querySelectorAll('.logistics-mode-card').forEach(card => {
        const modeInput = card.querySelector('input[name="logistics-mode"]');
        const modeVal   = modeInput ? modeInput.value : 'balans';
        const cost      = MODE_COSTS[modeVal] || 0;

        // Dodaj etykietę kosztu jeśli jeszcze nie ma
        if (!card.querySelector('.logistics-mode-cost')) {
            const costEl = document.createElement('span');
            costEl.className = 'logistics-mode-cost';
            costEl.textContent = logisticsCash(cost);
            card.appendChild(costEl);
        }

        card.addEventListener('click', function() {
            document.querySelectorAll('.logistics-mode-card').forEach(c => c.classList.remove('selected'));
            this.classList.add('selected');
            _logisticsResetFooter(); // wróć do normalnych przycisków gdy zmienia tryb
        });
    });
}

function closeLogisticsModal() {
    document.getElementById('logistics-modal').style.display = 'none';
    _logisticsResetFooter();
}

// ── Przywróć oryginalny footer modal ─────────────────────────────────────
function _logisticsResetFooter() {
    const footer = document.querySelector('.logistics-modal-footer');
    if (!footer) return;
    footer.innerHTML = `
        <button type="button" class="btn btn-sm btn-secondary" onclick="closeLogisticsModal()">
            ${ll('cancel') || 'Zamknij'}
        </button>
        <button type="button" class="btn btn-sm btn-primary" id="btn-logistics-run" onclick="_logisticsAskConfirm()">
            ⚡ ${ll('run') || 'Uruchom optymalizację'}
        </button>`;
}

// ── Krok 1: Pokaż potwierdzenie z kosztem ─────────────────────────────────
function _logisticsAskConfirm() {
    const modeInput = document.querySelector('input[name="logistics-mode"]:checked');
    const mode      = modeInput ? modeInput.value : 'balans';
    const cost      = MODE_COSTS[mode] || 0;
    const modeName  = getModeLabel(mode);

    const footer = document.querySelector('.logistics-modal-footer');
    if (!footer) return;

    footer.innerHTML = `
        <div class="logistics-confirm-box">
            <div class="logistics-confirm-info">
                <span class="logistics-confirm-mode">${ll('label_mode') || 'Tryb'}: <strong>${modeName}</strong></span>
                <span class="logistics-confirm-cost">${ll('label_fee') || 'Opłata'}: <strong class="c-warn">${logisticsCash(cost)}</strong></span>
            </div>
            <div class="logistics-confirm-btns">
                <button type="button" class="btn btn-sm btn-secondary" onclick="_logisticsResetFooter()">
                    ✕ ${ll('cancel') || 'Anuluj'}
                </button>
                <button type="button" class="btn btn-sm btn-primary" id="btn-logistics-confirm" onclick="runLogisticsOptimize()">
                    ✓ ${ll('confirm_btn') || 'Potwierdź i odlicz PLN'}
                </button>
            </div>
        </div>`;
}

// ── Ładuj aktualny stan transportu ───────────────────────────────────────
async function loadLogisticsSummary() {
    const body = document.getElementById('logistics-current-body');
    body.innerHTML = `<span class="logistics-loading">${ll('loading')}</span>`;
    try {
        const data = await logisticsApi('summary');
        if (!data.success) { body.innerHTML = `<span class="c-bad">${ll('err')}</span>`; return; }

        const t = data.totals || {};
        const typeIcons = { rurociag: '🔧', ciezarowki: '🚛', tankowiec: '🛢' };

        // Podsumowanie globalne
        let html = `
        <div class="logistics-summary-grid">
            <div class="logistics-stat">
                <div class="logistics-stat-lbl">${ll('label_loss')}</div>
                <div class="logistics-stat-val c-warn">${(t.loss || 0).toLocaleString('pl-PL', {minimumFractionDigits: 1, maximumFractionDigits: 1})} bbl/h</div>
            </div>
            <div class="logistics-stat">
                <div class="logistics-stat-lbl">${ll('label_cost')}</div>
                <div class="logistics-stat-val c-muted">${logisticsMoney(t.cost)}</div>
            </div>
        </div>`;

        // Lista odwiertów
        if (data.wells && data.wells.length > 0) {
            html += '<div class="logistics-wells-list">';
            data.wells.forEach(w => {
                const icon  = typeIcons[w.transport] || '?';
                const lossC = w.loss > 0 ? 'c-warn' : 'c-good';
                const wtPL  = wellTypePL(w.well_type);
                html += `
                <div class="logistics-well-row">
                    <span class="logistics-well-id">#${w.id}</span>
                    <span class="logistics-well-type ${w.well_type === 'offshore' ? 'c-blue' : ''}">${wtPL}</span>
                    <span class="logistics-well-transport">${icon} ${ll('type_' + w.transport)}</span>
                    <span class="logistics-well-cap c-muted">${w.capacity_pct}%</span>
                    <span class="logistics-well-loss ${lossC}">${w.loss > 0 ? '-' + w.loss.toFixed(1) + ' bbl/h' : '✓'}</span>
                </div>`;
            });
            html += '</div>';
        }
        body.innerHTML = html;

        // Sprawdź cooldown i ewentualnie zablokuj przycisk
        const cdData = await logisticsApi('cooldown');
        if (cdData.cooldown > 0) {
            const btn = document.getElementById('btn-logistics-run');
            if (btn) {
                btn.disabled = true;
                startCooldownTimer(btn, cdData.cooldown);
            }
        }
    } catch(e) {
        body.innerHTML = `<span class="c-bad">${ll('err')}: ${e.message}</span>`;
    }
}

// ── Krok 2: Uruchom optymalizację (po potwierdzeniu) ─────────────────────
async function runLogisticsOptimize() {
    const modeInput = document.querySelector('input[name="logistics-mode"]:checked');
    const mode      = modeInput ? modeInput.value : 'balans';

    const confirmBtn = document.getElementById('btn-logistics-confirm');
    if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.textContent = '⏳ ' + ll('optimizing'); }

    const resBox  = document.getElementById('logistics-results');
    const resBody = document.getElementById('logistics-results-body');
    resBox.style.display = 'none';

    try {
        const result = await logisticsApi('optimize', { mode });

        if (!result.success) {
            // Cooldown lub brak środków lub inny błąd
            if (result.cooldown) {
                _logisticsResetFooter();
                const btn = document.getElementById('btn-logistics-run');
                if (btn) startCooldownTimer(btn, result.cooldown);
                resBody.innerHTML = `<div class="logistics-cooldown-msg">⏱ ${result.error}</div>`;
            } else {
                _logisticsResetFooter();
                resBody.innerHTML = `<div class="c-bad">⚠ ${result.error}</div>`;
            }
            resBox.style.display = 'block';
            return;
        }

        // Sukces — pokaż wyniki
        const bef = result.before || {};
        const aft = result.after  || {};
        const typeIcons = { rurociag: '🔧', ciezarowki: '🚛', tankowiec: '🛢' };
        const modeCost  = result.mode_cost || MODE_COSTS[mode] || 0;

        let html = `
        <div class="logistics-cost-paid">
            💳 ${ll('label_fee') || 'Opłata'}: <strong>${logisticsCash(modeCost)}</strong>
        </div>
        <div class="logistics-compare">
            <div class="logistics-compare-col">
                <div class="logistics-compare-hdr">${ll('label_before')}</div>
                <div class="logistics-compare-stat"><span>${ll('label_loss')}</span><span class="c-warn">${(bef.loss || 0).toFixed(2)} bbl/h</span></div>
                <div class="logistics-compare-stat"><span>${ll('label_cost')}</span><span>${logisticsMoney(bef.cost)}</span></div>
                <div class="logistics-compare-stat"><span>${ll('label_eff')}</span><span>${bef.efficiency || 0}%</span></div>
            </div>
            <div class="logistics-compare-arrow">→</div>
            <div class="logistics-compare-col">
                <div class="logistics-compare-hdr">${ll('label_after')}</div>
                <div class="logistics-compare-stat"><span>${ll('label_loss')}</span><span class="${aft.loss < bef.loss ? 'c-good' : 'c-warn'}">${(aft.loss || 0).toFixed(2)} bbl/h</span></div>
                <div class="logistics-compare-stat"><span>${ll('label_cost')}</span><span class="${aft.cost < bef.cost ? 'c-good' : 'c-warn'}">${logisticsMoney(aft.cost)}</span></div>
                <div class="logistics-compare-stat"><span>${ll('label_eff')}</span><span class="${aft.efficiency > bef.efficiency ? 'c-good' : ''}">${aft.efficiency || 0}%</span></div>
            </div>
        </div>`;

        if (result.changed > 0) {
            html += `<div class="logistics-changed-header">🔄 ${ll('changed_count', {count: result.changed})}</div>`;
            html += '<div class="logistics-changes-list">';
            (result.changes || []).forEach(ch => {
                const oldIcon = typeIcons[ch.old_type] || '?';
                const newIcon = typeIcons[ch.new_type] || '?';
                const gainTxt = ch.gain > 0 ? `<span class="c-good">+${ch.gain.toFixed(1)} bbl/h</span>` : '';
                html += `
                <div class="logistics-change-row">
                    <span class="logistics-well-id">#${ch.well_id}</span>
                    <span>${oldIcon} ${ll('type_' + ch.old_type)} → ${newIcon} ${ll('type_' + ch.new_type)}</span>
                    ${gainTxt}
                </div>`;
            });
            html += '</div>';
        } else {
            html += `<div class="logistics-no-changes">✓ ${ll('no_changes')}</div>`;
        }

        resBody.innerHTML = html;
        resBox.style.display = 'block';

        // Uruchom timer cooldown i przywróć footer
        _logisticsResetFooter();
        const runBtn = document.getElementById('btn-logistics-run');
        if (runBtn) startCooldownTimer(runBtn, result.cooldown_secs || 300);

        // Odśwież podsumowanie
        loadLogisticsSummary();

    } catch(e) {
        _logisticsResetFooter();
        resBody.innerHTML = `<div class="c-bad">⚠ ${ll('err')}: ${e.message}</div>`;
        resBox.style.display = 'block';
    }
}

// ── Timer cooldown na przycisku ───────────────────────────────────────────
function startCooldownTimer(btn, secs) {
    if (!window._logisticsRunLabel) {
        window._logisticsRunLabel = '⚡ ' + (ll('run') || 'Uruchom optymalizację');
    }
    let remaining = secs;
    const tick = () => {
        if (remaining <= 0) {
            btn.disabled = false;
            btn.textContent = window._logisticsRunLabel;
            window._logisticsRunLabel = null;
            return;
        }
        const m = Math.floor(remaining / 60);
        const s = remaining % 60;
        btn.disabled  = true;
        btn.textContent = `⏳ ${m}:${String(s).padStart(2, '0')}`;
        remaining--;
        setTimeout(tick, 1000);
    };
    tick();
}
