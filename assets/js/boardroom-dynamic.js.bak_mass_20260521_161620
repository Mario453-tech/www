/**
 * boardroom-dynamic.js — sloty sali zarz¹du
 *
 * Klikniêcie pustego slotu z HR zatrudnionym  dialog wyboru regionu  HRApi
 * Klikniêcie pracownika HR  mini-panel z linkiem do hr.php
 */

var _BRL = window.BR_LANG || {};
function brl(k, p) {
    var s = _BRL[k] || k;
    if (p) Object.keys(p).forEach(function(pk) { s = s.replace(':' + pk, p[pk]); });
    return s;
}

const CX = 50, CY = 58, RX = 30, RY = 16;

const seatPositions = [
    { id:0, angle:360, scale:0.80, role_code:'director',  label:brl('seat_director') },
    // Prawa strona (od dyrektora id¹c zgodnie z ruchem wskazówek zegara)
    { id:1, angle:30,  scale:0.82, role_code:'hr',        label:brl('seat_hr') },        // 1. prawy
    { id:2, angle:48,  scale:0.92, role_code:'technical', label:brl('seat_technical') }, // 2. prawy
    { id:3, angle:92,  scale:1.02, role_code:'finance',   label:brl('seat_finance') },   // 3. prawy
    { id:4, angle:140, scale:1.10, role_code:'legal',     label:brl('seat_legal') },     // 4. prawy
    { id:5, angle:200, scale:1.15, role_code:'logistics', label:brl('seat_logistics') }, // dó³ lewy
    // Lewa strona (puste miejsca)
    { id:6, angle:248, scale:1.10, role_code:null,        label:null },
    { id:7, angle:280, scale:1.02, role_code:null,        label:null },
    { id:8, angle:310, scale:0.92, role_code:null,        label:null },
    { id:9, angle:334, scale:0.80, role_code:null,        label:null },
];

const roleIdMap = phpData.roleIdByCode || {};

function toRad(deg) { return deg * Math.PI / 180; }

function avatarSVG(color='white', size=28) {
    return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="${color}">
        <circle cx="12" cy="7" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
    </svg>`;
}

function avgSkill(c) {
    return (parseInt(c.skill_organization||0)+parseInt(c.skill_negotiation||0)+
            parseInt(c.skill_analysis||0)+parseInt(c.skill_stress||0)+
            parseInt(c.skill_ethics||0))/5;
}

function formatMoney(n) {
    return new Intl.NumberFormat(window.APP_LOCALE,{style:'currency',currency:window.APP_CURRENCY,minimumFractionDigits:0}).format(n);
}

const container = document.getElementById('slots');
const hrMember  = phpData.membersByRole['hr'] || null;

//  T£O SCENY 
(function initSceneBg() {
    const bgEl = document.querySelector('.scene-bg');
    if (!bgEl) return;
    const hasHr   = !!phpData.membersByRole['hr'];
    const hasTech = !!phpData.membersByRole['technical'];
    let img = 'boardroom_bg.png';
    if (hasHr && hasTech) img = 'boardroom_bg_hr_tech.png';
    else if (hasHr)       img = 'boardroom_bg_hr.png';
    bgEl.style.backgroundImage = `url('/assets/images/${img}')`;
    bgEl.style.opacity = '0.85';
})();

function getRecruitmentForRole(code) {
    const id = roleIdMap[code];
    if (!id) return null;
    return phpData.activeRecruitments.find(r => r.role_id == id) || null;
}

//  RENDER 

function render() {
    container.innerHTML = '';

    seatPositions.forEach(seat => {
        if (!seat.role_code && !seat.label) return; // nieaktywne sloty

        const rad = toRad(seat.angle - 90);
        const x   = CX + RX * Math.cos(rad);
        const y   = CY + RY * Math.sin(rad);

        let cls='', avatarColor='white', avatarSize=26, badge='', tooltip='', clickFn=null;

        if (seat.role_code === 'director') {
            cls='slot-director'; avatarColor='#0400ff'; avatarSize=32;
            tooltip=brl('tooltip_director');

        } else if (seat.role_code && phpData.membersByRole[seat.role_code]) {
            const m = phpData.membersByRole[seat.role_code];
            cls='slot-occupied'; avatarColor='#4ec97a';
            tooltip=brl('tooltip_occupied', { role: seat.label, name: m.first_name + ' ' + m.last_name });
            clickFn = seat.role_code === 'hr'
                ? () => showHrPanel(m)
                : seat.role_code === 'technical'
                    ? () => showTechnicalPanel(m)
                    : seat.role_code === 'finance'
                        ? () => showFinancePanel(m)
                        : seat.role_code === 'logistics'
                            ? () => showLogisticsPanel(m)
                            : seat.role_code === 'legal'
                                ? () => showLegalPanel(m)
                                : () => showEmployeeModal(m, seat.label);

        } else if (!seat.role_code) {
            return; // puste sloty bez roli — pomiñ

        } else {
            const roleId = roleIdMap[seat.role_code];
            if (!roleId) {
                return;
            }
            const count  = phpData.candidateCounts[roleId] || 0;
            const rec    = getRecruitmentForRole(seat.role_code);

            if (count > 0) {
                cls='slot-ready'; avatarColor='#e0b644';
                badge=`<div class="recruitment-notification">${count}</div>`;
                tooltip=brl('tooltip_candidates', { role: seat.label, count: count });
                clickFn = () => showCandidatesModal(roleId, seat.label);

            } else if (rec) {
                const mins = Math.max(0, Math.ceil(rec.seconds_remaining/60));
                cls='slot-recruiting'; avatarColor='rgba(179, 56, 56, 0.3)';
                badge=`<div class="hr-badge">&#8987; ~${mins}min</div>`;
                tooltip = hrMember
                    ? brl('tooltip_recruiting', { role: seat.label, name: hrMember.first_name, mins: mins })
                    : brl('tooltip_recruiting_no_hr', { role: seat.label, mins: mins });

            } else if (seat.role_code === 'hr') {
                cls='slot-hr'; avatarColor='#e8cc7a';
                badge=`<div class="hr-badge">${brl('hr_badge_required')}</div>`;
                tooltip=brl('tooltip_hr_required');
                clickFn = () => showDirectorHirePanel(roleId, seat.label);

            } else if (!hrMember) {
                cls='slot-empty'; avatarColor='rgba(255,255,255,0.85)';
                badge=`<div class="hr-badge">${brl('hire_badge')}</div>`;
                tooltip=brl('tooltip_recruit', { role: seat.label });
                clickFn = () => openRecruitDialog(roleId, seat.label);

            } else {
                tooltip=brl('tooltip_recruit', { role: seat.label });
                clickFn = () => openRecruitDialog(roleId, seat.label);
            }
        }

        const div = document.createElement('div');
        div.className = `slot ${cls}`;
        div.style.cssText = `left:${x}%;top:${y}%`;
        div.innerHTML = `
            <div class="slot-avatar" style="transform:scale(${seat.scale})">
                ${badge}
                ${avatarSVG(avatarColor, avatarSize)}
                <div class="slot-num">${seat.label ? seat.label.toUpperCase() : ''}</div>
            </div>
            <div class="slot-tooltip">${tooltip}</div>
        `;
        if (clickFn) { div.style.cursor='pointer'; div.addEventListener('click', clickFn); }
        container.appendChild(div);
    });
}

