//  T£O DYNAMICZNE 

function updateBackground() {
    const bgEl = document.querySelector('.scene-bg');
    if (!bgEl) return;

    const order = ['hr','technical','finance','legal','logistics'];
    const occupied = order.filter(c => phpData.membersByRole[c]);

    if (occupied.length === 0) {
        bgEl.style.backgroundImage = "url('/assets/images/boardroom_bg.png')";
        return;
    }

    // Buduj dwie wersje: z p³ci¹ (boardroom_bg_hr_M_tech_F.png) i bez (boardroom_bg_hr_tech.png)
    const partsWithGender = occupied.map(c => {
        const m = phpData.membersByRole[c];
        const g = (m.gender === 'F') ? 'F' : 'M';
        const s = c === 'technical' ? 'tech' : c;
        return s + '_' + g;
    });
    const partsNoGender = occupied.map(c => c === 'technical' ? 'tech' : c);

    // Lista prób: z p³ci¹  bez p³ci  skrócona z p³ci¹  skrócona bez p³ci  default
    const candidates = [];
    for (let len = partsWithGender.length; len >= 1; len--) {
        candidates.push('boardroom_bg_' + partsWithGender.slice(0, len).join('_') + '.png');
        candidates.push('boardroom_bg_' + partsNoGender.slice(0, len).join('_') + '.png');
    }
    candidates.push('boardroom_bg.png');

    // Usuñ duplikaty
    const unique = [...new Set(candidates)];
    console.log('Trying backgrounds:', unique);

    function tryNext(idx) {
        if (idx >= unique.length) return;
        const url = 'assets/images/' + unique[idx];
        const img = new Image();
        img.onload = () => {
            bgEl.style.backgroundImage = "url('" + url + "')";
            console.log('Background loaded:', unique[idx]);
        };
        img.onerror = () => tryNext(idx + 1);
        img.src = url;
    }
    tryNext(0);
}

