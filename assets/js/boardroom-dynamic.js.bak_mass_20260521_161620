                    onclick="closeModal();fireEmployee(${m.id},'${m.first_name} ${m.last_name}')">
                ${brl('fire_btn')}
            </button>
        </div>
    `);
}

async function fireEmployee(memberId, name) {
    confirmAction(brl('confirm_fire', { name: name }), function () {
        promptInput(
            brl('prompt_fire_reason'),
            brl('prompt_fire_default'),
            async function (reason) {
                const fd = new FormData();
                fd.append('action', 'fire_employee');
                fd.append('_token', phpData.csrfToken);
                fd.append('member_id', memberId);
                fd.append('reason', reason || brl('prompt_fire_default'));

                const res = await fetch('/src/HRApi.php', { method:'POST', body:fd });
                const result = await res.json();

                if (result.success) {
                    showBoardroomToast(brl('toast_fired'), result.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showBoardroomToast(brl('toast_err'), result.message || result.error, true);
                }
            },
            { title: brl('prompt_fire_reason'), confirmLabel: brl('fire_btn') }
        );
    }, { type: 'danger', confirmLabel: brl('fire_btn') });
}

//  MODAL HELPERS 

function openModal(html) {
    let modal = document.getElementById('boardroom-modal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'boardroom-modal';
        modal.className = 'recruitment-modal';
        modal.innerHTML = '<div class="recruitment-panel" id="boardroom-modal-panel"></div>';
        // Zamknij tylko gdy klik bezpoœrednio na overlay (nie na panel)
        modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
        document.body.appendChild(modal);
    }
    const panel = document.getElementById('boardroom-modal-panel');
    panel.innerHTML = html;
    // Klik wewn¹trz panelu NIE zamyka modala
    panel.addEventListener('click', e => e.stopPropagation(), { capture: false });
    modal.classList.add('active');
}

function closeModal() {
    const modal = document.getElementById('boardroom-modal');
    if (modal) modal.classList.remove('active');
}

