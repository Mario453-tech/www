//  DIALOG REKRUTACJI (wybór regionu) 

function openRecruitDialog(roleId, roleName) {
    const regions = [
        {code:'PL', name:brl('region_PL'), dur:brl('region_dur_1'), flag:''},
        {code:'UK', name:brl('region_UK'), dur:brl('region_dur_2'), flag:''},
        {code:'US', name:brl('region_US'), dur:brl('region_dur_4'), flag:''},
        {code:'NO', name:brl('region_NO'), dur:brl('region_dur_4'), flag:''},
        {code:'RU', name:brl('region_RU'), dur:brl('region_dur_1'), flag:''},
        {code:'PH', name:brl('region_PH'), dur:brl('region_dur_4'), flag:''},
        {code:'AE', name:brl('region_AE'), dur:brl('region_dur_4'), flag:''},
    ];

    let selectedRegion = regions[0].code;

    const regionCards = regions.map((r, i) => `
        <div class="recruit-region-card ${i === 0 ? 'selected' : ''}"
             data-code="${r.code}"
             onclick="recruitSelectRegion(this, '${r.code}')">
            <span class="recruit-region-flag">${r.flag}</span>
            <span class="recruit-region-name">${r.name}</span>
            <span class="recruit-region-dur">${r.dur}</span>
        </div>
    `).join('');

    openModal(`
        <div class="recruitment-header">
            <div>
                <div class="recruitment-title">${brl('recruit_title')}</div>
                <div class="recruitment-subtitle">${roleName}</div>
            </div>
            <button class="recruitment-close" onclick="closeModal()">×</button>
        </div>
        <div class="recruitment-content">
            <p class="recruit-note">
                ${hrMember
                    ? `${hrMember.first_name} ${hrMember.last_name} (${brl('hr_panel_title')}) ${brl('recruit_hr_note')}`
                    : brl('recruit_director_note')}
            </p>
            <div class="recruit-region-label">${brl('recruit_region_label')}</div>
            <div class="recruit-region-grid" id="recruit-region-grid">
                ${regionCards}
            </div>
            <input type="hidden" id="dialog-region" value="${selectedRegion}">
        </div>
        <div class="recruitment-actions">
            <button class="btn-recruitment" onclick="closeModal()">${brl('cancel_btn')}</button>
            <button class="btn-recruitment primary" id="submit-recruit-btn">
                ${brl('recruit_submit_btn')}
            </button>
        </div>
    `);

    document.getElementById('submit-recruit-btn')
        .addEventListener('click', () => submitRecruitment(roleId, roleName));
}

function recruitSelectRegion(el, code) {
    document.querySelectorAll('.recruit-region-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('dialog-region').value = code;
}

async function submitRecruitment(roleId, roleName) {
    const region = document.getElementById('dialog-region').value;
    const fd = new FormData();
    fd.append('action', 'start_recruitment');
    fd.append('_token', phpData.csrfToken);
    fd.append('role_id', roleId);
    fd.append('region_code', region);
    fd.append('initiated_by', 'director');

    try {
        const res    = await fetch('/src/HRApi.php', { method:'POST', body:fd });
        const result = await res.json();
        closeModal();
        if (result.success) {
            showBoardroomToast(brl('toast_recruited'), result.message);
            setTimeout(() => location.reload(), 1500);
        } else {
            showBoardroomToast(brl('toast_err'), result.message || result.error, true);
        }
    } catch(e) {
        console.error('submitRecruitment error:', e);
        showBoardroomToast(brl('toast_err'), e.message, true);
    }
}

async function showCandidatesModal(roleId, roleName) {
    // Pobierz kandydatów z HRApi
    const res     = await fetch(`/src/HRApi.php?action=get_candidates&role_id=${roleId}`);
    const data    = await res.json();
    const cands   = data.candidates || [];

    if (cands.length === 0) {
        recruitment.showCandidatesForRole(roleId, roleName);
        return;
    }

    // Sortuj malej¹co po œredniej — najwy¿szy = rekomendacja HR
    cands.sort((a,b) => avgSkill(b) - avgSkill(a));
    const recId = cands[0].id;

    const cards = cands.map(c => {
        const avg  = avgSkill(c).toFixed(1);
        const isRec = c.id == recId;
        const age  = Math.floor((Date.now() - new Date(c.birth_date)) / 31557600000);
        const hoursLeft = Math.max(0, Math.ceil((new Date(c.expires_at) - Date.now()) / 3600000));
        return `
            <div class="candidate-card${isRec ? ' candidate-card--rec' : ''}" data-candidate-id="${c.id}">
                ${isRec ? `<div class="rec-badge">${brl('rec_badge', { name: hrMember ? hrMember.first_name+' '+hrMember.last_name : 'HR' })}</div>` : ''}
                <div class="candidate-header">
                    <div class="candidate-info">
                        <div class="candidate-name">${c.first_name} ${c.last_name}</div>
                        <div class="candidate-meta">
                            <span class="candidate-meta-item">${brl('age', { age: age })}</span>
                            <span class="candidate-meta-item">${brl('experience_meta', { exp: c.experience_years })}</span>
                            <span class="candidate-meta-item">${c.nationality}</span>
                        </div>
                    </div>
                    <div>
                        <div class="candidate-salary">${formatMoney(c.expected_salary)}</div>
                        <div class="candidate-salary-label">${brl('expected_salary')}</div>
                    </div>
                </div>
                <div class="candidate-skills">
                    ${['skill_organization','skill_negotiation','skill_analysis','skill_stress','skill_ethics']
                        .map((k,i) => recruitment.renderSkill([brl('skill_org'),brl('skill_neg'),brl('skill_ana'),brl('skill_str'),brl('skill_eth')][i], c[k])).join('')}
                </div>
                <div class="candidate-experience">
                    <span class="experience-badge">${brl('avg_score', { avg: avg })}</span>
                    &middot; ${brl('expires_in', { h: hoursLeft })}
                </div>
            </div>
        `;
    }).join('');

    openModal(`
        <div class="recruitment-header">
            <div>
                <div class="recruitment-title">${roleName}</div>
                <div class="recruitment-subtitle">${brl('candidates_subtitle', { count: cands.length })}</div>
            </div>
            <button class="recruitment-close" onclick="closeModal()">×</button>
        </div>
        <div class="recruitment-content">${cards}</div>
        <div class="recruitment-actions">
            <button class="btn-recruitment" onclick="closeModal()">${brl('cancel_btn')}</button>
            <button class="btn-recruitment primary" id="hire-btn" onclick="hireBoardroomCandidate()" disabled>
                ${brl('hire_selected_btn')}
            </button>
        </div>
    `);

    // Bind klikniêcia kart
    document.querySelectorAll('.candidate-card').forEach(card => {
        card.addEventListener('click', () => {
            document.querySelectorAll('.candidate-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            window._selectedCandidateId = card.dataset.candidateId;
            document.getElementById('hire-btn').disabled = false;
        });
    });
}

async function hireBoardroomCandidate() {
    const id = window._selectedCandidateId;
    if (!id) return;
    confirmAction(brl('confirm_hire'), async function () {
        const fd = new FormData();
        fd.append('action', 'hire_candidate');
        fd.append('_token', phpData.csrfToken);
        fd.append('candidate_id', id);
        fd.append('contract_type', '1y');

        const res = await fetch('/src/HRApi.php', { method:'POST', body:fd });
        const result = await res.json();

        closeModal();
        if (result.success) {
            showBoardroomToast(brl('toast_hired'), result.message);
            setTimeout(() => { window.location.href = '/dashboard'; }, 1200);
        } else {
            showBoardroomToast(brl('toast_err'), result.message || result.error, true);
        }
    }, { type: 'confirm', confirmLabel: brl('hire_selected_btn') });
}

